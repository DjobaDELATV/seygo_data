  "text": {
    "en": {
      "name": "Goblin Calligrapher",
      "effect": "A Goblin who devotes himself to mastering perfect calligraphy of the word \"False\". He gives his all to each stroke."
    },
    "fr": {
      "name": "Gobelin du Faux",
      "effect": "Ce gobelin s'investit totalement pour ma\u00eetriser la parfaite calligraphie du mot \"Faux\". Son c\u0153ur et son esprit sont pleinement concentr\u00e9s sur son instrument d'\u00e9criture."
    },
    "de": {
      "name": "Goblinf\u00e4lscher",
      "effect": "Ein Goblin, der sich dazu entschlossen hat, die perfekte Schreibweise von \u201eFalsch\u201c zu meistern. Er hat sich mit Leib und Seele dem Federkiel verschrieben."
    },
    "it": {
      "name": "Goblin Fasullo",
      "effect": "Un Goblin che si dedica completamente alla realizzazione del trattato perfetto sul \"Falso\". Concentra sulla penna tutta la sua dedizione e tutto il suo sapere."
    },
    "pt": {
      "name": "Goblin Falso",
      "effect": "Um Goblin que se dedica ao dom\u00ednio perfeito da arte de escrever o \"Falso\". Ele foca todo o seu cora\u00e7\u00e3o e mente no pincel de escrita."
    },
    "es": {
      "name": "Goblin Falso",
      "effect": "Un goblin que se ha dedicado completamente a perfeccionar el arte de escribir la palabra \"Falso\". Concentra toda su mente y coraz\u00f3n en el pincel de escritura."
