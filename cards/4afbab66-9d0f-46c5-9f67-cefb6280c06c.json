      "effect": "\u53ef\u4ee5\u9009\u62e9\u573a\u4e0a\u76841\u53ea\u6548\u679c\u602a\u517d\u8fdb\u884c\u53d1\u52a8\u3002\u9009\u62e9\u7684\u602a\u517d\u4e0d\u53ef\u8fdb\u884c\u653b\u51fb\uff0c\u6548\u679c\u88ab\u65e0\u6548\u5316\u3002\u5f53\u9009\u62e9\u7684\u602a\u517d\u88ab\u7834\u574f\u65f6\uff0c\u7834\u574f\u6b64\u5361\u3002"
