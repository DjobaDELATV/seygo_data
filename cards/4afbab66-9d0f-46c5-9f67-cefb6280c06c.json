{
  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "4afbab66-9d0f-46c5-9f67-cefb6280c06c",
  "text": {
    "en": {
      "name": "Fiendish Chain",
      "effect": "Activate this card by targeting 1 Effect Monster on the field; negate the effects of that face-up monster while it is on the field, also that face-up monster cannot attack. When it is destroyed, destroy this card."
    },
    "fr": {
      "name": "Cha\u00eene D\u00e9moniaque",
      "effect": "Activez cette carte en ciblant 1 Monstre \u00e0 Effet sur le Terrain ; annulez les effets du monstre face recto tant qu'il est sur le Terrain, et aussi, le monstre face recto ne peut pas attaquer. Lorsqu'il est d\u00e9truit, d\u00e9truisez cette carte."
    },
    "de": {
      "name": "Teuflische Kette",
      "effect": "Aktiviere diese Karte, indem du 1 Effektmonster auf dem Spielfeld w\u00e4hlst; annulliere die Effekte jenes offenen Monsters, solange es auf dem Spielfeld liegt, zus\u00e4tzlich kann jenes offene Monster nicht angreifen. Wenn es zerst\u00f6rt wird, zerst\u00f6re diese Karte."
    },
    "it": {
      "name": "Catena Demoniaca",
      "effect": "Attiva questa carta scegliendo come bersaglio 1 Mostro con Effetto sul Terreno; annulla gli effetti di quel mostro scoperto mentre \u00e8 sul Terreno, inoltre quel mostro scoperto non pu\u00f2 attaccare. Quando viene distrutto, distruggi questa carta."
    },
    "pt": {
      "name": "Corrente Demon\u00edaca",
      "effect": "Ative este card ao escolher 1 Monstro de Efeito no campo; negue os efeitos desse monstro com a face para cima enquanto ele estiver no campo e, al\u00e9m disso, esse monstro com a face para cima n\u00e3o pode atacar. Quando ele for destru\u00eddo, destrua este card."
    },
    "es": {
      "name": "Cadena Demon\u00edaca",
      "effect": "Activa esta carta seleccionando 1 Monstruo de Efecto en el Campo; niega los efectos de ese monstruo boca arriba mientras est\u00e9 en el Campo, y adem\u00e1s ese monstruo boca arriba no puede atacar. Cuando es destruido, destruye esta carta."
    },
    "ja": {
      "name": "\u30c7\u30e2\u30f3\u30ba\u30fb\u30c1\u30a7\u30fc\u30f3",
      "effect": "\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u52b9\u679c\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u5bfe\u8c61\u3068\u3057\u3066\u3053\u306e\u30ab\u30fc\u30c9\u3092\u767a\u52d5\u3067\u304d\u308b\u3002\u2460\uff1a\u3053\u306e\u30ab\u30fc\u30c9\u304c\u9b54\u6cd5\uff06\u7f60\u30be\u30fc\u30f3\u306b\u5b58\u5728\u3059\u308b\u9650\u308a\u3001\u5bfe\u8c61\u306e\u8868\u5074\u8868\u793a\u30e2\u30f3\u30b9\u30bf\u30fc\u306f\u653b\u6483\u3067\u304d\u305a\u3001\u52b9\u679c\u306f\u7121\u52b9\u5316\u3055\u308c\u308b\u3002\u5bfe\u8c61\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\u7834\u58ca\u3055\u308c\u305f\u6642\u306b\u3053\u306e\u30ab\u30fc\u30c9\u306f\u7834\u58ca\u3055\u308c\u308b\u3002"
    },
    "ko": {
      "name": "\ub370\uba3c\uc988 \uccb4\uc778",
      "effect": "\ud544\ub4dc\uc758 \ud6a8\uacfc \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ub300\uc0c1\uc73c\ub85c \ud558\uace0 \uc774 \uce74\ub4dc\ub97c \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \u2460: \uc774 \uce74\ub4dc\uac00 \ub9c8\ubc95 & \ud568\uc815 \uc874\uc5d0 \uc874\uc7ac\ud558\ub294 \ud55c, \ub300\uc0c1\uc758 \uc55e\uba74 \ud45c\uc2dc \ubaac\uc2a4\ud130\ub294 \uacf5\uaca9\ud560 \uc218 \uc5c6\uc73c\uba70, \ud6a8\uacfc\ub294 \ubb34\ud6a8\ud654\ub41c\ub2e4. \ub300\uc0c1 \ubaac\uc2a4\ud130\uac00 \ud30c\uad34\ub418\uc5c8\uc744 \ub54c\uc5d0 \uc774 \uce74\ub4dc\ub294 \ud30c\uad34\ub41c\ub2e4."
    },
    "zh-TW": {
