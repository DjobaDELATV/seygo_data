  "text": {
    "en": {
      "name": "Secret Village of the Spellcasters",
      "effect": "If only you control a Spellcaster monster, your opponent cannot activate Spell Cards. If you control no Spellcaster monsters, you cannot activate Spell Cards."
    },
    "fr": {
      "name": "Village Secret des Magiciens",
      "effect": "Si vous seul contr\u00f4lez un monstre Magicien, votre adversaire ne peut pas activer de Cartes Magie. Si vous ne contr\u00f4lez aucun monstre Magicien, vous ne pouvez pas activer de Cartes Magie."
    },
    "de": {
      "name": "Geheimes Dorf der Hexer",
      "effect": "Falls nur du ein Hexer-Monster kontrollierst, kann dein Gegner keine Zauberkarten aktivieren. Falls du keine Hexer-Monster kontrollierst, kannst du keine Zauberkarten aktivieren."
    },
    "it": {
      "name": "Villaggio Segreto degli Incantatori",
      "effect": "Se solo tu controlli un mostro Incantatore, il tuo avversario non pu\u00f2 attivare Carte Magia. Se tu non controlli nessun mostro Incantatore, non puoi attivare Carte Magia."
    },
    "pt": {
      "name": "Vila Secreta dos Magos",
      "effect": "Se somente voc\u00ea controlar um monstro Mago, seu oponente n\u00e3o pode ativar Cards de Magia. Se voc\u00ea n\u00e3o controlar nenhum monstro Mago, voc\u00ea n\u00e3o pode ativar Cards de Magia."
    },
    "es": {
      "name": "Pueblo Secreto de los Magos",
      "effect": "Si s\u00f3lo t\u00fa controlas un monstruo Lanzador de Conjuros, tu adversario no puede activar Cartas M\u00e1gicas. Si no controlas monstruos Lanzador de Conjuros, no puedes activar Cartas M\u00e1gicas."
    },
