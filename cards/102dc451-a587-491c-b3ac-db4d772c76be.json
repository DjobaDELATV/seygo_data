  "text": {
    "en": {
      "name": "Fusion Gate",
      "effect": "During the Main Phase: The turn player can Fusion Summon 1 Fusion Monster from their Extra Deck, by banishing Fusion Materials mentioned on it from their hand or field."
    },
    "fr": {
      "name": "Portail de Fusion",
      "effect": "Durant la Main Phase : le joueur du tour peut Invoquer par Fusion 1 Monstre Fusion depuis son Extra Deck, en bannissant les Mat\u00e9riels Fusion mentionn\u00e9s sur celui-ci depuis sa main ou Terrain."
    },
    "de": {
      "name": "Fusionstor",
      "effect": "W\u00e4hrend der Main Phase: Der Zugspieler kann 1 Fusionsmonster als Fusionsbeschw\u00f6rung von seinem Extra Deck beschw\u00f6ren, indem er das auf ihm erw\u00e4hnte Fusionsmaterial von seiner Hand oder Spielfeldseite verbannt."
    },
    "it": {
      "name": "Cancello della Fusione",
      "effect": "Durante la Main Phase: il giocatore di turno pu\u00f2 Evocare tramite Fusione 1 Mostro Fusione dal suo Extra Deck, bandendo i Materiali da Fusione menzionati su di esso dalla sua mano o Terreno."
    },
    "pt": {
      "name": "Portal de Fus\u00e3o",
      "effect": "Durante a Fase Principal: o duelista do turno pode Invocar por Invoca\u00e7\u00e3o-Fus\u00e3o 1 Monstro de Fus\u00e3o do Deck Adicional dele, banindo as Mat\u00e9rias de Fus\u00e3o mencionadas nele da sua m\u00e3o ou do campo."
    },
    "es": {
      "name": "Puerta de Fusi\u00f3n",
      "effect": "Durante la Main Phase: el jugador en turno puede Invocar por Fusi\u00f3n 1 Monstruo de Fusi\u00f3n desde su Deck Extra, desterrando de su mano o Campo los Materiales de Fusi\u00f3n mencionados en \u00e9l."
    },
    "ja": {
