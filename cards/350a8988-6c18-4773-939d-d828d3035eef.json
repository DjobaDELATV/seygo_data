  "id": "350a8988-6c18-4773-939d-d828d3035eef",
  "text": {
    "en": {
      "name": "Psi-Blocker",
      "effect": "Once per turn: You can declare 1 card name; cards with that name, and their effects, cannot be used until the End of your opponent's next turn."
    },
    "fr": {
      "name": "Inhibiteur Psi",
      "effect": "Une fois par tour : vous pouvez d\u00e9clarer 1 nom de carte ; jusqu'\u00e0 la fin du prochain tour de votre adversaire, les cartes de ce nom et leurs effets ne peuvent pas \u00eatre utilis\u00e9s."
    },
    "de": {
      "name": "Psi-Blocker",
      "effect": "Einmal pro Spielzug: Du kannst 1 Kartennamen benennen; Karten mit dem benannten Namen und ihre Effekte k\u00f6nnen bis zum Ende des n\u00e4chsten Spielzugs deines Gegners nicht verwendet werden."
    },
    "it": {
      "name": "Bloccatore Psichico",
      "effect": "Una volta per turno: puoi dichiarare il nome di 1 carta; le carte con quel nome, ed i loro effetti, non possono essere utilizzati fino alla fine del prossimo turno del tuo avversario."
    },
    "es": {
      "name": "Bloqueador Psi",
      "effect": "Una vez por turno: puedes declarar el nombre de 1 carta; las cartas con ese nombre, y sus efectos, no pueden ser utilizados hasta el final del pr\u00f3ximo turno de tu adversario."
    },
    "ja": {
      "name": "\u30b5\u30a4\u30ad\u30c3\u30af\u30fb\u30d6\u30ed\u30c3\u30ab\u30fc",
      "effect": "\u2460\uff1a\uff11\u30bf\u30fc\u30f3\u306b\uff11\u5ea6\u3001\u30ab\u30fc\u30c9\u540d\u3092\uff11\u3064\u5ba3\u8a00\u3057\u3066\u767a\u52d5\u3067\u304d\u308b\u3002\u76f8\u624b\u30bf\u30fc\u30f3\u7d42\u4e86\u6642\u307e\u3067\u306e\u9593\u3001\u5ba3\u8a00\u3055\u308c\u305f\u30ab\u30fc\u30c9\u540d\u3092\u5143\u3005\u306e\u30ab\u30fc\u30c9\u540d\u3068\u3059\u308b\u304a\u4e92\u3044\u306e\u30ab\u30fc\u30c9\u306b\u4ee5\u4e0b\u3092\u9069\u7528\u3059\u308b\u3002\u25cf\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u51fa\u3059\u4e8b\u304c\u3067\u304d\u306a\u3044\u3002\u25cf\u30ab\u30fc\u30c9\u306e\u767a\u52d5\u53ca\u3073\u52b9\u679c\u306e\u767a\u52d5\u3068\u9069\u7528\u304c\u3067\u304d\u306a\u3044\u3002\u25cf\u901a\u5e38\u53ec\u559a\u30fb\u53cd\u8ee2\u53ec\u559a\u30fb\u7279\u6b8a\u53ec\u559a\u3067\u304d\u306a\u3044\u3002\u25cf\u653b\u6483\u53ca\u3073\u8868\u793a\u5f62\u5f0f\u306e\u5909\u66f4\u304c\u3067\u304d\u306a\u3044\u3002\u25cf\u7d20\u6750\u3092\u5fc5\u8981\u3068\u3059\u308b\u7279\u6b8a\u53ec\u559a\u306e\u305f\u3081\u306e\u7d20\u6750\u306b\u3067\u304d\u306a\u3044\u3002"
    },
    "ko": {
      "name": "\uc0ac\uc774\ud0a5 \ube14\ub85c\ucee4",
      "effect": "\u2460: 1\ud134\uc5d0 1\ubc88, \uce74\ub4dc\uba85\uc744 1\uac1c \uc120\uc5b8\ud558\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uc0c1\ub300 \ud134 \uc885\ub8cc\uc2dc\uae4c\uc9c0 \ub3d9\uc548, \uc120\uc5b8\ub41c \uce74\ub4dc\uba85\uc744 \uc6d0\ub798 \uce74\ub4dc\uba85\uc73c\ub85c \ud558\ub294 \uc11c\ub85c\uc758 \uce74\ub4dc\uc5d0 \uc774\ud558\ub97c \uc801\uc6a9\ud55c\ub2e4. \u25cf\ud544\ub4dc\uc5d0 \ub0bc \uc218 \uc5c6\ub2e4. \u25cf\uce74\ub4dc\uc758 \ubc1c\ub3d9 \ubc0f \ud6a8\uacfc\uc758 \ubc1c\ub3d9\uacfc \uc801\uc6a9\uc744 \ud560 \uc218 \uc5c6\ub2e4. \u25cf\ud1b5\uc0c1 \uc18c\ud658 / \ubc18\uc804 \uc18c\ud658 / \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc5c6\ub2e4. \u25cf\uacf5\uaca9 \ubc0f \ud45c\uc2dc \ud615\uc2dd\uc758 \ubcc0\uacbd\uc744 \ud560 \uc218 \uc5c6\ub2e4. \u25cf\uc18c\uc7ac\ub97c \ud544\uc694\ub85c \ud558\ub294 \ud2b9\uc218 \uc18c\ud658\uc744 \uc704\ud55c \uc18c\uc7ac\ub85c \ud560 \uc218 \uc5c6\ub2e4."
    },
    "zh-CN": {
      "name": "\u5ff5\u52a8\u529b\u963b\u6321\u8005",
      "effect": "\u2460\uff1a1\u56de\u54081\u6b21\uff0c\u5ba3\u8a001\u4e2a\u5361\u540d\u53ef\u4ee5\u53d1\u52a8\u3002\u76f4\u81f3\u5bf9\u624b\u56de\u5408\u7ed3\u675f\u65f6\u4e3a\u6b62\uff0c\u539f\u672c\u5361\u540d\u4e0e\u5ba3\u8a00\u7684\u5361\u540d\u76f8\u540c\u7684\u3001\u53cc\u65b9\u7684\u5361\u9002\u7528\u4ee5\u4e0b\u5185\u5bb9\u3002\u25cf\u4e0d\u53ef\u51fa\u5230\u573a\u4e0a\u3002\u25cf\u4e0d\u53ef\u5c06\u5361\u53d1\u52a8\u53ca\u5c06\u6548\u679c\u53d1\u52a8\u548c\u9002\u7528\u3002\u25cf\u4e0d\u53ef\u901a\u5e38\u53ec\u5524\u30fb\u53cd\u8f6c\u53ec\u5524\u30fb\u7279\u6b8a\u53ec\u5524\u3002\u25cf\u4e0d\u53ef\u653b\u51fb\u53ca\u53d8\u66f4\u8868\u793a\u5f62\u5f0f\u3002\u25cf\u4e0d\u53ef\u4f5c\u4e3a\u7528\u4e8e\u9700\u8981\u7d20\u6750\u7684\u7279\u6b8a\u53ec\u5524\u7684\u7d20\u6750\u3002"
