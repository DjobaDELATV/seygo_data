{
  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "3df6dba8-988b-4eb1-9889-2a5990d8a2bd",
  "text": {
    "en": {
      "name": "Mathematician",
      "effect": "When this card is Normal Summoned: You can send 1 Level 4 or lower monster from your Deck to the GY. When this card is destroyed by battle and sent to the GY: You can draw 1 card."
    },
    "fr": {
      "name": "Math\u00e9maticien",
      "effect": "Lorsque cette carte est Invoqu\u00e9e Normalement : vous pouvez envoyer 1 monstre de max. Niveau 4 depuis votre Deck au Cimeti\u00e8re. Lorsque cette carte est d\u00e9truite au combat et envoy\u00e9e au Cimeti\u00e8re : vous pouvez piocher 1 carte."
    },
    "de": {
      "name": "Der Mathematiker",
      "effect": "Wenn diese Karte als Normalbeschw\u00f6rung beschworen wird: Du kannst 1 Monster der Stufe 4 oder niedriger von deinem Deck auf den Friedhof legen. Wenn diese Karte durch Kampf zerst\u00f6rt und auf den Friedhof gelegt wird: Du kannst 1 Karte ziehen."
    },
    "it": {
      "name": "Il Matematico",
      "effect": "Quando questa carta viene Evocata Normalmente: puoi mandare 1 mostro di Livello 4 o inferiore dal tuo Deck al Cimitero. Quando questa carta viene distrutta in battaglia e mandata al Cimitero: puoi pescare 1 carta."
    },
    "pt": {
      "name": "Matem\u00e1tico",
      "effect": "Quando este card for Invocado por Invoca\u00e7\u00e3o-Normal: voc\u00ea pode enviar 1 monstro de N\u00edvel 4 ou menos do seu Deck para o Cemit\u00e9rio. Quando este card for destru\u00eddo em batalha e enviado para o Cemit\u00e9rio: voc\u00ea pode comprar 1 card."
    },
    "es": {
      "name": "Matem\u00e1tico",
      "effect": "Cuando esta carta es Invocada de Modo Normal: puedes mandar al Cementerio 1 monstruo de Nivel 4 o menor en tu Deck. Cuando esta carta es destruida en batalla y mandada al Cementerio: puedes robar 1 carta."
    },
    "ja": {
      "name": "\u30de\u30b9\u30de\u30c6\u30a3\u30b7\u30e3\u30f3",
