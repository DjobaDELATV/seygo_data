    "en": {
      "name": "Delta Crow - Anti Reverse",
      "effect": "If you control a \"Blackwing\" monster: Destroy all face-down Spells/Traps your opponent controls. If you control exactly 3 \"Blackwing\" monsters, you can activate this card from your hand."
    },
    "fr": {
      "name": "Corbeaux Delta - Anti Retournement",
      "effect": "Si vous contr\u00f4lez un monstre \"Aile Noire\" : d\u00e9truisez toutes les Magies et tous les Pi\u00e8ges face verso contr\u00f4l\u00e9s par votre adversaire. Si vous contr\u00f4lez exactement 3 monstres \"Aile Noire\", vous pouvez activer cette carte depuis votre main."
    },
