  "text": {
    "en": {
      "name": "X-Head Cannon",
      "effect": "A monster with a mighty cannon barrel, it is able to integrate its attacks. It attacks in many ways by combining and separating with other monsters."
    },
    "fr": {
      "name": "T\u00eate de Canon X",
      "effect": "Monstre dot\u00e9 d'un puissant canon, il utilise la technique d'int\u00e9gration pour mener ses combats. Il attaque la plupart du temps en s'associant ou se dissociant d'autres monstres."
    },
    "de": {
      "name": "X-Kopfkanone",
      "effect": "Ein Monster mit gewaltigen Kanonenl\u00e4ufen, die es f\u00fcr Angriffe benutzen kann. Es greift auf verschiedene Arten an, indem es sich mit anderen Monstern verbindet und wieder trennt."
    },
    "it": {
      "name": "X-Testa Cannone",
      "effect": "Un mostro con un imponente cannone, \u00e8 in grado di integrare i propri attacchi. Attacca in modi diversi unendosi e separandosi da altri mostri."
    },
    "pt": {
      "name": "Cabe\u00e7a de Canh\u00e3o X",
      "effect": "Um monstro com um poderoso tambor de canh\u00f5es, capaz de integrar os seus ataques. Ele ataca de muitas maneiras, combinando-se e separando-se de outros monstros."
    },
    "es": {
      "name": "X-Cabeza Ca\u00f1\u00f3n",
      "effect": "Un monstruo con un poderoso ca\u00f1\u00f3n, es capaz de integrar sus ataques. Ataca de muchas formas combin\u00e1ndose y separ\u00e1ndose de otros monstruos."
    },
    "ja": {
