      "effect": "\u9009\u62e9\u6211\u65b9\u5893\u5730\u76841\u53ea\u602a\u517d\uff0c\u5e76\u4ee5\u8868\u4fa7\u653b\u51fb\u8868\u793a\u8fdb\u884c\u7279\u6b8a\u53ec\u5524\u3002\u5f53\u6b64\u5361\u79bb\u5f00\u573a\u4e0a\u65f6\uff0c\u7834\u574f\u8be5\u602a\u517d\u3002\u5f53\u8be5\u602a\u517d\u88ab\u7834\u574f\u65f6\uff0c\u7834\u574f\u6b64\u5361\u3002"
    },
    "zh-CN": {
