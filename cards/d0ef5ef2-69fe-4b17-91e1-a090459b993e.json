  "text": {
    "en": {
      "name": "Dust Tornado",
      "effect": "Target 1 Spell/Trap your opponent controls; destroy that target, then you can Set 1 Spell/Trap from your hand."
    },
    "fr": {
      "name": "Tornade de Poussi\u00e8re",
      "effect": "Ciblez 1 Magie/Pi\u00e8ge contr\u00f4l\u00e9 par votre adversaire ; d\u00e9truisez la cible, puis vous pouvez Poser 1 Magie/Pi\u00e8ge depuis votre main."
    },
    "de": {
      "name": "Staubtornado",
      "effect": "W\u00e4hle 1 Zauber/Falle, den oder die dein Gegner kontrolliert; zerst\u00f6re jenes gew\u00e4hlte Ziel, dann kannst du 1 Zauber/Falle von deiner Hand setzen."
    },
    "it": {
      "name": "Tornado di Polvere",
      "effect": "Scegli come bersaglio 1 Magia/Trappola controllata dal tuo avversario; distruggi quel bersaglio, poi puoi Posizionare 1 Magia/Trappola dalla tua mano."
    },
    "pt": {
      "name": "Tornado de P\u00f3",
      "effect": "Escolha 1 Magia/Armadilha que seu oponente controla; destrua o alvo e, depois, voc\u00ea pode Baixar 1 Magia/Armadilha da sua m\u00e3o."
    },
    "es": {
      "name": "Tornado de Polvo",
      "effect": "Selecciona 1 M\u00e1gica/Trampa que controle tu adversario; destruye ese objetivo, y despu\u00e9s puedes Colocar 1 M\u00e1gica/Trampa en tu mano."
    },
