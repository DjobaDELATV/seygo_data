  "text": {
    "en": {
      "name": "Stop Defense",
      "effect": "Target 1 Defense Position monster your opponent controls; change that target to Attack Position."
    },
    "fr": {
      "name": "Stop D\u00e9fense",
      "effect": "S\u00e9lectionnez 1 des monstres de votre adversaire et passez-le en Position d'Attaque. Si la carte est face verso, retournez-la face recto. Si la carte a un Effet Flip, celui-ci est imm\u00e9diatement Activ\u00e9e."
    },
    "de": {
      "name": "Verteidigung stoppen",
      "effect": "W\u00e4hle 1 Monster in Verteidigungsposition auf der Spielfeldseite deines Gegners und bringe es in offene Angriffsposition."
    },
    "it": {
      "name": "Blocca Difesa",
      "effect": "Seleziona 1 dei mostri dell'avversario e cambiane la posizione in Posizione di Attacco. Se la carta \u00e8 coperta, scoprila. Se la carta ha un Effetto Scoperta, questo viene attivato immediatamente."
    },
    "pt": {
      "name": "Impedir a Defesa",
      "effect": "Escolha 1 monstro no Campo do seu advers\u00e1rio e mude-o para a Posi\u00e7\u00e3o de Ataque. Se o card estiver com a face para baixo, vire a face para cima. Se o card tiver algum efeito, ele \u00e9 Activado imediatamente."
    },
    "es": {
      "name": "Parar la Defensa",
      "effect": "Selecciona 1 monstruo en Posici\u00f3n de Defensa en el Campo de tu adversario y cambialo a Posici\u00f3n de Ataque boca arriba."
    },
