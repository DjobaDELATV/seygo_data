    },
    "zh-CN": {
      "name": "\u661f\u5e9f\u54c1\u540c\u6b65\u58eb",
      "effect": "\u6b64\u5361\u53ef\u4ee3\u66ff\u201c\u540c\u6b65\u58eb\u201d\u534f\u8c03\u4f5c\u4e3a\u540c\u6b65\u7d20\u6750\u3002\u6b64\u5361\u540d\u7684\u2460\u2461\u6548\u679c1\u56de\u5408\u4ec5\u53ef\u5404\u4f7f\u75281\u6b21\u3002\u2460\uff1a\u6b64\u5361\u5b58\u5728\u4e8e\u624b\u724c\u7684\u60c5\u51b5\u4e0b\uff0c\u4ee5\u81ea\u5df1\u5893\u5730\u76841\u53ea\u7b49\u7ea72\u4ee5\u4e0b\u7684\u602a\u517d\u4e3a\u5bf9\u8c61\u53ef\u4ee5\u53d1\u52a8\u3002\u5c06\u6b64\u5361\u7279\u6b8a\u53ec\u5524\uff0c\u5c06\u5bf9\u8c61\u602a\u517d\u7684\u6548\u679c\u65e0\u6548\u5e76\u7279\u6b8a\u53ec\u5524\u3002\u6b64\u56de\u5408\uff0c\u81ea\u5df1\u4ece\u989d\u5916\u724c\u7ec4\u4ec5\u53ef\u7279\u6b8a\u53ec\u5524\u540c\u6b65\u602a\u517d\u3002\u2461\uff1a\u5c06\u5893\u5730\u7684\u6b64\u5361\u9664\u5916\u53ef\u4ee5\u53d1\u52a8\u3002\u6b64\u56de\u5408\u4e2d\uff0c\u81ea\u5df1\u573a\u4e0a\u7684\u201c\u5e9f\u54c1\u6218\u58eb\u201d\u4e0d\u4f1a\u56e0\u5bf9\u624b\u7684\u6548\u679c\u800c\u88ab\u7834\u574f\u3002"
