  "text": {
    "en": {
      "name": "Left Leg of the Forbidden One",
      "effect": "A forbidden left leg sealed by magic. Whosoever breaks this seal will know infinite power."
    },
    "fr": {
      "name": "Jambe Gauche de l'Interdit",
      "effect": "Jambe gauche interdite scell\u00e9e par la magie. Toute personne rompant ce sceau conna\u00eetra la puissance infinie."
    },
    "de": {
      "name": "Linkes Bein der Verbotenen",
      "effect": "Ein verbanntes linkes Bein, das durch einen Zauber versiegelt ist. Wer dieses Siegel bricht, erh\u00e4lt unbegrenzte Macht."
    },
    "it": {
      "name": "Gamba Sx del Proibito",
      "effect": "Una gamba sinistra proibita resa inaccessibile dalla magia. Chiunque rompa il sigillo che la chiude conoscer\u00e0 potenza infinita."
    },
    "pt": {
      "name": "Perna Esquerda de \"O Proibido\"",
      "effect": "Uma perna esquerda, proibida e selada por magia. Qualquer um que romper este selo obter\u00e1 poder infinito."
    },
    "es": {
      "name": "Pierna Izquierda del Prohibido",
      "effect": "Una pierna izquierda prohibida, sellada m\u00e1gicamente. Quienquiera que rompa este sello conocer\u00e1 el poder infinito."
    },
    "ja": {
