  "text": {
    "en": {
      "name": "Magical Musket - Dancing Needle",
      "effect": "If you control a \"Magical Musket\" monster: Target up to 3 cards in the GYs; banish them. You can only activate 1 \"Magical Musket - Dancing Needle\" per turn."
    },
    "fr": {
      "name": "Magie de Mousquet - Aiguille Dansante",
      "effect": "Si vous contr\u00f4lez un monstre \"Magie de Mousquet\" : ciblez max. 3 cartes dans les Cimeti\u00e8res ; bannissez-les. Vous ne pouvez activer qu'1 \"Magie de Mousquet - Aiguille Dansante\" par tour."
    },
    "de": {
      "name": "Magische Muskete - Tanzende Nadel",
      "effect": "Falls du ein \u201eMagische/r Musket\u201c-Monster kontrollierst: W\u00e4hle bis zu 3 Karten in den Friedh\u00f6fen; verbanne sie. Du kannst nur 1 \u201eMagische Muskete - Tanzende Nadel\u201c pro Spielzug aktivieren."
    },
