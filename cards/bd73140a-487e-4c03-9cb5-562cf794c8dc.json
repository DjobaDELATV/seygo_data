  "text": {
    "en": {
      "name": "Scrap Crash",
      "effect": "Activate only when a \"Scrap\" monster you control is destroyed and sent to the Graveyard. Destroy all face-up Spell/Trap Cards on the field."
    },
    "fr": {
      "name": "\u00c9crasement de Ferraille",
      "effect": "Activable uniquement lorsqu'un monstre \"Ferraille\" que vous contr\u00f4lez est d\u00e9truit et envoy\u00e9 au Cimeti\u00e8re. D\u00e9truisez toutes les Cartes Magie et Pi\u00e8ge face recto sur le Terrain."
    },
    "de": {
      "name": "Schrott-Zusammensto\u00df",
      "effect": "Aktiviere diese Karte nur, wenn ein \u201eSchrott\u201c-Monster, das du kontrollierst, zerst\u00f6rt und auf den Friedhof gelegt wird. Zerst\u00f6re alle offenen Zauber-/Fallenkarten auf dem Spielfeld."
    },
    "it": {
