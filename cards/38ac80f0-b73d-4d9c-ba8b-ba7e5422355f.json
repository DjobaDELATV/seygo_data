  "text": {
    "en": {
      "name": "Inmato",
      "effect": "When 1 other face-up Plant-Type monster is targeted by the effect of a Spell or Trap Card your opponent controls, you can Tribute this card to draw 2 cards."
    },
    "fr": {
      "name": "Prisomate",
      "effect": "Lorsqu'1 autre monstre de Type Plante face recto est cibl\u00e9 par l'effet d'une Carte Magie ou Pi\u00e8ge contr\u00f4l\u00e9e par votre adversaire, vous pouvez Sacrifier cette carte pour piocher 2 cartes."
    },
    "de": {
      "name": "Insassomate",
      "effect": "Wenn 1 anderes offenes Monster vom Typ Pflanze als Ziel f\u00fcr den Effekt einer Zauber- oder Fallenkarte, die dein Gegner kontrolliert, gew\u00e4hlt wird, kannst du diese Karte als Tribut anbieten, um 2 Karten zu ziehen."
    },
    "it": {
