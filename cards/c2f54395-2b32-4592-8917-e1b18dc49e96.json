    },
    "ko": {
      "name": "\uc2ec\uc5f0\uc758 \uc554\uc0b4\uc790",
      "effect": "\u2460: \uc774 \uce74\ub4dc\uac00 \ub9ac\ubc84\uc2a4\ud588\uc744 \uacbd\uc6b0, \uc0c1\ub300 \ud544\ub4dc\uc758 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ub300\uc0c1\uc73c\ub85c \ud558\uace0 \ubc1c\ub3d9\ud55c\ub2e4. \uadf8 \uc0c1\ub300 \ubaac\uc2a4\ud130\ub97c \ud30c\uad34\ud55c\ub2e4. \u2461: \uc774 \uce74\ub4dc\uac00 \ud328\uc5d0\uc11c \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uc84c\uc744 \uacbd\uc6b0, \"\uc2ec\uc5f0\uc758 \uc554\uc0b4\uc790\" \uc774\uc678\uc758 \uc790\uc2e0 \ubb18\uc9c0\uc758 \ub9ac\ubc84\uc2a4 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ub300\uc0c1\uc73c\ub85c \ud558\uace0 \ubc1c\ub3d9\ud55c\ub2e4. \uadf8 \ubaac\uc2a4\ud130\ub97c \ud328\uc5d0 \ub123\ub294\ub2e4."
    }
