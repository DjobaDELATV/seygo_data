  "id": "c2f54395-2b32-4592-8917-e1b18dc49e96",
  "text": {
    "en": {
      "name": "Night Assailant",
      "effect": "FLIP: Target 1 monster your opponent controls; destroy that target.\nIf this card is sent from the hand to the GY: Target 1 Flip monster in your GY, except \"Night Assailant\"; add that target to your hand."
    },
    "fr": {
      "name": "Agresseur Nocturne",
      "effect": "FLIP : Ciblez 1 monstre contr\u00f4l\u00e9 par votre adversaire ; d\u00e9truisez la cible.\nSi cette carte est envoy\u00e9e depuis la main au Cimeti\u00e8re : ciblez 1 monstre Flip (\"Agresseur Nocturne\" exclu) dans votre Cimeti\u00e8re ; ajoutez la cible \u00e0 votre main."
    },
    "de": {
      "name": "N\u00e4chtlicher Angreifer",
      "effect": "FLIPP: W\u00e4hle 1 Monster, das dein Gegner kontrolliert; zerst\u00f6re jenes gew\u00e4hlte Ziel.\nFalls diese Karte von der Hand auf den Friedhof gelegt wird: W\u00e4hle 1 Flippmonster in deinem Friedhof, au\u00dfer \u201eN\u00e4chtlicher Angreifer\u201c; f\u00fcge jenes gew\u00e4hlte Ziel deiner Hand hinzu."
    },
    "it": {
      "name": "Assalitore Notturno",
      "effect": "SCOPRI: Scegli come bersaglio 1 mostro controllato dal tuo avversario; distruggi quel bersaglio.\nSe questa carta viene mandata dalla mano al Cimitero: scegli come bersaglio 1 mostro Scoperta nel tuo Cimitero, eccetto \"Assalitore Notturno\"; aggiungi quel bersaglio alla tua mano."
    },
    "pt": {
      "name": "Assaltante Noturno",
      "effect": "VIRE: Escolha 1 monstro que seu oponente controla; destrua o alvo.\nSe este card for enviado da m\u00e3o para o Cemit\u00e9rio: escolha 1 monstro de Virar no seu Cemit\u00e9rio, exceto \"Assaltante Noturno\"; adicione o alvo \u00e0 sua m\u00e3o."
    },
    "es": {
      "name": "Asaltante Nocturno",
      "effect": "VOLTEO: Selecciona 1 monstruo que controle tu adversario; destruye ese objetivo.\nSi esta carta es mandada de la mano al Cementerio: selecciona 1 monstruo de Volteo en tu Cementerio, excepto \"Asaltante Nocturno\"; a\u00f1ade ese objetivo a tu mano."
    },
    "ja": {
