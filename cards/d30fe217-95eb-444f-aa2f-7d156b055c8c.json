      "effect": "\u2460\uff1a\u4ee5\u81ea\u5df1\u5893\u5730\u7684\uff11\u53ea\u4e0d\u6b7b\u65cf\u602a\u517d\u548c\u5bf9\u624b\u5893\u5730\u7684\uff11\u53ea\u602a\u517d\u4e3a\u5bf9\u8c61\u53ef\u4ee5\u53d1\u52a8\u3002\u5c06\u8be5\u81ea\u5df1\u7684\u4e0d\u6b7b\u65cf\u602a\u517d\u7279\u6b8a\u53ec\u5524\u3002\u5c06\u8be5\u5bf9\u624b\u7684\u602a\u517d\u9664\u5916\u3002"
