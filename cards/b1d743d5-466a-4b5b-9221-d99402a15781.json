  "text": {
    "en": {
      "name": "Stamping Destruction",
      "effect": "If you control a Dragon monster: Target 1 Spell/Trap on the field; destroy that target, and if you do, inflict 500 damage to its controller."
    },
    "fr": {
      "name": "\u00c9crasement Destructeur",
      "effect": "Si vous contr\u00f4lez un monstre Dragon : ciblez 1 Magie/Pi\u00e8ge sur le Terrain ; d\u00e9truisez la cible, et si vous le faites, infligez 500 points de dommages \u00e0 son contr\u00f4leur."
    },
    "de": {
      "name": "Stampfende Zerst\u00f6rung",
      "effect": "Falls du ein Drache-Monster kontrollierst: W\u00e4hle 1 Zauber/Falle auf dem Spielfeld; zerst\u00f6re jenes gew\u00e4hlte Ziel und falls du dies tust, f\u00fcge seinem Beherrscher 500 Schaden zu."
    },
    "it": {
      "name": "Distruzione Schiacciante",
      "effect": "Se controlli un mostro Drago: scegli come bersaglio 1 Magia/Trappola sul Terreno; distruggi quel bersaglio e, se lo fai, infliggi 500 danni al suo controllore."
    },
