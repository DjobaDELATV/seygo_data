      "effect": "\u6b64\u5361\u53ef\u65e0\u987b\u91ca\u653e\u901a\u5e38\u53ec\u5524\u3002\u4ee5\u6b64\u65b9\u5f0f\u901a\u5e38\u53ec\u5524\u7684\u6b64\u5361\uff0c\u5176\u539f\u672c\u7684\u653b\u51fb\u529b\u53d8\u4e3a1900\u3002\u6b64\u5916\uff0c\u6b64\u5361\u53ef\u91ca\u653e3\u53ea\u602a\u517d\u5e76\u53ec\u5524\u3002\u4ee5\u6b64\u65b9\u6cd5\u6210\u529f\u53ec\u5524\u65f6\uff0c\u7834\u574f\u5bf9\u624b\u573a\u4e0a\u7684\u5168\u90e8\u5361\u724c\u3002"
