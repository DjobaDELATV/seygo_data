    "en": {
      "name": "Hieracosphinx",
      "effect": "Your opponent cannot select a face-down Defense Position monster as an attack target."
    },
    "fr": {
      "name": "Hieracosphinx",
      "effect": "Tant que cette carte reste face recto sur votre Terrain, votre adversaire ne peut pas s\u00e9lectionner de monstre face verso en Position de D\u00e9fense comme cible d'une attaque."
    },
    "de": {
      "name": "Hieracosphinx",
      "effect": "Solange diese Karte offen auf deiner Spielfeldseite liegt, kann dein Gegner keine Monster in verdeckter Verteidigungsposition als Ziel eines Angriffs w\u00e4hlen."
    },
