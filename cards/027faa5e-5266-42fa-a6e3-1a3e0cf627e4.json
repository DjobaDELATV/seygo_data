  "text": {
    "en": {
      "name": "Catapult Turtle",
      "effect": "Once per turn: You can Tribute 1 monster; inflict damage to your opponent equal to half the Tributed monster's ATK on the field."
    },
    "fr": {
      "name": "Tortue Catapulte",
      "effect": "Une fois par tour : vous pouvez Sacrifier 1 monstre ; infligez des dommages \u00e0 votre adversaire \u00e9gaux \u00e0 la moiti\u00e9 de l'ATK du monstre Sacrifi\u00e9 sur le Terrain."
    },
    "de": {
      "name": "Katapult-Schildkr\u00f6te",
      "effect": "Einmal pro Spielzug: Du kannst 1 Monster als Tribut anbieten; f\u00fcge deinem Gegner Schaden in H\u00f6he der H\u00e4lfte der ATK des als Tribut angebotenen Monsters auf dem Spielfeld zu."
    },
    "it": {
      "name": "Tartaruga Catapulta",
      "effect": "Una volta per turno: puoi offrire come Tributo 1 mostro; infliggi al tuo avversario danno pari alla meta dell'ATK sul Terreno del mostro offerto come Tributo."
    },
    "pt": {
