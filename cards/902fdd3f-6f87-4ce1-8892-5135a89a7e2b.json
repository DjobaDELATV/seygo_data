  "text": {
    "en": {
      "name": "Deep Sea Diva",
      "effect": "When this card is Normal Summoned: You can Special Summon 1 Level 3 or lower Sea Serpent monster from your Deck."
    },
    "fr": {
      "name": "Diva des Profondeurs",
      "effect": "Lorsque cette carte est Invoqu\u00e9e Normalement : vous pouvez Invoquer Sp\u00e9cialement 1 monstre Serpent de Mer de max. Niveau 3 depuis votre Deck."
    },
    "de": {
      "name": "Tiefseetaucher",
      "effect": "Wenn diese Karte als Normalbeschw\u00f6rung beschworen wird: Du kannst 1 Seeschlange-Monster der Stufe 3 oder niedriger als Spezialbeschw\u00f6rung von deinem Deck beschw\u00f6ren."
    },
    "it": {
      "name": "Diva del Mare Profondo",
