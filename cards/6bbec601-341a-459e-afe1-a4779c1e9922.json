  "text": {
    "en": {
      "name": "Crimson Blader",
      "effect": "1 Tuner + 1 or more non-Tuner monsters\nIf this card destroys an opponent's monster by battle and sends it to the GY: Your opponent cannot Normal or Special Summon Level 5 or higher monsters during their next turn."
    },
    "fr": {
      "name": "\u00c9p\u00e9iste Cramoisi",
      "effect": "1 Syntoniseur + 1+ monstre non-Syntoniseur\nSi cette carte d\u00e9truit un monstre de l'adversaire au combat et l'envoie au Cimeti\u00e8re : durant son prochain tour, votre adversaire ne peut Invoquer ni Normalement ni Sp\u00e9cialement de monstres de min. Niveau 5."
    },
    "de": {
      "name": "Blutroter Klingenk\u00e4mpfer",
      "effect": "1 Empf\u00e4nger- + 1 oder mehr Nicht-Empf\u00e4nger-Monster\nFalls diese Karte ein Monster deines Gegners durch Kampf zerst\u00f6rt und auf den Friedhof legt: Dein Gegner kann w\u00e4hrend seines n\u00e4chsten Spielzugs keine Monster der Stufe 5 oder h\u00f6her als Normal- oder Spezialbeschw\u00f6rung beschw\u00f6ren."
    },
    "it": {
      "name": "Spadaccino Cremisi",
      "effect": "1 Tuner + 1 o pi\u00f9 mostri non-Tuner\nSe questa carta distrugge un mostro dell'avversario in battaglia e lo manda al Cimitero: il tuo avversario non pu\u00f2 Evocare Normalmente o Specialmente mostri di Livello 5 o superiore durante il suo prossimo turno."
    },
    "pt": {
      "name": "Laminador Carmesim",
      "effect": "1 Regulador + 1 ou mais monstros n\u00e3o-Reguladores\nSe este card destruir um monstro do oponente em batalha e o enviar para o Cemit\u00e9rio: seu oponente n\u00e3o pode Invocar por Invoca\u00e7\u00e3o-Normal ou Especial monstros de N\u00edvel 5 ou mais durante o pr\u00f3ximo turno dele."
    },
    "es": {
      "name": "Blader Carmes\u00ed",
      "effect": "1 Cantante + 1+ monstruos que no sean Cantantes\nSi esta carta destruye un monstruo de tu adversario en batalla y lo manda al Cementerio: durante su pr\u00f3ximo turno, tu adversario no puede Invocar de Modo Normal o Especial monstruos de Nivel 5 o mayor."
    },
