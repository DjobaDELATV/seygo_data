  "text": {
    "en": {
      "name": "Overload Fusion",
      "effect": "Fusion Summon 1 DARK Machine Fusion Monster from your Extra Deck, by banishing Fusion Materials mentioned on it from your field or GY."
    },
    "fr": {
      "name": "Fusion en Surcharge",
      "effect": "Invoquez par Fusion 1 Monstre Fusion T\u00c9N\u00c8BRES Machine depuis votre Extra Deck, en bannissant les Mat\u00e9riels Fusion mentionn\u00e9s sur celui-ci depuis votre Terrain ou Cimeti\u00e8re."
    },
    "de": {
      "name": "\u00dcberlastfusion",
      "effect": "Beschw\u00f6re 1 FINSTERNIS Maschine-Fusionsmonster als Fusionsbeschw\u00f6rung von deinem Extra Deck, indem du das auf ihm erw\u00e4hnte Fusionsmaterial von deiner Spielfeldseite oder deinem Friedhof verbannst."
    },
    "it": {
      "name": "Fusione Sovraccarico",
      "effect": "Evoca tramite Fusione 1 Mostro Fusione OSCURIT\u00c0 Macchina dal tuo Extra Deck, bandendo i Materiali da Fusione menzionati su di esso dal tuo Terreno o Cimitero."
    },
    "pt": {
      "name": "Fus\u00e3o Sobrecarregada",
      "effect": "Invoque por Invoca\u00e7\u00e3o-Fus\u00e3o 1 Monstro de Fus\u00e3o M\u00e1quina de TREVAS do seu Deck Adicional, ao banir as Mat\u00e9rias de Fus\u00e3o mencionadas nele do seu campo ou Cemit\u00e9rio."
    },
    "es": {
      "name": "Sobrecarga de Fusi\u00f3n",
      "effect": "Invoca por Fusi\u00f3n, desde tu Deck Extra, 1 Monstruo de Fusi\u00f3n M\u00e1quina de OSCURIDAD, desterrando de tu Campo o Cementerio Materiales de Fusi\u00f3n mencionados en \u00e9l."
    },
    "ja": {
