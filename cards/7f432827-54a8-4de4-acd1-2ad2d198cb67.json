  "text": {
    "en": {
      "name": "Charcoal Inpachi",
      "effect": "A wicked wooden spirit that has burned out. The barbecue grilled with this charcoal is so awesome that everybody thinks it's priceless."
    },
    "fr": {
      "name": "Charbon d'Inpachi",
      "effect": "Incarnation d'un arbre g\u00e9ant qui a br\u00fbl\u00e9 int\u00e9gralement, tout barbecue r\u00e9alis\u00e9 avec ce charbon est si superbe qu'on le croirait pr\u00e9cieux."
    },
    "de": {
      "name": "Holzkohle-Inpachi",
      "effect": "Die Inkarnation eines gro\u00dfen Baums, der v\u00f6llig ausgebrannt ist. Alles, was mit seiner Holzkohle gegrillt wird, schmeckt so vorz\u00fcglich, dass es von jedem sehr gesch\u00e4tzt wird."
    },
    "it": {
      "name": "Inpachi Carbone",
      "effect": "L'incarnazione di un grande albero che \u00e8 stato completamente bruciato. Un barbecue fatto con questo carbone \u00e8 cos\u00ec superbo da farlo ritenere prezioso da tutti."
    },
    "pt": {
      "name": "Carv\u00e3o Inpachi",
      "effect": "Um perverso esp\u00edrito de madeira que se extinguiu. O churrasco na brasa com esse carv\u00e3o \u00e9 t\u00e3o incr\u00edvel que todos dizem que n\u00e3o tem pre\u00e7o."
    },
    "es": {
      "name": "Inpachi de Carb\u00f3n",
      "effect": "La encarnaci\u00f3n de un gran \u00e1rbol que fue quemado a conciencia. Una barbacoa hecha con este carb\u00f3n es tan soberbia que todos creen que es preciosa."
    },
