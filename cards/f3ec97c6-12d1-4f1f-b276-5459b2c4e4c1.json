  "text": {
    "en": {
      "name": "Dragon's Rebirth",
      "effect": "Target 1 Dragon monster you control; banish that target, and if you do, Special Summon 1 Dragon monster from your hand or GY."
    },
    "fr": {
      "name": "Transmigration de Dragon",
      "effect": "Ciblez 1 monstre Dragon que vous contr\u00f4lez ; bannissez la cible, et si vous le faites, Invoquez Sp\u00e9cialement 1 monstre Dragon depuis votre main ou Cimeti\u00e8re."
    },
    "de": {
      "name": "Drachenseelenwanderung",
      "effect": "W\u00e4hle 1 Drache-Monster, das du kontrollierst; verbanne jenes gew\u00e4hlte Ziel und falls du dies tust, beschw\u00f6re 1 Drache-Monster als Spezialbeschw\u00f6rung von deiner Hand oder deinem Friedhof."
    },
    "it": {
      "name": "Rinascita del Drago",
      "effect": "Scegli come bersaglio 1 mostro Drago che controlli; bandisci quel bersaglio e, se lo fai, Evoca Specialmente 1 mostro Drago dalla tua mano o Cimitero."
    },
    "pt": {
      "name": "Renascimento do Drag\u00e3o",
      "effect": "Escolha 1 monstro Drag\u00e3o que voc\u00ea controla; bana o alvo e, se isso acontecer, Invoque por Invoca\u00e7\u00e3o-Especial 1 monstro Drag\u00e3o da sua m\u00e3o ou do Cemit\u00e9rio."
    },
    "es": {
      "name": "Renacimiento del Drag\u00f3n",
      "effect": "Selecciona 1 monstruo Drag\u00f3n que controles; destierra ese objetivo y, si lo haces, Invoca de Modo Especial, desde tu mano o Cementerio, 1 monstruo Drag\u00f3n."
    },
