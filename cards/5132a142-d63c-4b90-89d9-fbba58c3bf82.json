  "text": {
    "en": {
      "name": "Dedication through Light and Darkness",
      "effect": "Tribute 1 \"Dark Magician\"; Special Summon 1 \"Dark Magician of Chaos\" from your hand, Deck, or Graveyard."
    },
    "fr": {
      "name": "Cons\u00e9cration par la Lumi\u00e8re et les T\u00e9n\u00e8bres",
      "effect": "Sacrifiez 1 \"Magicien Sombre\" ; Invoquez Sp\u00e9cialement 1 \"Magicien Sombre du Chaos\" depuis votre main, Deck ou Cimeti\u00e8re."
    },
    "de": {
      "name": "Engagement durch Licht und Finsternis",
      "effect": "Biete 1 \u201eDunkler Magier\u201c als Tribut an; beschw\u00f6re 1 \u201eDunkler Magier des Chaos\u201c als Spezialbeschw\u00f6rung von deiner Hand, deinem Deck oder deinem Friedhof."
    },
