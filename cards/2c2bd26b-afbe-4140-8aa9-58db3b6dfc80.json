  "text": {
    "en": {
      "name": "Favorite HERO Flame Wingman",
      "effect": "2 monsters with the same Type but different Attributes\n(This card is always treated as an \"Elemental HERO\" card.)\nWhen an attack is declared involving this card and a monster with 2200 or more ATK: You can make this card gain 1000 ATK, then you can Special Summon 1 Level 4 or lower monster from your hand in Defense Position. If a monster(s) was destroyed by battle this turn (Quick Effect): You can Fusion Summon 1 Fusion Monster from your Extra Deck, using monsters from your hand or field. You can only use each effect of \"Favorite HERO Flame Wingman\" once per turn.",
      "official": false
    },
    "ja": {
      "name": "\uff26\u30fb\uff28\uff25\uff32\uff2f \u30d5\u30ec\u30a4\u30e0\u30fb\u30a6\u30a3\u30f3\u30b0\u30de\u30f3",
