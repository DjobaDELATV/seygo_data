      "effect": "\u534f\u8c03\uff0b\u534f\u8c03\u4ee5\u5916\u7684\u602a\u517d1\u53ea\u4ee5\u4e0a\n\u6b64\u5361\u540d\u7684\u2460\u2462\u6548\u679c1\u56de\u5408\u4ec5\u53ef\u5404\u4f7f\u75281\u6b21\u3002\u2460\uff1a\u6b64\u5361\u540c\u6b65\u53ec\u5524\u7684\u60c5\u51b5\u4e0b\u53ef\u4ee5\u53d1\u52a8\u3002\u4ece\u81ea\u5df1\u5893\u5730\u5c06\u9f99\u65cf\u540c\u6b65\u602a\u517d\u5c3d\u53ef\u80fd\u5730\u7279\u6b8a\u53ec\u5524\u3002\u6b64\u56de\u5408\uff0c\u81ea\u5df1\u4e0d\u53ef\u7279\u6b8a\u53ec\u5524\u602a\u517d\u3002\u2461\uff1a\u6b64\u5361\u7684\u653b\u51fb\u529b\u4e0a\u5347\u76f8\u5f53\u4e8e\u81ea\u5df1\u573a\u4e0a\u5176\u4ed6\u7684\u540c\u6b65\u602a\u517d\u539f\u672c\u653b\u51fb\u529b\u7684\u5408\u8ba1\u6570\u503c\u3002\u2462\uff1a\u5bf9\u624b\u53d1\u52a8\u602a\u517d\u7684\u6548\u679c\u65f6\u53ef\u4ee5\u53d1\u52a8\u3002\u5c06\u81ea\u5df1\u573a\u4e0a\u76841\u53ea\u5176\u4ed6\u7684\u9f99\u65cf\u540c\u6b65\u602a\u517d\u653e\u56de\u989d\u5916\u724c\u7ec4\uff0c\u5c06\u8be5\u53d1\u52a8\u65e0\u6548\u3002"
