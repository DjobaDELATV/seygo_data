  "text": {
    "en": {
      "name": "Beckoning Light",
      "effect": "Discard your entire hand, then for each card you discarded to the GY by this effect, add 1 LIGHT monster from your GY to your hand."
    },
    "fr": {
      "name": "Lumi\u00e8re Attirante",
      "effect": "D\u00e9faussez toute votre main, puis pour chaque carte que vous avez d\u00e9fauss\u00e9e au Cimeti\u00e8re par cet effet, ajoutez 1 monstre LUMI\u00c8RE depuis votre Cimeti\u00e8re \u00e0 votre main."
    },
    "de": {
      "name": "Lockendes Licht",
      "effect": "Wirf deine gesamte Hand ab, dann f\u00fcge deiner Hand f\u00fcr jede durch diesen Effekt auf den Friedhof abgeworfene Karte 1 LICHT Monster von deinem Friedhof hinzu."
    },
