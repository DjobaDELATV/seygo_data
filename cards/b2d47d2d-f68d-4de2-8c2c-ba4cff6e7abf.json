  "text": {
    "en": {
      "name": "Elemental HERO Burstinatrix",
      "effect": "A flame manipulator who was the first Elemental HERO woman. Her Burstfire burns away villainy."
    },
    "fr": {
      "name": "Burstinatrix, H\u00c9ROS \u00c9l\u00e9mentaire",
      "effect": "Une manipulatrice de flammes qui \u00e9tait la premi\u00e8re femme H\u00c9ROS \u00c9l\u00e9mentaire. Son Explosion Flamboyante r\u00e9duit en cendres l'infamie."
    },
    "de": {
      "name": "Elementar-HELD Burstinatrix",
      "effect": "Eine Flammenmanipulatorin war die erste Frau unter den Elementar-HELDEN. Ihr Ausbruchsfeuer brennt Schurken weg."
    },
    "it": {
      "name": "Burstinatrix EROE Elementale",
      "effect": "Una manipolatrice di fiamme, prima EROE Elementale donna. La sua Fiammata scaccia la malvagit\u00e0 con le fiamme."
    },
    "pt": {
      "name": "Burstinatrix, o HER\u00d3I do Elemento",
      "effect": "Uma manipuladora das chamas que \u00e9 a primeira mulher HER\u00d3I do Elemento. Sua Explos\u00e3o de Fogo queima os vil\u00f5es."
    },
    "es": {
      "name": "H\u00c9ROE Elemental Burstinatrix",
      "effect": "Una manipuladora de las llamas que es la primera mujer de los H\u00c9ROEs Elementales. Su Llamarada quema la vileza."
    },
