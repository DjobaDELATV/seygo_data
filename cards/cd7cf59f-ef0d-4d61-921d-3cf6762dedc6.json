  "text": {
    "en": {
      "name": "Dark Ruler Ha Des",
      "effect": "Cannot be Special Summoned from the GY. Negate the effects of monsters destroyed by battle with Fiend monsters you control."
    },
    "fr": {
      "name": "Ha D\u00e8s le Gouverneur des T\u00e9n\u00e8bres",
      "effect": "Non Invocable Sp\u00e9cialement depuis le Cimeti\u00e8re. Annulez les effets des monstres d\u00e9truits au combat avec les monstres D\u00e9mon que vous contr\u00f4lez."
    },
    "de": {
      "name": "Dunkler Herrscher Ha Des",
      "effect": "Kann nicht als Spezialbeschw\u00f6rung vom Friedhof beschworen werden. Annulliere die Effekte von Monstern, die durch Kampf mit Unterweltler-Monstern zerst\u00f6rt werden, die du kontrollierst."
    },
    "it": {
      "name": "Ha Des Sovrano Oscuro",
      "effect": "Non pu\u00f2 essere Evocato Specialmente dal Cimitero. Annulla gli effetti dei mostri distrutti in battaglia con i mostri Demone che controlli."
    },
    "pt": {
      "name": "Governante Sombrio Ha Des",
      "effect": "N\u00e3o pode ser Invocado por Invoca\u00e7\u00e3o-Especial do Cemit\u00e9rio. Negue os efeitos de monstros destru\u00eddos em batalha com monstros Dem\u00f4nio que voc\u00ea controla."
    },
    "es": {
      "name": "Gobernante Oscuro Ha Des",
      "effect": "No puede ser Invocado de Modo Especial desde el Cementerio. Niega los efectos de los monstruos destruidos en batalla con monstruos Demonio que controles."
    },
