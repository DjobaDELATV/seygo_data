  "text": {
    "en": {
      "name": "Blowback Dragon",
      "effect": "Once per turn: You can target 1 card your opponent controls; toss a coin 3 times and destroy that target if at least 2 of the results are heads."
    },
    "fr": {
      "name": "Dragon \u00e0 Recul",
      "effect": "Une fois par tour : vous pouvez cibler 1 carte contr\u00f4l\u00e9e par votre adversaire ; lancez une pi\u00e8ce 3 fois et d\u00e9truisez la cible si min. 2 des r\u00e9sultats sont face."
    },
    "de": {
      "name": "R\u00fccksto\u00df-Drache",
      "effect": "Einmal pro Spielzug: Du kannst 1 Karte w\u00e4hlen, die dein Gegner kontrolliert; wirf 3-mal eine M\u00fcnze und zerst\u00f6re jenes gew\u00e4hlte Ziel, falls mindestens 2 der Ergebnisse Kopf sind."
    },
    "it": {
      "name": "Drago Sputafuoco",
      "effect": "Una volta per turno: puoi scegliere come bersaglio 1 carta controllata dal tuo avversario; lancia una moneta 3 volte e distruggi quel bersaglio se almeno 2 dei risultati sono testa."
    },
    "pt": {
      "name": "Drag\u00e3o Solta Fogo",
      "effect": "Uma vez por turno: voc\u00ea pode escolher 1 card que seu oponente controla; lance uma moeda 3 vezes e destrua o alvo se pelo menos 2 resultados forem cara."
    },
    "es": {
      "name": "Drag\u00f3n Escupefuego",
      "effect": "Una vez por turno: puedes seleccionar 1 carta que controle tu adversario; lanza una moneda 3 veces y destruye ese objetivo si al menos 2 de los resultados son caras."
    },
