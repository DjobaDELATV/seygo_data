  "text": {
    "en": {
      "name": "Silent Swordsman LV7",
      "effect": "Cannot be Normal Summoned/Set. Must be Special Summoned by \"Silent Swordsman LV5\", and cannot be Special Summoned by other ways. Negate all Spell effects on the field."
    },
    "fr": {
      "name": "Spadassin Silencieux LV7",
      "effect": "Ni Invocable Normalement ni Posable Normalement. Uniquement Invocable Sp\u00e9cialement avec \"Spadassin Silencieux LV5\" et non Invocable Sp\u00e9cialement autrement. Annulez tous les effets de Magie sur le Terrain."
    },
    "de": {
      "name": "Schweigsamer Schwertk\u00e4mpfer LV7",
      "effect": "Kann nicht als Normalbeschw\u00f6rung beschworen/gesetzt werden. Muss durch \u201eSchweigsamer Schwertk\u00e4mpfer LV5\u201c als Spezialbeschw\u00f6rung beschworen werden und kann nicht auf andere Art als Spezialbeschw\u00f6rung beschworen werden. Annulliere alle Zaubereffekte auf dem Spielfeld."
    },
    "it": {
      "name": "Spadaccino Silente LV7",
      "effect": "Non pu\u00f2 essere Evocato Normalmente/Posizionato. Deve essere Evocato Specialmente da \"Spadaccino Silente LV5\", e non pu\u00f2 essere Evocato Specialmente in altri modi. Annulla tutti gli effetti delle Magie sul Terreno."
    },
    "pt": {
      "name": "Espadachim Silencioso LV7",
      "effect": "N\u00e3o pode ser Invocado por Invoca\u00e7\u00e3o-Normal/Baixado. Deve ser Invocado por Invoca\u00e7\u00e3o-Especial por \"Espadachim Silencioso LV5\" e n\u00e3o pode ser Invocado por Invoca\u00e7\u00e3o-Especial de nenhuma outra forma. Negue todos os efeitos de Magia no campo."
    },
    "es": {
      "name": "Espadach\u00edn Silencioso LV7",
      "effect": "No puede ser Invocado de Modo Normal/Colocado. Debe ser Invocado de Modo Especial por \"Espadach\u00edn Silencioso LV5\", y no puede ser Invocado de Modo Especial de otra forma. Niega todos los efectos de Cartas M\u00e1gicas en el Campo."
    },
