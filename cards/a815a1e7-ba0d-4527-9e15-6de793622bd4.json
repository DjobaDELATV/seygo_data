  "text": {
    "en": {
      "name": "Reincarnation of the Unchained",
      "effect": "When this card is activated: You can add 1 \"Unchained\" Spell (except \"Reincarnation of the Unchained\") or 1 \"Abomination's Prison\" from your Deck to your hand. Once per turn: You can target up to 3 \"Unchained\" cards in your GY, except \"Reincarnation of the Unchained\"; shuffle them into the Deck, then you can destroy other cards you control up to the number shuffled. You can only activate 1 \"Reincarnation of the Unchained\" per turn.",
      "official": false
    },
