  "id": "4137ce7d-bb16-46fe-8474-d2eb871fea55",
  "text": {
    "en": {
      "name": "Premature Burial",
      "effect": "Activate this card by paying 800 LP, then target 1 monster in your GY; Special Summon it in Attack Position and equip it with this card. When this card is destroyed, destroy the equipped monster."
    },
    "fr": {
      "name": "Enterrement Pr\u00e9matur\u00e9",
      "effect": "Activez cette carte en payant 800 LP, puis ciblez 1 monstre dans votre Cimeti\u00e8re ; Invoquez-le Sp\u00e9cialement en Position d'Attaque et \u00e9quipez-le avec cette carte. Lorsque cette carte est d\u00e9truite, d\u00e9truisez le monstre \u00e9quip\u00e9."
    },
    "de": {
      "name": "Voreiliges Begr\u00e4bnis",
      "effect": "Aktiviere diese Karte, indem du 800 LP zahlst, und w\u00e4hle dann 1 Monster in deinem Friedhof; beschw\u00f6re das gew\u00e4hlte Ziel als Spezialbeschw\u00f6rung in die Angriffsposition und r\u00fcste es mit dieser Karte aus. Wenn diese Karte zerst\u00f6rt wird, zerst\u00f6re das ausger\u00fcstete Monster."
    },
    "it": {
      "name": "Sepoltura Prematura",
      "effect": "Attiva questa carta pagando 800 LP, poi scegli come bersaglio 1 mostro nel tuo Cimitero; Evoca Specialmente quel bersaglio in Posizione di Attacco ed equipaggialo con questa carta. Quando questa carta viene distrutta, distruggi il mostro equipaggiato."
    },
    "pt": {
      "name": "Enterro Precoce",
      "effect": "Ative este card ao pagar 800 PV e, depois, escolha 1 monstro no seu Cemit\u00e9rio; Invoque-o por Invoca\u00e7\u00e3o-Especial em Posi\u00e7\u00e3o de Ataque e equipe-o com este card. Quando este card for destru\u00eddo, destrua o monstro equipado."
    },
    "es": {
      "name": "Entierro Prematuro",
      "effect": "Activa esta carta pagando 800 LP, y despu\u00e9s selecciona 1 monstruo en tu Cementerio; Invoca ese objetivo de Modo Especial en Posici\u00f3n de Ataque y equ\u00edpalo con esta carta. Cuando esta carta es destruida, destruye el monstruo equipado."
    },
    "ja": {
