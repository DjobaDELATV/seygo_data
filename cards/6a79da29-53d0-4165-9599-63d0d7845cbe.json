  "text": {
    "en": {
      "name": "Gold Sarcophagus",
      "effect": "Banish 1 card from your Deck, face-up. During your 2nd Standby Phase after this card's activation, add that card to the hand."
    },
    "fr": {
      "name": "Sarcophage Dor\u00e9",
      "effect": "Bannissez face recto 1 carte depuis votre Deck. Durant votre 2e Standby Phase apr\u00e8s activation de cette carte, ajoutez la carte \u00e0 la main."
    },
    "de": {
      "name": "Gold-Sarkophag",
      "effect": "Verbanne 1 Karte offen von deinem Deck. W\u00e4hrend deiner 2. Standby Phase nach der Aktivierung dieser Karte, f\u00fcge jene Karte der Hand hinzu."
    },
    "it": {
      "name": "Sarcofago d'Oro",
      "effect": "Bandisci 1 carta dal tuo Deck, scoperta. Durante la tua 2\u00aa Standby Phase dopo l'attivazione di questa carta, aggiungi quella carta alla mano."
    },
    "pt": {
      "name": "Sarc\u00f3fago Dourado",
      "effect": "Bana, com a face para cima, 1 card do seu Deck. Durante sua 2\u00aa Fase de Apoio depois da ativa\u00e7\u00e3o deste card, adicione esse card \u00e0 m\u00e3o."
    },
    "es": {
