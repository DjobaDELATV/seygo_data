  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "c2c2e3e7-9261-4e23-ae66-65395029c51e",
  "text": {
    "en": {
      "name": "Exchange of the Spirit",
      "effect": "If both players have 15 or more cards in their GYs: Pay 1000 LP; each player swaps the cards in their GY with the cards in their Deck, then shuffles their Deck. You can only activate 1 \"Exchange of the Spirit\" per Duel."
    },
    "fr": {
      "name": "Permutation des Mondes",
      "effect": "Si chaque joueur a min. 15 cartes dans son Cimeti\u00e8re : payez 1000 LP ; chaque joueur \u00e9change les cartes dans son Cimeti\u00e8re avec les cartes dans son Deck, puis m\u00e9lange son Deck. Vous ne pouvez activer qu'1 \"Permutation des Mondes\" par Duel."
    },
    "de": {
      "name": "Austausch des Geistes",
      "effect": "Falls beide Spieler 15 oder mehr Karten in ihren Friedh\u00f6fen haben: Zahle 1000 LP; jeder Spieler vertauscht die Karten in seinem Friedhof mit den Karten in seinem Deck, dann mischt er sein Deck. Du kannst nur 1 \u201eAustausch des Geistes\u201c pro Duell aktivieren."
    },
    "it": {
      "name": "Scambio dello Spirito",
      "effect": "Se entrambi i giocatori hanno 15 o pi\u00f9 carte nel loro Cimitero: paga 1000 LP; ogni giocatore scambia le carte nel suo Cimitero con le carte nel suo Deck, poi mischia il suo Deck. Puoi attivare solo 1 \"Scambio dello Spirito\" per Duello."
    },
    "pt": {
      "name": "Troca de Esp\u00edrito",
      "effect": "Se os dois duelistas tiverem 15 ou mais cards nos seus Cemit\u00e9rios: pague 1000 PV; cada duelista troca os cards no seu Cemit\u00e9rio com os cards no seu Deck e, depois, embaralha seu Deck. Voc\u00ea s\u00f3 pode ativar 1 \"Troca de Esp\u00edrito\" por Duelo."
    },
    "es": {
      "name": "Inversi\u00f3n de Sepulturas",
      "effect": "Si ambos jugadores tienen 15 cartas o m\u00e1s en sus Cementerios: paga 1000 LP; cada jugador cambia las cartas en su Cementerio por las cartas de su Deck, y despu\u00e9s baraja su Deck. S\u00f3lo puedes activar 1 \"Inversi\u00f3n de Sepulturas\" por Duelo."
    },
    "ja": {
