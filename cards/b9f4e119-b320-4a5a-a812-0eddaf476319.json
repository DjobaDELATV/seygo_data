    "en": {
      "name": "Autonomous Action Unit",
      "effect": "Pay 1500 LP, then target 1 monster in your opponent's GY; Special Summon it to your field in Attack Position, and equip it with this card. When this card leaves the field, destroy the equipped monster."
    },
    "fr": {
      "name": "Unit\u00e9 d'Action Autonome",
