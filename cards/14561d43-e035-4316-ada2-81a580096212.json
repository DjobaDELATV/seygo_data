  "text": {
    "en": {
      "name": "Exodia the Forbidden One",
      "effect": "If you have \"Right Leg of the Forbidden One\", \"Left Leg of the Forbidden One\", \"Right Arm of the Forbidden One\" and \"Left Arm of the Forbidden One\" in addition to this card in your hand, you win the Duel."
    },
    "fr": {
      "name": "\u00c9xodia l'Interdit",
      "effect": "Si vous avez \"Jambe Droite de l'Interdit\", \"Jambe Gauche de l'Interdit\", \"Bras Droit de l'Interdit\" et \"Bras Gauche de l'Interdit\" en plus de cette carte dans votre main, vous gagnez le Duel."
    },
    "de": {
      "name": "Exodia, die Verbotene",
      "effect": "Falls du zus\u00e4tzlich zu dieser Karte \u201eRechtes Bein der Verbotenen\u201c, \u201eLinkes Bein der Verbotenen\u201c, \u201eRechter Arm der Verbotenen\u201c und \u201eLinker Arm der Verbotenen\u201c in deiner Hand hast, gewinnst du das Duell."
    },
    "it": {
      "name": "Exodia il Proibito",
      "effect": "Se hai \"Gamba Dx del Proibito\", \"Gamba Sx del Proibito\", \"Braccio Dx del Proibito\" e \"Braccio Sx del Proibito\" in aggiunta a questa carta nella tua mano, vinci il Duello."
    },
    "pt": {
      "name": "Exodia, \"O Proibido\"",
      "effect": "Se voc\u00ea tiver \"Perna Direita de \"O Proibido\"\", \"Perna Esquerda de \"O Proibido\"\", \"Bra\u00e7o Direito de \"O Proibido\"\" e \"Bra\u00e7o Esquerdo de \"O Proibido\"\", al\u00e9m de este card na sua m\u00e3o, voc\u00ea vence o Duelo."
    },
    "es": {
      "name": "Exodia, el Prohibido",
      "effect": "Si tienes \"Pierna Derecha del Prohibido\", \"Pierna Izquierda del Prohibido\", \"Brazo Derecho del Prohibido\" y \"Brazo Izquierdo del Prohibido\", adem\u00e1s de esta carta en tu mano, ganas el Duelo."
    },
    "ja": {
