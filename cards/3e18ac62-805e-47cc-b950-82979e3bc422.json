  "text": {
    "en": {
      "name": "Koalo-Koala",
      "effect": "\"Sea Koala\" + \"Tree Otter\"\nYou can send 1 Beast-Type monster from your hand to the Graveyard to target 1 monster your opponent controls; destroy it."
    },
    "fr": {
      "name": "Koalo-Koala",
      "effect": "\"Koala des Mers\" + \"Loutre des Arbres\"\nVous pouvez envoyer 1 monstre de Type B\u00eate depuis votre main au Cimeti\u00e8re pour cibler 1 monstre contr\u00f4l\u00e9 par votre adversaire ; d\u00e9truisez-le."
    },
    "de": {
      "name": "Koalo-Koala",
      "effect": "\u201eMeereskoala\u201c + \u201eBaumotter\u201c\nDu kannst 1 Monster vom Typ Ungeheuer von deiner Hand auf den Friedhof legen, um 1 Monster zu w\u00e4hlen, das dein Gegner kontrolliert; zerst\u00f6re es."
    },
    "it": {
      "name": "Koalo-Koala",
      "effect": "\"Koala Marino\" + \"Lontra degli Alberi\"\nPuoi mandare 1 mostro di Tipo Bestia dalla tua mano al Cimitero per scegliere come bersaglio 1 mostro controllato dal tuo avversario; distruggilo."
    },
    "es": {
      "name": "Koalo-Koala",
      "effect": "\"Koala Marino\" + \"Nutria Arbor\u00edcola\"\nPuedes mandar al Cementerio, desde tu mano, 1 monstruo de Tipo Bestia para seleccionar 1 monstruo que controle tu adversario; destr\u00fayelo."
    },
    "ja": {
      "name": "\u30b3\u30a2\u30e9\u30c3\u30b3\u30a2\u30e9",
