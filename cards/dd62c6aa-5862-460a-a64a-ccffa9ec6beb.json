  "text": {
    "en": {
      "name": "Blackwing Armed Wing",
      "effect": "1 \"Blackwing\" Tuner + 1+ non-Tuner monsters\nIf this card attacks a Defense Position monster, it gains 500 ATK during the Damage Step only, also inflict piercing battle damage to your opponent."
    },
    "fr": {
      "name": "Aile Noire - Arsenal A\u00e9rien",
      "effect": "1 Syntoniseur \"Aile Noire\" + 1+ monstre non-Syntoniseur\nSi cette carte attaque un monstre en Position de D\u00e9fense, elle gagne 500 ATK durant la Damage Step uniquement, et aussi, infligez des dommages de combat per\u00e7ants \u00e0 votre adversaire."
    },
    "de": {
      "name": "Schwarzfl\u00fcgel-Waffenmeister",
      "effect": "1 \u201eSchwarzfl\u00fcgel\u201c-Empf\u00e4nger + 1+ Nicht-Empf\u00e4nger-Monster\nFalls diese Karte ein Monster in Verteidigungsposition angreift, erh\u00e4lt sie nur w\u00e4hrend des Damage Steps 500 ATK, zus\u00e4tzlich f\u00fcge deinem Gegner durchschlagenden Kampfschaden zu."
    },
    "it": {
      "name": "Alanera Ala Armata",
      "effect": "1 Tuner \"Alanera\" + 1+ mostri non-Tuner\nSe questa carta attacca un mostro in Posizione di Difesa, essa guadagna 500 ATK solamente durante il Damage Step, inoltre infliggi danno da combattimento perforante al tuo avversario."
    },
    "pt": {
      "name": "Asanegra Armado",
      "effect": "1 Regulador \"Asanegra\" + 1+ monstros n\u00e3o-Reguladores\nSe este card atacar um monstro em Posi\u00e7\u00e3o de Defesa, ele ganha 500 de ATK apenas durante a Etapa de Dano e, al\u00e9m disso, cause dano de batalha perfurante ao seu oponente."
    },
    "es": {
      "name": "Alanegra Armado",
      "effect": "1 Cantante \"Alanegra\" + 1+ monstruos que no sean Cantantes\nSi esta carta ataca a un monstruo en Posici\u00f3n de Defensa, gana 500 ATK s\u00f3lo durante el Damage Step, y adem\u00e1s inflige da\u00f1o de batalla de penetraci\u00f3n a tu adversario."
    },
    "ja": {
