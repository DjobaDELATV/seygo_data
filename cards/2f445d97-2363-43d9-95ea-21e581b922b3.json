  "text": {
    "en": {
      "name": "Scrap-Iron Scarecrow",
      "effect": "When an opponent's monster declares an attack: Target the attacking monster; negate the attack, also, after that, Set this card face-down instead of sending it to the GY."
    },
    "fr": {
      "name": "\u00c9pouvantail de Ferraille",
      "effect": "Lorsqu'un monstre de l'adversaire d\u00e9clare une attaque : ciblez le monstre attaquant ; annulez l'attaque, et aussi, apr\u00e8s \u00e7a, Posez cette carte face verso au lieu de l'envoyer au Cimeti\u00e8re."
    },
    "de": {
      "name": "Eisenschrott-Vogelscheuche",
      "effect": "Wenn ein Monster eines Gegners einen Angriff deklariert: W\u00e4hle das angreifende Monster; annulliere den Angriff, zus\u00e4tzlich setze diese Karte danach verdeckt, anstatt sie auf den Friedhof zu legen."
    },
    "it": {
      "name": "Spaventapasseri di Ferraglia",
      "effect": "Quando un mostro dell'avversario dichiara un attacco: scegli come bersaglio il mostro attaccante; annulla l'attacco, inoltre, dopo aver fatto quello, Posiziona questa carta coperta invece di mandarla al Cimitero."
    },
    "pt": {
      "name": "Espantalho de Ferro-Velho",
      "effect": "Quando um monstro do oponente declarar um ataque: escolha o monstro atacante; negue o ataque e, al\u00e9m disso, depois, Baixe este card com a face para baixo em vez de envi\u00e1-lo para o Cemit\u00e9rio."
    },
    "es": {
      "name": "Espantap\u00e1jaros de Chatarra",
      "effect": "Cuando un monstruo del adversario declara un ataque: selecciona al monstruo atacante; niega el ataque y adem\u00e1s, despu\u00e9s de eso, Coloca esta carta boca abajo en lugar de mandarla al Cementerio."
    },
    "ja": {
