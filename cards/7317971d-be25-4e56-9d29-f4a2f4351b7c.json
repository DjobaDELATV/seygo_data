  "text": {
    "en": {
      "name": "PSY-Frame Driver",
      "effect": "A Psychic soldier that rides into battle against the Security Forces on currents of lightning, using an autonomic amplifier called \"PSY-Frame\"."
    },
    "fr": {
      "name": "Pilote Structure-PSY",
      "effect": "Un soldat Psychique qui combat les Forces de S\u00e9curit\u00e9 en surfant sur des courants de foudre \u00e0 l'aide d'un amplificateur autonome \"Structure-PSY\"."
    },
    "de": {
      "name": "PSI-H\u00fcllentreiber",
      "effect": "Ein Psi-Soldat, der auf Lichtblitzen in die Schlacht gegen die Sicherheitskr\u00e4fte zieht. Er verwendet einen autonomen Verst\u00e4rker, der \u201ePSI-H\u00fclle\u201c genannt wird."
    },
    "it": {
      "name": "PSI-Struttura Pilota",
      "effect": "Un soldato Psichico che si lancia in battaglia contro le Forze di Sicurezza su correnti di lampi, utilizzando un amplificatore autonomo chiamato \"PSI-Struttura\"."
    },
    "pt": {
      "name": "PS\u00cd-Arma\u00e7\u00e3o Condutor",
      "effect": "Um soldado Ps\u00edquico que entra em conflito com as For\u00e7as de Seguran\u00e7a como ondas rel\u00e2mpago, usando um amplificador auton\u00f4mico chamado \"PS\u00cd-Arma\u00e7\u00e3o\"."
    },
    "es": {
      "name": "Conductor de Armaz\u00f3n-PS\u00cd",
      "effect": "Un soldado Ps\u00edquico que entra en batalla en contra de las Fuerzas de Seguridad sobre corrientes de rayos, usando un amplificador auton\u00f3mico llamado \"Armaz\u00f3n-PS\u00cd\"."
    },
    "ja": {
