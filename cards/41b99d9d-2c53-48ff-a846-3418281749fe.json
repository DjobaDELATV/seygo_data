    "en": {
      "name": "Luster Dragon #2",
      "effect": "This dragon feeds on emerald. Enchanted by this monster even when attacked, few people live to tell of its beauty."
    },
    "fr": {
      "name": "Dragon \u00c9tincelant N\u00b02",
      "effect": "Ce dragon se nourrit d'\u00e9meraudes. Le peu de personnes ayant surv\u00e9cu \u00e0 sa rencontre ne tarissent pas d'\u00e9loges sur sa beaut\u00e9."
    },
    "de": {
      "name": "Schimmerdrache #2",
