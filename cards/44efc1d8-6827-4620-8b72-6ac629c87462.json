  "text": {
    "en": {
      "name": "Toon World the Perfect World",
      "effect": "This card's name becomes \"Toon World\" while in the Field Zone. Once per turn: You can add 1 \"Toon\" card, or 1 card that mentions a \"Toon\" card's name, from your Deck to your hand. You can only use this effect of \"Toon World the Perfect World\" thrice per turn. Before resolving another activated card or effect, you can banish 1 Toon monster you control until immediately after that card/effect resolves, also you cannot banish monsters with that same original name with this effect of \"Toon World the Perfect World\" for the rest of this turn.",
      "official": false
    },
    "ja": {
      "name": "\u5b8c\u5168\u306a\u308b\u4e16\u754c \u30c8\u30a5\u30fc\u30f3\u30fb\u30ef\u30fc\u30eb\u30c9"
    },
