  "text": {
    "en": {
      "name": "Card of Safe Return",
      "effect": "When a monster(s) is Special Summoned from your GY (except during the Damage Step): You can draw 1 card."
    },
    "fr": {
      "name": "Carte de Retour Sain & Sauf",
      "effect": "Lorsqu'un ou plusieurs monstres sont Invoqu\u00e9s Sp\u00e9cialement depuis votre Cimeti\u00e8re (sauf durant la Damage Step) : vous pouvez piocher 1 carte."
    },
    "de": {
      "name": "Karte der sicheren Wiederkehr",
      "effect": "Wenn ein oder mehr Monster als Spezialbeschw\u00f6rung von deinem Friedhof beschworen werden (au\u00dfer w\u00e4hrend des Damage Steps): Du kannst 1 Karte ziehen."
    },
    "it": {
      "name": "Carta del Ritorno Sicuro",
      "effect": "Quando uno o pi\u00f9 mostri vengono Evocati Specialmente dal tuo Cimitero (eccetto durante il Damage Step): puoi pescare 1 carta."
    },
    "pt": {
