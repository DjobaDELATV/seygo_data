  "text": {
    "en": {
      "name": "Jar of Avarice",
      "effect": "Target 5 cards in your GY, except \"Jar of Avarice\"; shuffle all 5 into the Deck, then draw 1 card. You can only activate 1 \"Jar of Avarice\" per turn."
    },
    "fr": {
      "name": "Jarre d'Avarice",
      "effect": "Ciblez 5 cartes (\"Jarre d'Avarice\" exclu) dans votre Cimeti\u00e8re ; m\u00e9langez-les toutes les 5 dans le Deck, puis piochez 1 carte. Vous ne pouvez activer qu'1 \"Jarre d'Avarice\" par tour."
    },
    "de": {
      "name": "Krug der Tr\u00e4gheit",
      "effect": "W\u00e4hle 5 Karten in deinem Friedhof, au\u00dfer \u201eKrug der Tr\u00e4gheit\u201c; mische alle 5 ins Deck, dann ziehe 1 Karte. Du kannst nur 1 \u201eKrug der Tr\u00e4gheit\u201c pro Spielzug aktivieren."
    },
    "it": {
      "name": "Anfora dell'Avarizia",
      "effect": "Scegli come bersaglio 5 carte nel tuo Cimitero, eccetto \"Anfora dell'Avarizia\"; mischiale tutte e 5 nel Deck, poi pesca 1 carta. Puoi attivare solo 1 \"Anfora dell'Avarizia\" per turno."
    },
    "pt": {
      "name": "Jarra da Avarice",
      "effect": "Escolha 5 cards no seu Cemit\u00e9rio, exceto \"Jarra da Avarice\"; embaralhe todos os 5 no Deck e, depois, compre 1 card. Voc\u00ea s\u00f3 pode ativar 1 \"Jarra da Avarice\" por turno."
    },
    "es": {
      "name": "Tarro de la Avaricia",
      "effect": "Selecciona 5 cartas en tu Cementerio, excepto \"Tarro de la Avaricia\"; baraja las 5 al Deck, y despu\u00e9s roba 1 carta. S\u00f3lo puedes activar 1 \"Tarro de la Avaricia\" por turno."
    },
