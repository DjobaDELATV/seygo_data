  "text": {
    "en": {
      "name": "Umi",
      "effect": "All Fish, Sea Serpent, Thunder, and Aqua monsters on the field gain 200 ATK/DEF, also all Machine and Pyro monsters on the field lose 200 ATK/DEF."
    },
    "fr": {
      "name": "Umi",
      "effect": "Tous les monstres Poisson, Serpent de Mer, Tonnerre ou Aqua sur le Terrain gagnent 200 ATK/DEF, et aussi, tous les monstres Machine et Pyro sur le Terrain perdent 200 ATK/DEF."
    },
    "de": {
      "name": "Umi",
      "effect": "Alle Fisch-, Seeschlange-, Donner- und Aqua-Monster auf dem Spielfeld erhalten 200 ATK/DEF, zus\u00e4tzlich verlieren alle Maschine- und Pyro-Monster auf dem Spielfeld 200 ATK/DEF."
    },
    "it": {
      "name": "Umi",
      "effect": "Tutti i mostri Pesce, Serpente Marino, Tuono e Acqua sul Terreno guadagnano 200 ATK/DEF, inoltre tutti i mostri Macchina e Pyro sul Terreno perdono 200 ATK/DEF."
    },
    "pt": {
