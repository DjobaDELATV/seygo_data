  "text": {
    "en": {
      "name": "Heat Wave",
      "effect": "At the start of your Main Phase 1: Neither player can Normal or Special Summon Effect Monsters, until your next Draw Phase."
    },
    "fr": {
      "name": "Onde de Chaleur",
      "effect": "Au d\u00e9but de votre Main Phase 1 : jusqu'\u00e0 votre prochaine Draw Phase, aucun joueur ne peut Invoquer ni Normalement ni Sp\u00e9cialement de Monstres \u00e0 Effet."
    },
    "de": {
      "name": "Hitzewelle",
      "effect": "Am Beginn deiner Main Phase 1: Kein Spieler kann bis zu deiner n\u00e4chsten Draw Phase Effektmonster als Normal- oder Spezialbeschw\u00f6rung beschw\u00f6ren."
    },
    "it": {
      "name": "Onda di Calore",
      "effect": "All'inizio della tua Main Phase 1: nessun giocatore pu\u00f2 Evocare Normalmente o Specialmente Mostri con Effetto, fino alla tua prossima Draw Phase."
    },
    "pt": {
      "name": "Onda de Calor",
      "effect": "No come\u00e7o da sua Fase Principal 1: at\u00e9 sua pr\u00f3xima Fase de Compra, nenhum duelista pode Invocar Monstros de Efeito por Invoca\u00e7\u00e3o-Normal ou Especial."
    },
    "es": {
      "name": "Oleada de Calor",
      "effect": "Al comienzo de tu Main Phase 1: hasta tu pr\u00f3xima Draw Phase, ning\u00fan jugador puede Invocar Monstruos de Efecto de Modo Normal o Especial."
    },
