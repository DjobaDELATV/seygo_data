  "text": {
    "en": {
      "name": "Chain Destruction",
      "effect": "When a monster(s) with 2000 or less ATK is Summoned: Target 1 of them; destroy all cards with that name in its controller's hand and Main Deck."
    },
    "fr": {
      "name": "Destruction en Cha\u00eene",
      "effect": "Lorsqu'un ou plusieurs monstres avec max. 2000 ATK sont Invoqu\u00e9s : ciblez-en 1 ; d\u00e9truisez toutes les cartes de ce nom dans la main et Main Deck de son contr\u00f4leur."
    },
    "de": {
      "name": "Kettenzerst\u00f6rung",
      "effect": "Wenn ein oder mehr Monster mit 2000 oder weniger ATK beschworen werden: W\u00e4hle 1 von ihnen; zerst\u00f6re alle Karten mit jenem Namen in der Hand und im Main Deck seines Beherrschers."
    },
    "it": {
      "name": "Distruzione a Catena",
      "effect": "Quando uno o pi\u00f9 mostri con ATK 2000 o inferiore vengono Evocati: scegli 1 di essi come bersaglio; distruggi tutte le carte con quel nome nella mano e nel Main Deck del suo controllore."
    },
