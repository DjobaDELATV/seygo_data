      "effect": "\u2460\uff1a\u53ef\u4ece\u4ee5\u4e0b\u6548\u679c\u4e2d\u9009\u62e91\u4e2a\u53d1\u52a8\u3002\n\u25cf\u4ee5\u5bf9\u624b\u573a\u4e0a\u76841\u53ea\u8868\u4fa7\u8868\u793a\u7684\u602a\u517d\u4e3a\u5bf9\u8c61\u53ef\u4ee5\u53d1\u52a8\u3002\u6539\u53d8\u8be5\u5bf9\u624b\u7684\u8868\u4fa7\u8868\u793a\u602a\u517d\u7684\u8868\u793a\u5f62\u5f0f\u3002\n\u25cf\u89e3\u653e\u81ea\u5df1\u573a\u4e0a\u76841\u53ea\u602a\u517d\uff0c\u4ee5\u5bf9\u624b\u573a\u4e0a\u76841\u53ea\u8868\u4fa7\u8868\u793a\u7684\u602a\u517d\u4e3a\u5bf9\u8c61\u53ef\u4ee5\u53d1\u52a8\u3002\u76f4\u81f3\u7ed3\u675f\u9636\u6bb5\u4e3a\u6b62\u83b7\u5f97\u8be5\u8868\u4fa7\u8868\u793a\u602a\u517d\u7684\u63a7\u5236\u6743\u3002"
