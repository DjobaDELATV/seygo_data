  "text": {
    "en": {
      "name": "Aquamirror Cycle",
      "effect": "Target 1 WATER monster you control and 2 WATER monsters in your Graveyard; shuffle the first target into the Deck, and if you do, add the second targets to your hand."
    },
    "fr": {
      "name": "Cycle Aquamiroir",
      "effect": "Ciblez 1 monstre EAU que vous contr\u00f4lez et 2 monstres EAU dans votre Cimeti\u00e8re ; m\u00e9langez la premi\u00e8re cible dans le Deck, et si vous le faites, ajoutez les secondes cibles \u00e0 votre main."
    },
    "de": {
      "name": "Kreislauf des Wasserspiegels",
      "effect": "W\u00e4hle 1 WASSER Monster, das du kontrollierst, und 2 WASSER Monster in deinem Friedhof; mische das erste Ziel ins Deck und falls du dies tust, f\u00fcge die anderen beiden gew\u00e4hlten Ziele deiner Hand hinzu."
    },
    "it": {
      "name": "Ciclo Acquaspecchio",
      "effect": "Scegli come bersaglio 1 mostro ACQUA che controlli e 2 mostri ACQUA nel tuo Cimitero; mischia il primo bersaglio nel Deck e, se lo fai, aggiungi i secondi bersagli alla tua mano."
    },
    "pt": {
      "name": "Ciclo Aqua-espelhado",
      "effect": "Escolha 1 monstro de \u00c1GUA que voc\u00ea controla e 2 monstros de \u00c1GUA no seu Cemit\u00e9rio; embaralhe o primeiro alvo no Deck e, se isso acontecer, adicione os segundos alvos \u00e0 sua m\u00e3o."
    },
    "es": {
      "name": "Ciclo Aquaespejo",
      "effect": "Selecciona 1 monstruo de AGUA que controles y 2 monstruos de AGUA en tu Cementerio; baraja al Deck el primer objetivo y, si lo haces, a\u00f1ade a tu mano los dem\u00e1s objetivos."
    },
