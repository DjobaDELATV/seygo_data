    },
    "ko": {
      "name": "\uae30\uc5b4 \ud0c0\uc6b4",
      "effect": "\u2460: \uc774 \uce74\ub4dc\uac00 \ud544\ub4dc \uc874\uc5d0 \uc874\uc7ac\ud558\ub294 \ud55c, \uc591\ucabd \ud50c\ub808\uc774\uc5b4\ub294 \"\uc564\ud2f1 \uae30\uc5b4\" \ubaac\uc2a4\ud130\ub97c \uc77c\ubc18 \uc18c\ud658\ud560 \uacbd\uc6b0\uc5d0 \ud544\uc694\ud55c \ub9b4\ub9ac\uc2a4\ub97c 1\uc7a5 \uc801\uac8c \ud560 \uc218 \uc788\ub2e4. \u2461: \uc774 \uce74\ub4dc\uac00 \ud30c\uad34\ub418\uc5b4 \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uc84c\uc744 \ub54c\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uc790\uc2e0\uc758 \ud328 / \ub371 / \ubb18\uc9c0\uc5d0\uc11c \"\uc564\ud2f1 \uae30\uc5b4\" \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ud2b9\uc218 \uc18c\ud658\ud55c\ub2e4."
