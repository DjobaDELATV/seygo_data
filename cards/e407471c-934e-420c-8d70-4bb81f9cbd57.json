  "text": {
    "en": {
      "name": "Jain, Lightsworn Paladin",
      "effect": "If this card attacks an opponent's monster, it gains 300 ATK during the Damage Step only. Once per turn, during your End Phase: Send the top 2 cards of your Deck to the Graveyard."
    },
