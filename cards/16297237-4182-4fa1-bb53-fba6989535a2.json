    "en": {
      "name": "El Shaddoll Fusion",
      "effect": "Fusion Summon 1 \"Shaddoll\" Fusion Monster from your Extra Deck, using monsters from your hand or field. You can only activate 1 \"El Shaddoll Fusion\" per turn."
    },
    "fr": {
      "name": "Fusion Marionnette de l'Ombre El",
      "effect": "Invoquez par Fusion 1 Monstre Fusion \"Marionnette de l'Ombre\" depuis votre Extra Deck, en utilisant des monstres depuis votre main ou Terrain. Vous ne pouvez activer qu'1 \"Fusion Marionnette de l'Ombre El\" par tour."
    },
    "de": {
