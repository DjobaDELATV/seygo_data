  "text": {
    "en": {
      "name": "Dark Magical Curtain",
      "effect": "Each player can Special Summon 1 DARK Spellcaster monster from their hand or Deck (but neither player can activate their effects this turn), then if you Special Summoned a monster whose original name is \"Dark Magician\" or \"Dark Magician Girl\", you can add 1 Spell/Trap that mentions \"Dark Magician\" from your Deck to your hand, except \"Dark Magical Curtain\". You can only activate 1 \"Dark Magical Curtain\" per turn.",
      "official": false
    },
    "ja": {
      "name": "\u9ed2\u9b54\u5c0e\u306e\u30ab\u30fc\u30c6\u30f3",
      "effect": "\u3053\u306e\u30ab\u30fc\u30c9\u540d\u306e\u30ab\u30fc\u30c9\u306f\uff11\u30bf\u30fc\u30f3\u306b\uff11\u679a\u3057\u304b\u767a\u52d5\u3067\u304d\u306a\u3044\u3002\u2460\uff1a\u304a\u4e92\u3044\u306f\u305d\u308c\u305e\u308c\u81ea\u8eab\u306e\u624b\u672d\u30fb\u30c7\u30c3\u30ad\u304b\u3089\u9b54\u6cd5\u4f7f\u3044\u65cf\u30fb\u95c7\u5c5e\u6027\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u7279\u6b8a\u53ec\u559a\u3067\u304d\u308b\u3002\u3053\u306e\u52b9\u679c\u3067\u81ea\u5206\u304c\u7279\u6b8a\u53ec\u559a\u3057\u305f\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\u5143\u3005\u306e\u30ab\u30fc\u30c9\u540d\u304c\u300c\u30d6\u30e9\u30c3\u30af\u30fb\u30de\u30b8\u30b7\u30e3\u30f3\u300d\u304b\u300c\u30d6\u30e9\u30c3\u30af\u30fb\u30de\u30b8\u30b7\u30e3\u30f3\u30fb\u30ac\u30fc\u30eb\u300d\u306e\u5834\u5408\u3001\u3055\u3089\u306b\u81ea\u5206\u306f\u300c\u9ed2\u9b54\u5c0e\u306e\u30ab\u30fc\u30c6\u30f3\u300d\u3092\u9664\u304f\u3001\u300c\u30d6\u30e9\u30c3\u30af\u30fb\u30de\u30b8\u30b7\u30e3\u30f3\u300d\u306e\u30ab\u30fc\u30c9\u540d\u304c\u8a18\u3055\u308c\u305f\u9b54\u6cd5\u30fb\u7f60\u30ab\u30fc\u30c9\uff11\u679a\u3092\u30c7\u30c3\u30ad\u304b\u3089\u624b\u672d\u306b\u52a0\u3048\u308b\u4e8b\u304c\u3067\u304d\u308b\u3002\u3053\u306e\u30bf\u30fc\u30f3\u3001\u3053\u306e\u52b9\u679c\u3067\u7279\u6b8a\u53ec\u559a\u3057\u305f\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\u52b9\u679c\u306f\u767a\u52d5\u3067\u304d\u306a\u3044\u3002"
    },
    "ko": {
      "name": "\ud751\ub9c8\ub3c4\uc758 \ucee4\ud2bc",
      "effect": "\uc774 \uce74\ub4dc\uba85\uc758 \uce74\ub4dc\ub294 1\ud134\uc5d0 1\uc7a5\ubc16\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc5c6\ub2e4. \u2460: \uc591\ucabd \ud50c\ub808\uc774\uc5b4\ub294 \uac01\uac01 \uc790\uc2e0\uc758 \ud328 / \ub371\uc5d0\uc11c \ub9c8\ubc95\uc0ac\uc871 / \uc5b4\ub460 \uc18d\uc131 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc788\ub2e4. \uc774 \ud6a8\uacfc\ub85c \uc790\uc2e0\uc774 \ud2b9\uc218 \uc18c\ud658\ud55c \ubaac\uc2a4\ud130\uc758 \uc6d0\ub798\uc758 \uce74\ub4dc\uba85\uc774 \"\ube14\ub799 \ub9e4\uc9c0\uc158\"\uc774\ub098 \"\ube14\ub799 \ub9e4\uc9c0\uc158 \uac78\"\uc77c \uacbd\uc6b0, \ucd94\uac00\ub85c \uc790\uc2e0\uc740 \"\ud751\ub9c8\ub3c4\uc758 \ucee4\ud2bc\"\uc774 \uc544\ub2cc, \"\ube14\ub799 \ub9e4\uc9c0\uc158\"\uc758 \uce74\ub4dc\uba85\uc774 \uc4f0\uc5ec\uc9c4 \ub9c8\ubc95 / \ud568\uc815 \uce74\ub4dc 1\uc7a5\uc744 \ub371\uc5d0\uc11c \ud328\uc5d0 \ub123\uc744 \uc218 \uc788\ub2e4. \uc774 \ud134\uc5d0, \uc774 \ud6a8\uacfc\ub85c \ud2b9\uc218 \uc18c\ud658\ud55c \ubaac\uc2a4\ud130\uc758 \ud6a8\uacfc\ub294 \ubc1c\ub3d9\ud560 \uc218 \uc5c6\ub2e4."
    },
    "zh-CN": {
      "name": "\u9ed1\u4e4b\u9b54\u5bfc\u7684\u5e18\u5e03",
      "effect": "\u6b64\u5361\u540d\u7684\u53611\u56de\u5408\u4ec5\u53ef\u53d1\u52a81\u5f20\u3002\u2460\uff1a\u53cc\u65b9\u53ef\u5404\u81ea\u4ece\u81ea\u8eab\u624b\u724c\u30fb\u724c\u7ec4\u5c061\u53ea\u9b54\u6cd5\u5e08\u65cf\u30fb\u6697\u5c5e\u6027\u602a\u517d\u7279\u6b8a\u53ec\u5524\u3002\u81ea\u5df1\u4ee5\u6b64\u6548\u679c\u7279\u6b8a\u53ec\u5524\u7684\u602a\u517d\u539f\u672c\u5361\u540d\u4e3a\u201c\u9ed1\u9b54\u5bfc\u201d\u6216\u201c\u9ed1\u9b54\u5bfc\u5973\u5b69\u201d\u7684\u60c5\u51b5\u4e0b\uff0c\u81ea\u5df1\u8fdb\u800c\u53ef\u4ece\u724c\u7ec4\u5c06\u9664\u201c\u9ed1\u4e4b\u9b54\u5bfc\u7684\u5e18\u5e03\u201d\u4ee5\u5916\u7684\u30011\u5f20\u8bb0\u8f7d\u6709\u201c\u9ed1\u9b54\u5bfc\u201d\u5361\u540d\u7684\u9b54\u6cd5\u30fb\u9677\u9631\u5361\u52a0\u5165\u624b\u724c\u3002\u6b64\u56de\u5408\uff0c\u4ee5\u6b64\u6548\u679c\u7279\u6b8a\u53ec\u5524\u7684\u602a\u517d\u7684\u6548\u679c\u4e0d\u53ef\u53d1\u52a8\u3002"
