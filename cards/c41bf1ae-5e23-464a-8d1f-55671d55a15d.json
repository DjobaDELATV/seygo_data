  "text": {
    "en": {
      "name": "Orcustrated Return",
      "effect": "Send 1 \"Orcust\" or \"World Legacy\" monster from your hand or face-up field to the GY; draw 2 cards. You can only activate 1 \"Orcustrated Return\" per turn."
    },
    "fr": {
      "name": "Retour Orcustr\u00e9",
      "effect": "Envoyez 1 monstre \"Orcust\" ou \"H\u00e9ritage du Monde\" depuis votre main ou Terrain face recto au Cimeti\u00e8re ; piochez 2 cartes. Vous ne pouvez activer qu'1 \"Retour Orcustr\u00e9\" par tour."
    },
    "de": {
      "name": "Orcustrierte R\u00fcckkehr",
      "effect": "Lege 1 \u201eOrcust\u201c- oder \u201eWeltverm\u00e4chtnis\u201c-Monster von deiner Hand oder offen von deiner Spielfeldseite auf den Friedhof; ziehe 2 Karten. Du kannst nur 1 \u201eOrcustrierte R\u00fcckkehr\u201c pro Spielzug aktivieren."
    },
    "it": {
      "name": "Ritorno Orcusestrato",
      "effect": "Manda 1 mostro \"Orcusestra\" o \"Eredit\u00e0 del Mondo\" dalla tua mano o Terreno scoperto al Cimitero; pesca 2 carte. Puoi attivare solo 1 \"Ritorno Orcusestrato\" per turno."
    },
    "pt": {
