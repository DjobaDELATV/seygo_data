  "text": {
    "en": {
      "name": "A Hero Lives",
      "effect": "If you control no face-up monsters: Pay half your LP; Special Summon 1 Level 4 or lower \"Elemental HERO\" monster from your Deck."
    },
    "fr": {
      "name": "H\u00e9ros Vivant",
      "effect": "Si vous ne contr\u00f4lez aucun monstre face recto : payez la moiti\u00e9 de vos LP ; Invoquez Sp\u00e9cialement 1 monstre \"H\u00c9ROS \u00c9l\u00e9mentaire\" de max. Niveau 4 depuis votre Deck."
    },
    "de": {
      "name": "Ein Held lebt",
      "effect": "Falls du keine offenen Monster kontrollierst: Zahle die H\u00e4lfte deiner LP; beschw\u00f6re 1 \u201eElementar-HELD\u201c-Monster der Stufe 4 oder niedriger als Spezialbeschw\u00f6rung von deinem Deck."
    },
    "it": {
      "name": "Un Eroe Sopravvive",
      "effect": "Se non controlli nessun mostro scoperto: paga la met\u00e0 dei tuoi LP; Evoca Specialmente 1 mostro \"EROE Elementale\" di Livello 4 o inferiore dal tuo Deck."
    },
    "pt": {
      "name": "Um Her\u00f3i Vive",
      "effect": "Se voc\u00ea n\u00e3o controlar nenhum monstro com a face para cima: pague metade dos seus PV; Invoque por Invoca\u00e7\u00e3o-Especial 1 monstro \"HER\u00d3I do Elemento\" de N\u00edvel 4 ou menos do seu Deck."
    },
    "es": {
      "name": "Un H\u00e9roe Vive",
      "effect": "Si no controlas monstruos boca arriba: paga la mitad de tus LP; Invoca de Modo Especial, desde tu Deck, 1 monstruo \"H\u00c9ROE Elemental\" de Nivel 4 o menor."
    },
    "ja": {
      "name": "\u30d2\u30fc\u30ed\u30fc\u30a2\u30e9\u30a4\u30d6",
      "effect": "\u2460\uff1a\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306b\u8868\u5074\u8868\u793a\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\u5b58\u5728\u3057\u306a\u3044\u5834\u5408\u3001\uff2c\uff30\u3092\u534a\u5206\u6255\u3063\u3066\u767a\u52d5\u3067\u304d\u308b\u3002\u30c7\u30c3\u30ad\u304b\u3089\u30ec\u30d9\u30eb\uff14\u4ee5\u4e0b\u306e\u300c\uff25\u30fb\uff28\uff25\uff32\uff2f\u300d\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u7279\u6b8a\u53ec\u559a\u3059\u308b\u3002"
    },
    "ko": {
      "name": "\ud788\uc5b4\ub85c \uc5bc\ub77c\uc774\ube0c",
      "effect": "\u2460: \uc790\uc2e0 \ud544\ub4dc\uc5d0 \uc55e\uba74 \ud45c\uc2dc \ubaac\uc2a4\ud130\uac00 \uc874\uc7ac\ud558\uc9c0 \uc54a\uc744 \uacbd\uc6b0, LP\ub97c \uc808\ubc18 \uc9c0\ubd88\ud558\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \ub371\uc5d0\uc11c \ub808\ubca8 4 \uc774\ud558\uc758 \"\uc5d8\ub9ac\uba58\ud2c0 \ud788\uc5b4\ub85c\" \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ud2b9\uc218 \uc18c\ud658\ud55c\ub2e4."
    },
    "zh-CN": {
