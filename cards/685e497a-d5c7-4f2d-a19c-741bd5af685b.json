  "text": {
    "en": {
      "name": "Gilford the Lightning",
      "effect": "You can Tribute 3 monsters to Tribute Summon (but not Set) this card. If Summoned this way: Destroy all monsters your opponent controls."
    },
    "fr": {
      "name": "Gilford, L'\u00c9clair",
      "effect": "Vous pouvez Sacrifier 3 monstres pour Invoquer par Sacrifice (mais pas Poser) cette carte. Si elle est Invoqu\u00e9e de cette fa\u00e7on : d\u00e9truisez tous les monstres contr\u00f4l\u00e9s par votre adversaire."
    },
    "de": {
      "name": "Gilford der Blitz",
      "effect": "Du kannst 3 Monster als Tribut anbieten, um diese Karte als Tributbeschw\u00f6rung zu beschw\u00f6ren (aber nicht, um sie zu setzen). Falls sie auf diese Art beschworen wird: Zerst\u00f6re alle Monster, die dein Gegner kontrolliert."
    },
