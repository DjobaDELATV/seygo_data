  "text": {
    "en": {
      "name": "Limiter Removal",
      "effect": "Double the ATK of all Machine monsters you currently control, until the end of this turn. During the End Phase of this turn, destroy those monsters."
    },
    "fr": {
      "name": "Limiter Removal",
      "effect": "Jusqu'\u00e0 la fin de ce tour, doublez l'ATK de tous les monstres Machine que vous contr\u00f4lez actuellement. Durant la End Phase de ce tour, d\u00e9truisez ces monstres."
    },
    "de": {
      "name": "Begrenzer-Entferner",
      "effect": "Verdopple bis zum Ende dieses Spielzugs die ATK aller Maschine-Monster, die du derzeit kontrollierst. W\u00e4hrend der End Phase dieses Spielzugs, zerst\u00f6re jene Monster."
    },
