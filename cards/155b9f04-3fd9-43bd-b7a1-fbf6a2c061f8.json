  "text": {
    "en": {
      "name": "Cloak and Dagger",
      "effect": "Declare 1 Monster Card name. If your opponent Normal Summons, Special Summons, or flips that monster(s) face-up, remove that monster(s) and this card from play."
    },
    "fr": {
      "name": "Espionnage",
      "effect": "D\u00e9clarez 1 nom de Carte Monstre. Si votre adversaire fait l'Invocation Normale, l'Invocation Sp\u00e9ciale ou l'Invocation Flip d'un (ou plusieurs) de ce(s) monstre(s) face recto, retirez ce(s) monstre(s) et cette carte du jeu."
    },
    "de": {
      "name": "Umhang und Dolch",
      "effect": "Deklariere 1 Monsterkartennamen. Falls dein Gegner dieses Monster als Normalbeschw\u00f6rung oder Spezialbeschw\u00f6rung beschw\u00f6rt oder es aufdeckt, entferne dieses Monster und diese Karte aus dem Spiel."
    },
    "it": {
      "name": "Mantello e Pugnale",
      "effect": "Dichiara 1 nome di una Carta Mostro. Se il tuo avversario Evoca Normalmente uno o pi\u00f9 di questi mostri, Speciale o per Scoperta, rimuovi quei mostri e questa carta dal gioco."
    },
    "es": {
      "name": "De Capa y Espada",
      "effect": "Nombra una Carta de Monstruo. Si tu adversario Invoca de modo Normal o Especial o voltea ese (esos) monstruo(s) boca arriba, retira a ese (esos) monstruo(s) y a esta carta del juego."
    },
