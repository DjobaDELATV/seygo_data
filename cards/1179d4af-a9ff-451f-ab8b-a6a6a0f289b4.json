    "ko": {
      "name": "\uc12c\ub3c4\ud76c\uff0d\uc2dc\uc988\ucfe0",
      "effect": "\ubb3c \uc18d\uc131 \uc774\uc678\uc758 \"\uc12c\ub3c4\ud76c\" \ubaac\uc2a4\ud130 1\uc7a5\n\uc790\uc2e0\uc740 \"\uc12c\ub3c4\ud76c\uff0d\uc2dc\uc988\ucfe0\"\ub97c 1\ud134\uc5d0 1\ubc88\ubc16\uc5d0 \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc5c6\ub2e4. \u2460: \uc0c1\ub300 \ud544\ub4dc\uc758 \ubaac\uc2a4\ud130\uc758 \uacf5\uaca9\ub825 / \uc218\ube44\ub825\uc740, \uc790\uc2e0 \ubb18\uc9c0\uc758 \ub9c8\ubc95 \uce74\ub4dc\uc758 \uc218 \u00d7 100 \ub0b4\ub9b0\ub2e4. \u2461: \uc774 \uce74\ub4dc\ub97c \ud2b9\uc218 \uc18c\ud658\ud55c \ud134\uc758 \uc5d4\ub4dc \ud398\uc774\uc988\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \ub371\uc5d0\uc11c, \uac19\uc740 \uc774\ub984\uc758 \uce74\ub4dc\uac00 \uc790\uc2e0 \ubb18\uc9c0\uc5d0 \uc874\uc7ac\ud558\uc9c0 \uc54a\ub294 \"\uc12c\ub3c4\" \ub9c8\ubc95 \uce74\ub4dc 1\uc7a5\uc744 \ud328\uc5d0 \ub123\ub294\ub2e4."
    },
