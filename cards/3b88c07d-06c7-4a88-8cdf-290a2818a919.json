  "text": {
    "en": {
      "name": "Magicalized Fusion",
      "effect": "Fusion Summon 1 Spellcaster Fusion Monster from your Extra Deck, by banishing its materials from your field or GY. You can only activate 1 \"Magicalized Fusion\" per turn."
    },
    "fr": {
      "name": "Fusion Magiqualis\u00e9e",
      "effect": "Invoquez par Fusion 1 Monstre Fusion Magicien depuis votre Extra Deck, en bannissant ses Mat\u00e9riels depuis votre Terrain ou Cimeti\u00e8re. Vous ne pouvez activer qu'1 \"Fusion Magiqualis\u00e9e\" par tour."
    },
    "de": {
      "name": "Magiegeladene Fusion",
      "effect": "Beschw\u00f6re 1 Hexer-Fusionsmonster als Fusionsbeschw\u00f6rung von deinem Extra Deck, indem du sein Material von deiner Spielfeldseite oder deinem Friedhof verbannst. Du kannst nur 1 \u201eMagiegeladene Fusion\u201c pro Spielzug aktivieren."
    },
    "it": {
      "name": "Fusione Magicalizzata",
      "effect": "Evoca tramite Fusione 1 Mostro Fusione Incantatore dal tuo Extra Deck, bandendo i suoi materiali dal tuo Terreno o Cimitero. Puoi attivare solo 1 \"Fusione Magicalizzata\" per turno."
    },
    "pt": {
      "name": "Fus\u00e3o Magicalizada",
      "effect": "Invoque por Invoca\u00e7\u00e3o-Fus\u00e3o 1 Monstro de Fus\u00e3o Mago do seu Deck Adicional, ao banir suas mat\u00e9rias do seu campo ou Cemit\u00e9rio. Voc\u00ea s\u00f3 pode ativar 1 \"Fus\u00e3o Magicalizada\" por turno."
    },
    "es": {
      "name": "Fusi\u00f3n Magicalizada",
      "effect": "Invoca por Fusi\u00f3n 1 Monstruo de Fusi\u00f3n Lanzador de Conjuros desde tu Deck Extra, desterrando sus materiales en tu Campo o Cementerio. S\u00f3lo puedes activar 1 \"Fusi\u00f3n Magicalizada\" por turno."
    },
