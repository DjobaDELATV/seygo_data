  "text": {
    "en": {
      "name": "Vanity's Emptiness",
      "effect": "Neither player can Special Summon monsters. If a card is sent from the Deck or the field to your GY: Destroy this card."
    },
    "fr": {
      "name": "Espace de N\u00e9gation",
      "effect": "Aucun joueur ne peut Invoquer Sp\u00e9cialement de monstres. Si une carte est envoy\u00e9e depuis le Deck ou Terrain \u00e0 votre Cimeti\u00e8re : d\u00e9truisez cette carte."
    },
    "de": {
      "name": "Bedeutungslosigkeit der Eitelkeit",
      "effect": "Kein Spieler kann Monster als Spezialbeschw\u00f6rung beschw\u00f6ren. Falls eine Karte vom Deck oder vom Spielfeld auf deinen Friedhof gelegt wird: Zerst\u00f6re diese Karte."
    },
    "it": {
      "name": "Vacuit\u00e0 della Vanit\u00e0",
      "effect": "Nessun giocatore pu\u00f2 Evocare Specialmente mostri. Se una carta viene mandata dal Deck o dal Terreno al tuo Cimitero: distruggi questa carta."
    },
    "pt": {
      "name": "O Vazio da Vaidade",
      "effect": "Nenhum duelista pode Invocar monstros por Invoca\u00e7\u00e3o-Especial. Se um card for enviado do Deck ou do campo para o seu Cemit\u00e9rio: destrua este card."
    },
    "es": {
      "name": "La Futilidad de la Vanidad",
      "effect": "Ning\u00fan jugador puede Invocar monstruos de Modo Especial. Si una carta en el Deck o el Campo es mandada a tu Cementerio: destruye esta carta."
    },
    "ja": {
