  "text": {
    "en": {
      "name": "Summoned Skull",
      "effect": "A fiend with dark powers for confusing the enemy. Among the Fiend-Type monsters, this monster boasts considerable force.\n\n(This card is always treated as an \"Archfiend\" card.)"
    },
    "fr": {
      "name": "Cr\u00e2ne Invoqu\u00e9",
      "effect": "D\u00e9mon dont les pouvoirs diaboliques d\u00e9sorientent l'ennemi. Parmi les monstres de Type D\u00e9mon, ce monstre a une force consid\u00e9rable.\n\n(Cette carte est toujours trait\u00e9e comme carte \"Archd\u00e9mon\".)"
    },
    "de": {
      "name": "Herbeigerufener Totenkopf",
      "effect": "Ein Unterweltler, der seine Gegner mit dunklen Kr\u00e4ften verwirrt. Er ist einer der m\u00e4chtigsten Unterweltler.\n\n(Diese Karte wird immer als \u201eErzunterweltler\u201c-Karte behandelt.)"
    },
    "it": {
      "name": "Teschio Evocato",
      "effect": "Un demone che confonde i nemici con i suoi poteri oscuri. Tra tutti i mostri Demone, questo vanta una forza considerevole.\n\n(Questa carta \u00e8 sempre considerata come una carta \"Arcidemone\".)"
    },
    "pt": {
      "name": "Caveira Invocada",
      "effect": "Um dem\u00f4nio com poderes das trevas para confundir o inimigo. Entre os monstros do tipo dem\u00f4nio, \u00e9 dos mais fortes.\n\n(Este card \u00e9 tratado como um card \"Arquidem\u00f4nio\".)"
    },
    "es": {
      "name": "Cr\u00e1neo Convocado",
      "effect": "Un demonio con poderes oscuros para confundir al enemigo. Entre los monstruos de Tipo Demonio, este monstruo alardea de considerable fuerza.\n\n(Esta carta se trata siempre como una carta \"Archidemonio\")."
    },
