    "ko": {
      "name": "\uc544\ub9c8\uc870\ub124\uc2a4\uc758 \uc560\uc644\ud638\ub791\uc774",
      "effect": "\u2460: \"\uc544\ub9c8\uc870\ub124\uc2a4\uc758 \uc560\uc644\ud638\ub791\uc774\"\ub294 \uc790\uc2e0 \ud544\ub4dc\uc5d0 1\uc7a5\ubc16\uc5d0 \uc55e\uba74 \ud45c\uc2dc\ub85c \uc874\uc7ac\ud560 \uc218 \uc5c6\ub2e4. \u2461: \uc774 \uce74\ub4dc\uc758 \uacf5\uaca9\ub825\uc740, \uc790\uc2e0 \ud544\ub4dc\uc758 \"\uc544\ub9c8\uc870\ub124\uc2a4\" \ubaac\uc2a4\ud130\uc758 \uc218 \u00d7 400 \uc62c\ub9b0\ub2e4. \u2462: \uc774 \uce74\ub4dc\uac00 \ubaac\uc2a4\ud130 \uc874\uc5d0 \uc874\uc7ac\ud558\ub294 \ud55c, \uc0c1\ub300 \ubaac\uc2a4\ud130\ub294 \uc774 \uce74\ub4dc \uc774\uc678\uc758 \"\uc544\ub9c8\uc870\ub124\uc2a4\" \ubaac\uc2a4\ud130\ub97c \uacf5\uaca9\ud560 \uc218 \uc5c6\ub2e4."
    }
