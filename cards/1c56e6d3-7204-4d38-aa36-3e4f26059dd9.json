  "text": {
    "en": {
      "name": "Dragunity Darkspear",
      "effect": "Once per turn: You can Tribute 1 Dragon \"Dragunity\" monster, then target 1 Level 4 or lower Winged Beast monster in your GY; Special Summon that target."
    },
    "fr": {
      "name": "Lance Sombre Dragunit\u00e9",
      "effect": "Une fois par tour : vous pouvez Sacrifier 1 monstre \"Dragunit\u00e9\" Dragon, puis ciblez 1 monstre B\u00eate Ail\u00e9e de max. Niveau 4 dans votre Cimeti\u00e8re ; Invoquez Sp\u00e9cialement la cible."
    },
    "de": {
      "name": "Dracheneinheit Dunkelspeer",
      "effect": "Einmal pro Spielzug: Du kannst 1 \u201eDracheneinheit\u201c-Drache-Monster als Tribut anbieten und dann 1 Gefl\u00fcgeltes Ungeheuer-Monster der Stufe 4 oder niedriger in deinem Friedhof w\u00e4hlen; beschw\u00f6re das gew\u00e4hlte Ziel als Spezialbeschw\u00f6rung."
    },
    "it": {
      "name": "Lancianera Dragunit\u00e0",
      "effect": "Una volta per turno: puoi offrire come Tributo 1 mostro \"Dragunit\u00e0\" Drago, poi scegliere come bersaglio 1 mostro Bestia Alata di Livello 4 o inferiore nel tuo Cimitero; Evoca Specialmente quel bersaglio."
    },
    "pt": {
