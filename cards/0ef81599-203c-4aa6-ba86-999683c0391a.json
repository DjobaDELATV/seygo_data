  "text": {
    "en": {
      "name": "Dimension Shifter",
      "effect": "If you have no cards in your GY (Quick Effect): You can send this card from your hand to the GY; until the end of the next turn, any card sent to the GY is banished instead."
    },
    "fr": {
      "name": "Migrateur Dimensionnel",
      "effect": "Si vous n'avez aucune carte dans votre Cimeti\u00e8re (Effet Rapide) : vous pouvez envoyer cette carte depuis votre main au Cimeti\u00e8re ; jusqu'\u00e0 la fin du prochain tour, les cartes envoy\u00e9es au Cimeti\u00e8re sont bannies \u00e0 la place."
    },
    "de": {
      "name": "Dimensionsverschieber",
      "effect": "Falls du keine Karten in deinem Friedhof hast (Schnelleffekt): Du kannst diese Karte von deiner Hand auf den Friedhof legen; bis zum Ende des n\u00e4chsten Spielzugs wird jede Karte, die auf den Friedhof gelegt wird, stattdessen verbannt."
    },
    "it": {
      "name": "Scorridore Dimensionale",
      "effect": "Se non hai carte nel tuo Cimitero (Effetto Rapido): puoi mandare questa carta dalla tua mano al Cimitero; fino alla fine del prossimo turno, qualsiasi carta mandata al Cimitero viene invece bandita."
    },
    "pt": {
      "name": "Deslocador Dimensional",
      "effect": "Se voc\u00ea n\u00e3o tiver cards no seu Cemit\u00e9rio (Efeito R\u00e1pido): voc\u00ea pode enviar este card da sua m\u00e3o para o Cemit\u00e9rio; at\u00e9 o final do pr\u00f3ximo turno, qualquer card enviado para o Cemit\u00e9rio, em vez disso, \u00e9 banido."
    },
    "es": {
      "name": "Variador Dimensional",
      "effect": "Si no tienes cartas en tu Cementerio (Efecto R\u00e1pido): puedes mandar al Cementerio esta carta en tu mano; hasta el final del pr\u00f3ximo turno, cualquier carta mandada al Cementerio es desterrada en su lugar."
    },
    "ja": {
      "name": "\u30c7\u30a3\u30e1\u30f3\u30b7\u30e7\u30f3\u30fb\u30a2\u30c8\u30e9\u30af\u30bf\u30fc",
