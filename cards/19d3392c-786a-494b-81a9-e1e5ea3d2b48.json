    "ko": {
      "name": "Live\u2606Twin \ud0a4\uc2a4\ud0ac",
      "effect": "\uc774 \uce74\ub4dc\uba85\uc758 \u2460\uc758 \ud6a8\uacfc\ub294 1\ud134\uc5d0 1\ubc88\ubc16\uc5d0 \uc0ac\uc6a9\ud560 \uc218 \uc5c6\ub2e4. \u2460: \uc774 \uce74\ub4dc\uac00 \uc77c\ubc18 \uc18c\ud658 / \ud2b9\uc218 \uc18c\ud658\uc5d0 \uc131\uacf5\ud588\uc744 \uacbd\uc6b0, \uc790\uc2e0 \ud544\ub4dc\uc5d0 \ub2e4\ub978 \ubaac\uc2a4\ud130\uac00 \uc874\uc7ac\ud558\uc9c0 \uc54a\uc73c\uba74 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \ud328 / \ub371\uc5d0\uc11c \"\ub9ac\uc77c\ub77c\" \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ud2b9\uc218 \uc18c\ud658\ud55c\ub2e4. \u2461: \uc774 \uce74\ub4dc\uac00 \ubaac\uc2a4\ud130 \uc874\uc5d0 \uc874\uc7ac\ud558\ub294 \ud55c, \uc0c1\ub300 \ubaac\uc2a4\ud130\uac00 \uacf5\uaca9 \uc120\uc5b8\ud560 \ub54c\ub9c8\ub2e4, \uc790\uc2e0\uc740 500 LP \ud68c\ubcf5\ud55c\ub2e4."
    },
    "zh-CN": {
