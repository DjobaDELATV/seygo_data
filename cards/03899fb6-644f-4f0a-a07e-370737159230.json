  "id": "03899fb6-644f-4f0a-a07e-370737159230",
  "text": {
    "en": {
      "name": "Creature Swap",
      "effect": "Each player chooses 1 monster they control and switches control of those monsters with each other. Those monsters cannot change their battle positions for the rest of this turn."
    },
    "fr": {
      "name": "Permutation de Cr\u00e9ature",
      "effect": "Chaque joueur choisit 1 monstre qu'il contr\u00f4le et \u00e9change son contr\u00f4le avec celui choisi par l'adversaire. Le reste de ce tour, ces monstres ne peuvent pas changer de position de combat."
    },
    "de": {
      "name": "Kreaturentausch",
      "effect": "Jeder Spieler bestimmt 1 Monster, das er kontrolliert, und ihr tauscht die Kontrolle \u00fcber jene Monster. Jene Monster k\u00f6nnen f\u00fcr den Rest dieses Spielzugs ihre Kampfpositionen nicht \u00e4ndern."
    },
    "it": {
      "name": "Scambio-Creature",
      "effect": "Ogni giocatore seleziona 1 mostro che controlla e scambia il controllo di quel mostro con quello selezionato dall'avversario. Quei mostri non possono cambiare la loro posizione per il resto di questo turno."
    },
    "pt": {
      "name": "Troca de Criaturas",
      "effect": "Cada duelista seleciona 1 monstro que ele controla e eles trocam o controle desses monstros um com o outro. Esses monstros n\u00e3o podem mudar suas posi\u00e7\u00f5es de batalha pelo resto deste turno."
    },
    "es": {
      "name": "Intercambio de Criatura",
      "effect": "Cada jugador elige 1 monstruo que controle e intercambia el control de ese monstruo con el otro jugador. Por el resto de este turno, esos monstruos no pueden cambiar sus posiciones de batalla."
    },
    "ja": {
