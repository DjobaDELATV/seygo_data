  "text": {
    "en": {
      "name": "Mezuki",
      "effect": "You can banish this card from your GY, then target 1 Zombie monster in your GY; Special Summon that target."
    },
    "fr": {
      "name": "Mezuki",
      "effect": "Vous pouvez bannir cette carte depuis votre Cimeti\u00e8re, puis ciblez 1 monstre Zombie dans votre Cimeti\u00e8re ; Invoquez Sp\u00e9cialement la cible."
    },
    "de": {
      "name": "Mezuki",
      "effect": "Du kannst diese Karte von deinem Friedhof verbannen und dann 1 Zombie-Monster in deinem Friedhof w\u00e4hlen; beschw\u00f6re jenes gew\u00e4hlte Ziel als Spezialbeschw\u00f6rung."
    },
    "it": {
      "name": "Mezuki",
      "effect": "Puoi bandire questa carta dal tuo Cimitero, poi scegliere come bersaglio 1 mostro Zombie nel tuo Cimitero; Evoca Specialmente quel bersaglio."
    },
    "pt": {
      "name": "Mezuki",
      "effect": "Voc\u00ea pode banir este card do seu Cemit\u00e9rio e, depois, escolha 1 monstro Zumbi no seu Cemit\u00e9rio; Invoque o alvo por Invoca\u00e7\u00e3o-Especial."
    },
