{
  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "09a57485-1eb5-4ecb-ad48-7143984da23d",
  "text": {
    "en": {
      "name": "Powerful Rebirth",
      "effect": "Activate this card by targeting 1 Level 4 or lower monster in your GY; Special Summon that target. Increase its Level by 1 and ATK/DEF by 100. When that monster is destroyed, destroy this card."
    },
    "fr": {
      "name": "Puissante Renaissance",
      "effect": "Activez cette carte en ciblant 1 monstre de max. Niveau 4 dans votre Cimeti\u00e8re ; Invoquez Sp\u00e9cialement la cible. Augmentez son Niveau de 1 et son ATK/DEF de 100. Lorsque le monstre est d\u00e9truit, d\u00e9truisez cette carte."
    },
    "de": {
      "name": "Machtvolle Wiedergeburt",
      "effect": "Aktiviere diese Karte, indem du 1 Monster der Stufe 4 oder niedriger in deinem Friedhof w\u00e4hlst; beschw\u00f6re jenes gew\u00e4hlte Ziel als Spezialbeschw\u00f6rung. Erh\u00f6he seine Stufe um 1 und seine ATK/DEF um 100. Wenn jenes Monster zerst\u00f6rt wird, zerst\u00f6re diese Karte."
    },
    "it": {
      "name": "Rinascita Potente",
      "effect": "Attiva questa carta scegliendo come bersaglio 1 mostro di Livello 4 o inferiore nel tuo Cimitero; Evoca Specialmente quel bersaglio. Aumenta il suo Livello di 1 e i suoi ATK/DEF di 100. Quando quel mostro viene distrutto, distruggi questa carta."
    },
    "pt": {
      "name": "Renascimento Poderoso",
      "effect": "Ative este card ao escolher 1 monstro de N\u00edvel 4 ou menos no seu Cemit\u00e9rio; Invoque o alvo por Invoca\u00e7\u00e3o-Especial. Aumente o N\u00edvel dele em 1 e o ATK/DEF em 100. Quando esse monstro for destru\u00eddo, destrua este card."
    },
    "es": {
      "name": "Renacimiento Poderoso",
      "effect": "Activa esta carta seleccionando 1 monstruo de Nivel 4 o menor en tu Cementerio; Invoca ese objetivo de Modo Especial. Aumenta su Nivel en 1 y su ATK/DEF en 100. Cuando ese monstruo es destruido, destruye esta carta."
    },
    "ja": {
      "name": "\u5f37\u5316\u8607\u751f",
      "effect": "\u2460\uff1a\u81ea\u5206\u306e\u5893\u5730\u306e\u30ec\u30d9\u30eb\uff14\u4ee5\u4e0b\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u5bfe\u8c61\u3068\u3057\u3066\u3053\u306e\u30ab\u30fc\u30c9\u3092\u767a\u52d5\u3067\u304d\u308b\u3002\u305d\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u7279\u6b8a\u53ec\u559a\u3059\u308b\u3002\u3053\u306e\u30ab\u30fc\u30c9\u304c\u9b54\u6cd5\uff06\u7f60\u30be\u30fc\u30f3\u306b\u5b58\u5728\u3059\u308b\u9650\u308a\u3001\u305d\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\u30ec\u30d9\u30eb\u306f\uff11\u3064\u4e0a\u304c\u308a\u3001\u653b\u6483\u529b\u30fb\u5b88\u5099\u529b\u306f\uff11\uff10\uff10\u30a2\u30c3\u30d7\u3059\u308b\u3002\u305d\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\u7834\u58ca\u3055\u308c\u305f\u6642\u306b\u3053\u306e\u30ab\u30fc\u30c9\u306f\u7834\u58ca\u3055\u308c\u308b\u3002"
    },
    "ko": {
      "name": "\uac15\ud654\uc18c\uc0dd",
      "effect": "\u2460: \uc790\uc2e0 \ubb18\uc9c0\uc758 \ub808\ubca8 4 \uc774\ud558\uc758 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ub300\uc0c1\uc73c\ub85c \ud558\uace0 \uc774 \uce74\ub4dc\ub97c \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uadf8 \ubaac\uc2a4\ud130\ub97c \ud2b9\uc218 \uc18c\ud658\ud55c\ub2e4. \uc774 \uce74\ub4dc\uac00 \ub9c8\ubc95 & \ud568\uc815 \uc874\uc5d0 \uc874\uc7ac\ud558\ub294 \ud55c, \uadf8 \ubaac\uc2a4\ud130\uc758 \ub808\ubca8\uc740 1\uac1c \uc62c\ub77c\uac00\uace0, \uacf5\uaca9\ub825 / \uc218\ube44\ub825\uc740 100 \uc62c\ub9b0\ub2e4. \uadf8 \ubaac\uc2a4\ud130\uac00 \ud30c\uad34\ub418\uc5c8\uc744 \ub54c\uc5d0 \uc774 \uce74\ub4dc\ub294 \ud30c\uad34\ub41c\ub2e4."
    },
    "zh-TW": {
      "name": "\u5f3a\u5316\u5fa9\u7526",
      "effect": "\u4ece\u6211\u65b9\u5893\u5730\u9009\u62e9\u7b49\u7ea74\u4ee5\u4e0b\u76841\u53ea\u602a\u517d\u8fdb\u884c\u7279\u6b8a\u53ec\u5524\u3002\u53d7\u6b64\u6548\u679c\u7279\u6b8a\u53ec\u5524\u7684\u602a\u517d\u5c06\u63d0\u53471\u7b49\u7ea7\uff0c\u63d0\u5347\u653b\u51fb\u529b\u3001\u5b88\u5907\u529b100\u70b9\u3002\u5f53\u8be5\u602a\u517d\u906d\u7834\u574f\u65f6\uff0c\u7834\u574f\u6b64\u5361\u3002"
    },
    "zh-CN": {
      "name": "\u5f3a\u5316\u82cf\u751f",
