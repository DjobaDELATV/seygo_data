  "text": {
    "en": {
      "name": "Tutan Mask",
      "effect": "When a Spell/Trap Card is activated that targets exactly 1 Zombie monster on the field (and no other cards): Negate the activation, and if you do, destroy it."
    },
    "fr": {
      "name": "Masque de Tutan",
      "effect": "Lorsqu'une Carte Magie/Pi\u00e8ge qui cible exactement 1 monstre Zombie sur le Terrain (et aucune autre carte) est activ\u00e9e : annulez l'activation, et si vous le faites, d\u00e9truisez-la."
    },
    "de": {
      "name": "Tutan-Maske",
      "effect": "Wenn eine Zauber-/Fallenkarte aktiviert wird, die genau 1 Zombie-Monster auf dem Spielfeld (und keine anderen Karten) als Ziel w\u00e4hlt: Annulliere die Aktivierung und falls du dies tust, zerst\u00f6re sie."
    },
    "it": {
      "name": "Maschera di Tutan",
      "effect": "Quando viene attivata una Carta Magia/Trappola che sceglie come bersaglio esattamente 1 mostro Zombie sul Terreno (e nessun'altra carta): annulla l'attivazione e, se lo fai, distruggila."
    },
    "pt": {
      "name": "M\u00e1scara de Tutan",
      "effect": "Quando um Card de Magia/Armadilha que escolha como alvo exatamente 1 monstro Zumbi no campo (e nenhum outro card) for ativado: negue a ativa\u00e7\u00e3o e, se isso acontecer, destrua-o."
    },
    "es": {
      "name": "M\u00e1scara Tutan",
      "effect": "Cuando es activada una Carta M\u00e1gica/de Trampa que selecciona exactamente 1 monstruo Zombi en el Campo (y ninguna otra carta): niega la activaci\u00f3n y, si lo haces, destruye la carta."
    },
