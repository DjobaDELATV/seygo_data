    "en": {
      "name": "Zeradias, Herald of Heaven",
      "effect": "You can discard this card to the GY; add 1 \"The Sanctuary in the Sky\" from your Deck to your hand. If \"The Sanctuary in the Sky\" is not on the field, destroy this card."
    },
    "fr": {
      "name": "Z\u00e9radias, H\u00e9raut du Paradis",
      "effect": "Vous pouvez d\u00e9fausser cette carte au Cimeti\u00e8re ; ajoutez 1 \"Le Sanctuaire C\u00e9leste\" depuis votre Deck \u00e0 votre main. Si \"Le Sanctuaire C\u00e9leste\" n'est pas sur le Terrain, d\u00e9truisez cette carte."
    },
    "de": {
      "name": "Zeradias, Herold des Himmels",
