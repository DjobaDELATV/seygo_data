  "text": {
    "en": {
      "name": "Snatch Steal",
      "effect": "Equip only to an opponent's monster. Take control of the equipped monster. Once per turn, during your opponent's Standby Phase: They gain 1000 LP."
    },
    "fr": {
      "name": "Vol \u00e0 l'Arrach\u00e9",
      "effect": "\u00c9quipable uniquement \u00e0 un monstre de l'adversaire. Prenez le contr\u00f4le du monstre \u00e9quip\u00e9. Une fois par tour, durant la Standby Phase de votre adversaire : il gagne 1000 LP."
    },
    "de": {
      "name": "Schnappstahl",
      "effect": "R\u00fcste nur ein Monster eines Gegners mit dieser Karte aus. \u00dcbernimm die Kontrolle \u00fcber das ausger\u00fcstete Monster. Einmal pro Spielzug, w\u00e4hrend der Standby Phase deines Gegners: Er erh\u00e4lt 1000 LP."
    },
    "it": {
      "name": "Strappa Possesso",
      "effect": "Equipaggia solo a un mostro dell'avversario. Prendi il controllo del mostro equipaggiato. Una volta per turno, durante la Standby Phase del tuo avversario: lui guadagna 1000 LP."
    },
    "pt": {
      "name": "Roubo Precipitado",
      "effect": "S\u00f3 pode ser equipado a um monstro do oponente. Tome o controle do monstro equipado. Uma vez por turno, durante a Fase de Apoio do seu oponente: ele ganha 1000 PV."
    },
    "es": {
      "name": "Robo Oportunista",
      "effect": "S\u00f3lo puedes equipar esta carta a un monstruo del adversario. Toma el control del monstruo equipado. Una vez por turno, durante la Standby Phase de tu adversario: \u00e9ste gana 1000 LP."
    },
