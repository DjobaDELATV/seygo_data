  "text": {
    "en": {
      "name": "Alligator's Sword Dragon",
      "effect": "\"Baby Dragon\" + \"Alligator's Sword\"\nThis card can attack your opponent directly if the only face-up monsters they control are EARTH, WATER, or FIRE."
    },
    "fr": {
      "name": "Dragon du Glaive de l'Alligator",
      "effect": "\"B\u00e9b\u00e9 Dragon\" + \"Glaive de l'Alligator\"\nCette carte peut attaquer directement votre adversaire s'il contr\u00f4le uniquement des monstres TERRE, EAU ou FEU face recto."
    },
    "de": {
      "name": "Alligatorschwert-Drache",
      "effect": "\u201eBabydrache\u201c + \u201eAlligatorschwert\u201c\nDiese Karte kann deinen Gegner direkt angreifen, falls die einzigen offenen Monster, die er kontrolliert, ERDE, WASSER oder FEUER sind."
    },
    "it": {
      "name": "Drago Spada dell'Alligatore",
      "effect": "\"Cucciolo di Drago\" + \"Spada dell'Alligatore\"\nQuesta carta pu\u00f2 attaccare il tuo avversario direttamente se gli unici mostri scoperti che controlla sono TERRA, ACQUA o FUOCO."
    },
    "pt": {
      "name": "Drag\u00e3o Espada do Jacar\u00e9",
      "effect": "\"Drag\u00e3o Filhote\" + \"Espada do Jacar\u00e9\"\nEste card pode atacar diretamente seu oponente se os \u00fanicos monstros com a face para cima que ele controla forem de TERRA, \u00c1GUA ou FOGO."
    },
    "es": {
      "name": "Drag\u00f3n del Alig\u00e1tor de la Espada",
      "effect": "\"Beb\u00e9 Drag\u00f3n\" + \"Alig\u00e1tor de la Espada\"\nEsta carta puede atacar a tu adversario directamente si los \u00fanicos monstruos boca arriba que controla son de TIERRA, AGUA o FUEGO."
    },
