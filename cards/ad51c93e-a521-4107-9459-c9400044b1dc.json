  "text": {
    "en": {
      "name": "The Puppet Magic of Dark Ruler",
      "effect": "Target 1 Fiend monster in your GY; banish face-up monsters you control whose total Levels exactly equal the Level of that monster, then Special Summon it."
    },
    "fr": {
      "name": "Poup\u00e9e Magique du Gouverneur des T\u00e9n\u00e8bres",
      "effect": "Ciblez 1 monstre D\u00e9mon dans votre Cimeti\u00e8re ; bannissez des monstres face recto que vous contr\u00f4lez dont le Niveau total est exactement \u00e9gal au Niveau du monstre, puis Invoquez-le Sp\u00e9cialement."
    },
    "de": {
      "name": "Puppenmagie des Dunklen Herrschers",
      "effect": "W\u00e4hle 1 Unterweltler-Monster in deinem Friedhof; verbanne offene Monster, die du kontrollierst und deren gemeinsame Stufe genau der Stufe des Monsters entspricht, dann beschw\u00f6re es als Spezialbeschw\u00f6rung."
    },
    "it": {
      "name": "Il Pupazzo Magico del Sovrano Oscuro",
      "effect": "Scegli come bersaglio 1 mostro Demone nel tuo Cimitero; bandisci mostri scoperti che controlli con Livello totale pari esattamente al Livello di quel mostro, poi Evocalo Specialmente."
    },
    "es": {
