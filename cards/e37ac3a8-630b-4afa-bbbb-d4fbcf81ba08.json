  "text": {
    "en": {
      "name": "Thestalos the Firestorm Monarch",
      "effect": "If this card is Tribute Summoned: Discard 1 random card from your opponent's hand, then, if it was a Monster Card, inflict damage to your opponent equal to its original Level x 100."
    },
    "fr": {
      "name": "Thestalos, le Monarque de la Temp\u00eate de Feu",
      "effect": "Si cette carte est Invoqu\u00e9e par Sacrifice : d\u00e9faussez 1 carte au hasard \u00e0 votre adversaire, puis, si c'\u00e9tait une Carte Monstre, infligez des dommages \u00e0 votre adversaire \u00e9gaux \u00e0 son Niveau d'origine x 100."
    },
    "de": {
      "name": "Thestalos, der Feuersturmmonarch",
      "effect": "Falls diese Karte als Tributbeschw\u00f6rung beschworen wird: Wirf 1 zuf\u00e4llige Karte von der Hand deines Gegners ab, dann, falls es eine Monsterkarte war, f\u00fcge deinem Gegner Schaden in H\u00f6he ihrer Grundstufe x 100 zu."
    },
    "it": {
      "name": "Thestalos il Monarca della Tempesta di Fuoco",
      "effect": "Se questa carta viene Evocata tramite Tributo: scarta 1 carta a caso dalla mano del tuo avversario, poi, se era una Carta Mostro, infliggi al tuo avversario danno pari al suo Livello originale x 100."
    },
    "pt": {
      "name": "Thestalos, o Monarca da Tempestade de Fogo",
      "effect": "Se este card for Invocado por Invoca\u00e7\u00e3o-Tributo: descarte 1 card aleat\u00f3rio da m\u00e3o do seu oponente e, depois, se era um Card de Monstro, cause dano ao seu oponente igual ao N\u00edvel original desse monstro x 100."
    },
    "es": {
      "name": "Thestalos el Monarca de la Tormenta de Fuego",
      "effect": "Si esta carta es Invocada por Sacrificio: descarta 1 carta al azar de la mano de tu adversario y despu\u00e9s, si era una Carta de Monstruo, inflige da\u00f1o a tu adversario igual a su Nivel original x 100."
    },
