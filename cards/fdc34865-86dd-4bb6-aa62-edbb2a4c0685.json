  "text": {
    "en": {
      "name": "Fiend Griefing",
      "effect": "Target 1 monster in your opponent's GY; shuffle it into the Deck, then you can send 1 Fiend monster from your Deck to the GY."
    },
    "fr": {
      "name": "Peine de D\u00e9mon",
