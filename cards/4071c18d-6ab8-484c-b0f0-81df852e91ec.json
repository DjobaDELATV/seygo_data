    "en": {
      "name": "Crimson Call",
      "effect": "Add 1 Level 4 or lower Fiend monster from your GY to your hand, or if you control \"Red Dragon Archfiend\" or a Synchro Monster that mentions it, you can add the monster from your Deck instead. If your \"/Assault Mode\" monster or \"Red Dragon Archfiend\" attacks, at the end of the Damage Step: You can banish this card from your GY; that monster can make a second attack in a row. You can only activate 1 \"Crimson Call\" per turn.",
      "official": false
    },
