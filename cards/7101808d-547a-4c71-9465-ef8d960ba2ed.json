  "text": {
    "en": {
      "name": "Royal Oppression",
      "effect": "Either player can pay 800 Life Points to negate the Special Summon of a monster(s), and/or an effect that Special Summons a monster(s), and destroy those cards."
    },
    "fr": {
      "name": "Oppression Royale",
      "effect": "Chaque joueur peut payer 800 Life Points pour annuler l'Invocation Sp\u00e9ciale d'un ou plusieurs monstres, et/ou un effet qui permet d'Invoquer Sp\u00e9cialement un ou plusieurs monstres, et d\u00e9truire ces cartes."
    },
    "de": {
      "name": "Unterdr\u00fcckungsherrschaft",
      "effect": "Jeder Spieler kann 800 Life Points zahlen, um die Spezialbeschw\u00f6rung von Monstern und/oder einem Effekt, der Monster als Spezialbeschw\u00f6rung beschw\u00f6rt, zu annullieren und die Karten zu zerst\u00f6ren."
    },
    "it": {
      "name": "Oppressione Reale",
      "effect": "Qualsiasi giocatore pu\u00f2 pagare 800 Life Point per annullare l'Evocazione Speciale di uno o pi\u00f9 mostri, e/o un effetto che Evoca Specialmente uno o pi\u00f9 mostri, e distruggere quelle carte."
    },
    "pt": {
      "name": "Opress\u00e3o Real",
      "effect": "Qualquer duelista pode pagar 800 PV para negar a Invoca\u00e7\u00e3o-Especial de um ou mais monstros, e/ou um efeito que Invoque por Invoca\u00e7\u00e3o-Especial um ou mais monstros, e destruir esses cards."
    },
    "es": {
      "name": "Opresi\u00f3n Real",
      "effect": "Cualquier jugador puede pagar 800 Life Points para negar la Invocaci\u00f3n Especial de uno o m\u00e1s monstruos, y/o un efecto que Invoca a uno o m\u00e1s monstruos de Modo Especial, y destruir esas cartas."
    },
