  "text": {
    "en": {
      "name": "Super Polymerization",
      "effect": "Discard 1 card; Fusion Summon 1 Fusion Monster from your Extra Deck, using monsters from either field. Neither player can activate cards or effects in response to this card's activation."
    },
    "fr": {
      "name": "Super Polym\u00e9risation",
      "effect": "D\u00e9faussez 1 carte ; Invoquez par Fusion 1 Monstre Fusion depuis votre Extra Deck, en utilisant des monstres depuis au moins l'un des Terrains. Aucun joueur ne peut activer ni de cartes ni d'effets en r\u00e9ponse \u00e0 l'activation de cette carte."
    },
    "de": {
      "name": "Superpolymerisation",
      "effect": "Wirf 1 Karte ab; beschw\u00f6re 1 Fusionsmonster als Fusionsbeschw\u00f6rung von deinem Extra Deck, indem du Monster von einer beliebigen Spielfeldseite verwendest. Kein Spieler kann Karten oder Effekte als Reaktion auf die Aktivierung dieser Karte aktivieren."
    },
    "it": {
      "name": "Super Polimerizzazione",
      "effect": "Scarta 1 carta; Evoca tramite Fusione 1 Mostro Fusione dal tuo Extra Deck, utilizzando mostri da qualsiasi Terreno. Nessun giocatore pu\u00f2 attivare carte o effetti in risposta all'attivazione di questa carta."
    },
    "pt": {
      "name": "Super Polimeriza\u00e7\u00e3o",
      "effect": "Descarte 1 card; Invoque por Invoca\u00e7\u00e3o-Fus\u00e3o 1 Monstro de Fus\u00e3o do seu Deck Adicional, usando monstros de qualquer campo. Nenhum duelista pode ativar cards ou efeitos em resposta \u00e0 ativa\u00e7\u00e3o deste card."
    },
    "es": {
      "name": "S\u00faper Polimerizaci\u00f3n",
      "effect": "Descarta 1 carta; Invoca por Fusi\u00f3n 1 Monstruo de Fusi\u00f3n desde tu Deck Extra, usando monstruos de cualquier Campo. Ning\u00fan jugador puede activar cartas o efectos en respuesta a la activaci\u00f3n de esta carta."
    },
    "ja": {
