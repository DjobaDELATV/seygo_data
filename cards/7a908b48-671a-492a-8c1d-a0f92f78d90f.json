  "text": {
    "en": {
      "name": "Designer Frightfur",
      "effect": "Target 1 \"Edge Imp\" or \"Fluffal\" monster in your Graveyard; Special Summon it, and if you do, it can be treated as a \"Frightfur\" monster for a Fusion Summon."
    },
    "fr": {
      "name": "Marque Frourreur",
      "effect": "Ciblez 1 monstre \"Lutin Tranchant\" ou \"Peluchimal\" dans votre Cimeti\u00e8re ; Invoquez-le Sp\u00e9cialement, et si vous le faites, il peut \u00eatre trait\u00e9 comme un monstre \"Frourreur\" pour une Invocation Fusion."
    },
    "de": {
      "name": "Designer-Schreckenspelz",
      "effect": "W\u00e4hle 1 \u201eenkobold\u201c- oder \u201eKuscheltier\u201c-Monster in deinem Friedhof; beschw\u00f6re es als Spezialbeschw\u00f6rung und falls du dies tust, kann es f\u00fcr eine Fusionsbeschw\u00f6rung als ein \u201eSchreckenspelz\u201c-Monster behandelt werden."
    },
    "it": {
      "name": "Designer Pellicciaspavento",
      "effect": "Scegli come bersaglio 1 mostro \"Imp Filo\" o \"Fluffal\" nel tuo Cimitero; Evocalo Specialmente e, se lo fai, esso pu\u00f2 essere considerato come un mostro \"Pellicciaspavento\" per un'Evocazione tramite Fusione."
    },
    "pt": {
      "name": "Designer Peladura",
      "effect": "Escolha 1 monstro \"Diabrete de\" ou \"Fofanimal\" no seu Cemit\u00e9rio; Invoque-o por Invoca\u00e7\u00e3o-Especial e, se isso acontecer, ele pode ser considerado como um monstro \"Peladura\" para uma Invoca\u00e7\u00e3o-Fus\u00e3o."
    },
    "es": {
      "name": "Atemorizante de Dise\u00f1o",
      "effect": "Selecciona 1 monstruo \"Diablillo de\" o \"Peluchanimal\" en tu Cementerio; Inv\u00f3calo de Modo Especial y, si lo haces, \u00e9ste puede ser tratado como un monstruo \"Atemorizante\" para una Invocaci\u00f3n por Fusi\u00f3n."
    },
