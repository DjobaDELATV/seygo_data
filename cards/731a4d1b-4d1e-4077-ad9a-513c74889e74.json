  "id": "731a4d1b-4d1e-4077-ad9a-513c74889e74",
  "text": {
    "en": {
      "name": "Liberty at Last!",
      "effect": "When a monster you control is destroyed by battle and sent to the GY: Target 2 face-up monsters on the field; shuffle those targets into the Deck."
    },
    "fr": {
      "name": "Vive la Libert\u00e9 !",
      "effect": "Lorsqu'un monstre que vous contr\u00f4lez est d\u00e9truit au combat et envoy\u00e9 au Cimeti\u00e8re : ciblez 2 monstres face recto sur le Terrain ; m\u00e9langez les cibles dans le Deck."
    },
    "de": {
      "name": "Endlich frei!",
      "effect": "Wenn ein Monster, das du kontrollierst, durch Kampf zerst\u00f6rt und auf den Friedhof gelegt wird: W\u00e4hle 2 offene Monster auf dem Spielfeld; mische jene gew\u00e4hlten Ziele ins Deck."
    },
    "it": {
      "name": "Libert\u00e0 Finalmente!",
      "effect": "Quando un mostro che controlli viene distrutto in battaglia e mandato al Cimitero: scegli come bersaglio 2 mostri scoperti sul Terreno; mischia quei bersagli nel Deck."
    },
    "pt": {
      "name": "Enfim, Liberdade!",
      "effect": "Quando um monstro que voc\u00ea controla for destru\u00eddo em batalha e enviado para o Cemit\u00e9rio: escolha 2 monstros com a face para cima no campo; embaralhe os alvos no Deck."
    },
    "es": {
      "name": "\u00a1Libertad al fin!",
      "effect": "Cuando un monstruo que controles es destruido en batalla y mandado al Cementerio: selecciona 2 monstruos boca arriba en el Campo; baraja esos objetivos al Deck."
    },
    "ja": {
