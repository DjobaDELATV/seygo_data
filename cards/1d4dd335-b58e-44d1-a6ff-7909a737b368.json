    "en": {
      "name": "Winged Dragon, Guardian of the Fortress #1",
      "effect": "A dragon commonly found guarding mountain fortresses. Its signature attack is a sweeping dive from out of the blue."
    },
    "fr": {
      "name": "Dragon Ail\u00e9, Gardien de la Forteresse N\u00b01",
      "effect": "Dragon que l'on trouve g\u00e9n\u00e9ralement gardant les forteresses de montagne. On le reconna\u00eet \u00e0 son attaque sous forme de plongeon profond venu de nulle part."
    },
    "de": {
      "name": "Gefl\u00fcgelter Drache, Festungsw\u00e4chter #1",
      "effect": "Ein Drache, der h\u00e4ufig Bergfestungen bewacht. Er greift f\u00fcr gew\u00f6hnlich wie aus heiterem Himmel mit einer schwungvollen Flugattacke an."
    },
    "it": {
      "name": "Drago Alato #1",
      "effect": "Un drago che di solito si trova a guardia di fortezze di montagna. Il suo attacco preferito \u00e8 un'improvvisa picchiata."
    },
