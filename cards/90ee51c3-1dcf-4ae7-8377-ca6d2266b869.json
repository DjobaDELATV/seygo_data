  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "90ee51c3-1dcf-4ae7-8377-ca6d2266b869",
  "text": {
    "en": {
      "name": "Harpie Queen",
      "effect": "This card's name becomes \"Harpie Lady\" while on the field or in the GY. You can discard this card to the GY; add 1 \"Harpies' Hunting Ground\" from your Deck to your hand."
    },
    "fr": {
      "name": "Reine Harpie",
      "effect": "Le nom de cette carte devient \"Dame Harpie\" tant qu'elle est sur le Terrain ou dans le Cimeti\u00e8re. Vous pouvez d\u00e9fausser cette carte au Cimeti\u00e8re ; ajoutez 1 \"Terrain de Chasse des Harpies\" depuis votre Deck \u00e0 votre main."
    },
    "de": {
      "name": "Harpyien-K\u00f6nigin",
      "effect": "Der Name dieser Karte wird zu \u201eHarpyie\u201c, solange sie auf dem Spielfeld oder im Friedhof liegt. Du kannst diese Karte auf den Friedhof abwerfen; f\u00fcge deiner Hand 1 \u201eJagdgr\u00fcnde der Harpyien\u201c von deinem Deck hinzu."
    },
    "it": {
      "name": "Regina Arpia",
      "effect": "Il nome di questa carta diventa \"Lady Arpia\" mentre \u00e8 sul Terreno o nel Cimitero. Puoi scartare questa carta al Cimitero; aggiungi 1 \"Terreno di Caccia delle Arpie\" dal tuo Deck alla tua mano."
    },
    "pt": {
      "name": "Rainha Harpia",
      "effect": "O nome deste card se torna \"Lady Harpia\" enquanto estiver no campo ou no Cemit\u00e9rio. Voc\u00ea pode descartar este card para o Cemit\u00e9rio; adicione 1 \"Terreno de Ca\u00e7a das Harpias\" do seu Deck \u00e0 sua m\u00e3o."
    },
    "es": {
      "name": "Reina Arp\u00eda",
      "effect": "El nombre de esta carta se convierte en \"Dama Arp\u00eda\" mientras est\u00e1 en el Campo o el Cementerio. Puedes descartar esta carta al Cementerio; a\u00f1ade a tu mano 1 \"Territorio de Caza de las Arp\u00edas\" en tu Deck."
    },
    "ja": {
