  "text": {
    "en": {
      "name": "Veil of Darkness",
      "effect": "During your Draw Phase, if you draw a DARK monster(s): You can reveal any number of them; send them to the GY, then you can draw 1 more card."
    },
    "fr": {
      "name": "Voile des T\u00e9n\u00e8bres",
      "effect": "Durant votre Draw Phase, si vous piochez un ou plusieurs monstres T\u00c9N\u00c8BRES : vous pouvez en r\u00e9v\u00e9ler un nombre de votre choix ; envoyez-les au Cimeti\u00e8re, puis vous pouvez piocher 1 carte suppl\u00e9mentaire."
    },
    "de": {
      "name": "Schleier der Finsternis",
      "effect": "W\u00e4hrend deiner Draw Phase, falls du ein oder mehr FINSTERNIS Monster ziehst: Du kannst eine beliebige Anzahl von ihnen vorzeigen; lege sie auf den Friedhof, dann kannst du 1 weitere Karte ziehen."
    },
    "it": {
      "name": "Velo dell'Oscurit\u00e0",
      "effect": "Durante la tua Draw Phase, se peschi uno o pi\u00f9 mostri OSCURIT\u00c0: puoi rivelare un qualsiasi numero di essi; mandali al Cimitero, poi puoi pescare 1 altra carta."
    },
    "pt": {
      "name": "V\u00e9u da Escurid\u00e3o",
      "effect": "Durante sua Fase de Compra, se voc\u00ea comprar um ou mais monstros de TREVAS: voc\u00ea pode revelar qualquer n\u00famero deles; envie-os para o Cemit\u00e9rio e, depois, voc\u00ea pode comprar mais 1 card."
    },
    "es": {
      "name": "Velo de Oscuridad",
      "effect": "Durante tu Draw Phase, si robaste uno o m\u00e1s monstruos de OSCURIDAD: puedes mostrar cualquier n\u00famero de \u00e9stos; m\u00e1ndalos al Cementerio, y despu\u00e9s puedes robar 1 carta m\u00e1s."
    },
