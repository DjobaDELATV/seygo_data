  "text": {
    "en": {
      "name": "Unchained Malevolent Magistrate Kamura",
      "effect": "You can target up to 3 cards you control; destroy them, and if you do, Special Summon this card from your hand, then you can apply any of the following effects, in sequence, based on the original types of the destroyed cards.\n\u25cf Monster: Draw 1 card.\n\u25cf Spell: Change the battle position of 1 monster on the field.\n\u25cf Trap: Destroy 1 other card on the field.\nIf this card on the field is destroyed by card effect: You can destroy all monsters on the field. You can only use each effect of \"Unchained Malevolent Magistrate Kamura\" once per turn.",
      "official": false
    },
    "ja": {
      "name": "\u7834\u68b0\u51a5\u5b98\u30ab\u30e0\u30e9",
