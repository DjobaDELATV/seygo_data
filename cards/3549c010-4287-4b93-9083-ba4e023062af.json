  "text": {
    "en": {
      "name": "Wattcancel",
      "effect": "When your opponent would Normal or Special Summon a monster(s): Discard 1 \"Watt\" monster; negate the Summon, and if you do, destroy that monster(s)."
    },
    "fr": {
      "name": "\u00c9lectro-Annulation",
      "effect": "Lorsque votre adversaire va Invoquer Normalement ou Sp\u00e9cialement un ou plusieurs monstres : d\u00e9faussez 1 monstre \"\u00c9lectro-\" ; annulez l'Invocation, et si vous le faites, d\u00e9truisez ces monstres."
    },
    "de": {
      "name": "Wattabbruch",
      "effect": "Wenn dein Gegner ein oder mehr Monster als Normal- oder Spezialbeschw\u00f6rung beschw\u00f6ren w\u00fcrde: Wirf 1 \u201eWatt\u201c-Monster ab; annulliere die Beschw\u00f6rung und falls du dies tust, zerst\u00f6re jene Monster."
    },
    "it": {
      "name": "Wattannullamento",
      "effect": "Quando il tuo avversario sta per Evocare Normalmente o Specialmente uno o pi\u00f9 mostri: scarta 1 mostro \"Watt\"; annulla l'Evocazione e, se lo fai, distruggi quei mostri."
    },
    "pt": {
      "name": "Wattcancelar",
      "effect": "Quando seu oponente Invocaria um ou mais monstros por Invoca\u00e7\u00e3o-Normal ou Especial: descarte 1 monstro \"Watt\"; negue a Invoca\u00e7\u00e3o e, se isso acontecer, destrua esse(s) monstro(s)."
    },
    "es": {
      "name": "Wattcancelar",
      "effect": "Cuando tu adversario fuera a Invocar uno o m\u00e1s monstruos de Modo Normal o Especial: descarta 1 monstruo \"Watt\"; niega la Invocaci\u00f3n y, si lo haces, destruye ese o esos monstruos."
    },
