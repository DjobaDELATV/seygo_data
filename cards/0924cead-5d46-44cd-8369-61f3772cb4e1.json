  "text": {
    "en": {
      "name": "Revived King Ha Des",
      "effect": "\"Plaguespreader Zombie\" + 1+ non-Tuner Zombie monsters\nNegate the effects of Effect Monsters destroyed by battle with Zombie monsters you control."
    },
    "fr": {
      "name": "Roi Ha D\u00e8s Ressuscit\u00e9",
      "effect": "\"Zombie \u00c9pid\u00e9mique\" + 1+ monstre non-Syntoniseur Zombie\nAnnulez les effets des Monstres \u00e0 Effet d\u00e9truits au combat avec les monstres Zombie que vous contr\u00f4lez."
    },
    "de": {
      "name": "Auferstandener K\u00f6nig Ha Des",
      "effect": "\u201eSeuchenverbreitender Zombie\u201c + 1+ Zombie-Nicht-Empf\u00e4nger-Monster\nAnnulliere die Effekte von Effektmonstern, die durch Kampf mit Zombie-Monstern zerst\u00f6rt werden, die du kontrollierst."
    },
    "it": {
      "name": "Re Ha Des Rinato",
      "effect": "\"Zombie Untore\" + 1+ mostri Zombie non-Tuner\nAnnulla gli effetti dei Mostri con Effetto distrutti in battaglia da mostri Zombie che controlli."
    },
    "pt": {
      "name": "Rei Ha Des Renascido",
      "effect": "\"Zumbi Espalha-praga\" + 1+ monstros Zumbi n\u00e3o-Reguladores\nNegue os efeitos de Monstros de Efeito destru\u00eddos em batalha com monstros Zumbi que voc\u00ea controla."
    },
    "es": {
      "name": "Ha Des Rey Resurrecto",
      "effect": "\"Zombi Esparceplaga\" + 1+ monstruos Zombi que no sean Cantantes\nNiega los efectos de Monstruos de Efecto destruidos en batalla con monstruos Zombi que controles."
    },
    "ja": {
