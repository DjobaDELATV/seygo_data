    "en": {
      "name": "Spell Shattering Arrow",
      "effect": "Destroy as many face-up Spells your opponent controls as possible, and if you do, inflict 500 damage to your opponent for each."
    },
    "fr": {
      "name": "Fl\u00e8che Brise-Sort",
      "effect": "D\u00e9truisez autant de Magies face recto contr\u00f4l\u00e9es par votre adversaire que possible, et si vous le faites, infligez 500 points de dommages \u00e0 votre adversaire pour chacune d'elles."
    },
    "de": {
      "name": "Zauberbrechender Pfeil",
      "effect": "Zerst\u00f6re so viele offene Zauber, die dein Gegner kontrolliert, wie m\u00f6glich und falls du dies tust, f\u00fcge deinem Gegner f\u00fcr jeden 500 Schaden zu."
    },
    "it": {
      "name": "Freccia Spezza-Magia",
      "effect": "Distruggi tante Magie scoperte controllate dal tuo avversario quante possibile e, se lo fai, infliggi 500 danni al tuo avversario per ognuna di esse."
    },
