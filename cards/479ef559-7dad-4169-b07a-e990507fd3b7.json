  "text": {
    "en": {
      "name": "Gem-Knight Tourmaline",
      "effect": "He channels mystic energies and changes them into fighting strength through the power of Tourmaline. Many admire his way of life."
    },
    "fr": {
      "name": "Tourmaline, Chevalier-Gemmes",
      "effect": "Il canalise des \u00e9nergies mystiques et les utilise au combat gr\u00e2ce \u00e0 son pouvoir tourmaline. Il est admir\u00e9 pour sa vision de la vie."
    },
    "de": {
      "name": "Edelstein-Ritter Turmalin",
      "effect": "Er kanalisiert mystische Energien und wandelt sie durch die St\u00e4rke des Turmalins in k\u00e4mpferische St\u00e4rke. Viele bewundern seine Lebensweise."
    },
    "it": {
      "name": "Cavaliere-Gemma Tormalina",
