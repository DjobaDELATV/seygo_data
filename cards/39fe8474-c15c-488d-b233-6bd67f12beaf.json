    "en": {
      "name": "Crystal Raigeki",
      "effect": "Send 1 \"Crystal Beast\" card from your Spell & Trap Zone to the GY, then target 1 card your opponent controls; destroy that target."
    },
    "fr": {
      "name": "Cristal Raigeki",
      "effect": "Envoyez 1 carte \"B\u00eate Cristalline\" depuis votre Zone Magie & Pi\u00e8ge au Cimeti\u00e8re, puis ciblez 1 carte contr\u00f4l\u00e9e par votre adversaire ; d\u00e9truisez la cible."
    },
    "de": {
      "name": "Kristall Raigeki",
      "effect": "Lege 1 \u201eKristallungeheuer\u201c-Karte von deiner Zauber- & Fallenzone auf den Friedhof und w\u00e4hle dann 1 Karte, die dein Gegner kontrolliert; zerst\u00f6re das gew\u00e4hlte Ziel."
    },
    "it": {
