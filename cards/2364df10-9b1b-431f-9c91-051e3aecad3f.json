  "text": {
    "en": {
      "name": "Future Fusion Nova",
      "effect": "When this card is activated: Fusion Summon 1 LIGHT Machine Fusion Monster from your Extra Deck, using monsters from your Deck, including \"Cyber Dragon\", also for the rest of this turn after this card resolves, you cannot Special Summon, except Machine monsters, also you cannot declare attacks, except with the Summoned monster. When this card leaves the field, destroy that monster. When that monster is destroyed, destroy this card. You can only activate 1 \"Future Fusion Nova\" per turn.",
      "official": false
    },
    "ja": {
      "name": "\u672a\u6765\u878d\u5408\uff0d\u30d5\u30e5\u30fc\u30c1\u30e3\u30fc\u30fb\u30d5\u30e5\u30fc\u30b8\u30e7\u30f3\u30fb\u30ce\u30f4\u30a1",
