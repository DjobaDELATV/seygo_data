  "text": {
    "en": {
      "name": "Blazing Inpachi",
      "effect": "A wicked wooden spirit now burning in flames. Its fire attack is powerful, but it will soon be nothing but ashes."
    },
    "fr": {
      "name": "Inpachi Ardent",
      "effect": "Un esprit mal\u00e9fique des bois qui br\u00fble en permanence. Ses attaques de feu sont redoutables, mais il ne sera bient\u00f4t plus qu'un tas de cendres."
    },
    "de": {
      "name": "Flammen-Inpachi",
      "effect": "Ein b\u00f6sartiger h\u00f6lzerner Geist, welcher nun in Flammen steht. Sein Feuerangriff ist stark, aber schon bald wird nichts mehr von ihm \u00fcbrig sein, au\u00dfer Asche."
    },
    "it": {
      "name": "Inpachi Fiammeggiante",
      "effect": "Uno spirito del legno posseduto che adesso brucia tra le fiamme. Il suo attacco di fuoco \u00e8 potente ma presto non ne rimarr\u00e0 che cenere."
    },
    "pt": {
      "name": "Inpachi em Chamas",
      "effect": "Um esp\u00edrito de madeira perverso, agora a arder em chamas. O seu ataque de fogo \u00e9 poderoso, mas em breve ele n\u00e3o ser\u00e1 nada a n\u00e3o ser cinzas."
    },
    "es": {
      "name": "Inpachi Ardiente",
      "effect": "Un esp\u00edritu de madera malvado ahora ardiendo en llamas. Su ataque de fuego es poderoso, pero pronto no ser\u00e1 m\u00e1s que cenizas."
    },
