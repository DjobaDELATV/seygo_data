  "text": {
    "en": {
      "name": "Miracle Fusion",
      "effect": "Fusion Summon 1 \"Elemental HERO\" Fusion Monster from your Extra Deck, by banishing Fusion Materials mentioned on it from your field or GY."
    },
    "fr": {
      "name": "Fusion Miraculeuse",
      "effect": "Invoquez par Fusion 1 Monstre Fusion \"H\u00c9ROS \u00c9l\u00e9mentaire\" depuis votre Extra Deck, en bannissant les Mat\u00e9riels Fusion mentionn\u00e9s sur celui-ci depuis votre Terrain ou Cimeti\u00e8re."
    },
    "de": {
      "name": "Wunderfusion",
      "effect": "Beschw\u00f6re 1 \u201eElementar-HELD\u201c-Fusionsmonster als Fusionsbeschw\u00f6rung von deinem Extra Deck, indem du das auf ihm erw\u00e4hnte Fusionsmaterial von deiner Spielfeldseite oder deinem Friedhof verbannst."
    },
    "it": {
      "name": "Fusione Miracolo",
      "effect": "Evoca tramite Fusione 1 Mostro Fusione \"EROE Elementale\" dal tuo Extra Deck, bandendo i Materiali da Fusione menzionati su di esso dal tuo Terreno o Cimitero."
    },
    "pt": {
      "name": "Fus\u00e3o Miraculosa",
      "effect": "Invoque por Invoca\u00e7\u00e3o-Fus\u00e3o 1 Monstro de Fus\u00e3o \"HER\u00d3I do Elemento\" do seu Deck Adicional, ao banir as Mat\u00e9rias de Fus\u00e3o mencionadas nele do seu campo ou Cemit\u00e9rio."
    },
    "es": {
      "name": "Fusi\u00f3n Milagrosa",
      "effect": "Invoca por Fusi\u00f3n 1 Monstruo de Fusi\u00f3n \"H\u00c9ROE Elemental\" desde tu Deck Extra, desterrando de tu Campo o Cementerio los Materiales de Fusi\u00f3n mencionados en \u00e9l."
    },
