    "ko": {
      "name": "\uc544\uc774:\ud53c \ub9c8\uc2a4\uce74\ub808\ub098",
      "effect": "\ub9c1\ud06c \ubaac\uc2a4\ud130 \uc774\uc678\uc758 \ubaac\uc2a4\ud130 2\uc7a5\n\uc774 \uce74\ub4dc\uba85\uc758 \u2460\uc758 \ud6a8\uacfc\ub294 1\ud134\uc5d0 1\ubc88\ubc16\uc5d0 \uc0ac\uc6a9\ud560 \uc218 \uc5c6\ub2e4. \u2460: \uc0c1\ub300 \uba54\uc778 \ud398\uc774\uc988\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uc774 \uce74\ub4dc\ub97c \ud3ec\ud568\ud558\ub294 \uc790\uc2e0 \ud544\ub4dc\uc758 \ubaac\uc2a4\ud130\ub97c \uc18c\uc7ac\ub85c\uc11c \ub9c1\ud06c \uc18c\ud658\uc744 \uc2e4\ud589\ud55c\ub2e4. \u2461: \uc774 \uce74\ub4dc\ub97c \ub9c1\ud06c \uc18c\uc7ac\ub85c \ud55c \ub9c1\ud06c \ubaac\uc2a4\ud130\ub294 \uc0c1\ub300 \ud6a8\uacfc\ub85c\ub294 \ud30c\uad34\ub418\uc9c0 \uc54a\ub294\ub2e4."
