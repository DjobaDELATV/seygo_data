  "text": {
    "en": {
      "name": "Raidraptor - Nest",
      "effect": "If you control 2 or more \"Raidraptor\" monsters: You can add 1 \"Raidraptor\" monster from your Deck or GY to your hand. You can only use this effect of \"Raidraptor - Nest\" once per turn."
    },
    "fr": {
      "name": "Raidraptor - Nid",
      "effect": "Si vous contr\u00f4lez min. 2 monstres \"Raidraptor\" : vous pouvez ajouter 1 monstre \"Raidraptor\" depuis votre Deck ou Cimeti\u00e8re \u00e0 votre main. Vous ne pouvez utiliser cet effet de \"Raidraptor - Nid\" qu'une fois par tour."
    },
    "de": {
      "name": "\u00dcberfallraptor - Nest",
      "effect": "Falls du 2 oder mehr \u201e\u00dcberfallraptor\u201c-Monster kontrollierst: Du kannst deiner Hand 1 \u201e\u00dcberfallraptor\u201c-Monster von deinem Deck oder Friedhof hinzuf\u00fcgen. Du kannst diesen Effekt von \u201e\u00dcberfallraptor - Nest\u201c nur einmal pro Spielzug verwenden."
    },
    "it": {
