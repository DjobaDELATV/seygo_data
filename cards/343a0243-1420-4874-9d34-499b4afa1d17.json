  "text": {
    "en": {
      "name": "Machine Duplication",
      "effect": "Target 1 Machine monster you control with 500 or less ATK; Special Summon up to 2 monsters from your Deck with the same name as that face-up monster."
    },
    "fr": {
      "name": "Machine de Duplication",
      "effect": "Ciblez 1 monstre Machine que vous contr\u00f4lez avec max. 500 ATK ; Invoquez Sp\u00e9cialement max. 2 monstres du m\u00eame nom que le monstre face recto depuis votre Deck."
    },
    "de": {
      "name": "Maschinenduplizierung",
      "effect": "W\u00e4hle 1 Maschine-Monster mit 500 oder weniger ATK, das du kontrollierst; beschw\u00f6re bis zu 2 Monster mit demselben Namen wie jenes offene Monster als Spezialbeschw\u00f6rung von deinem Deck."
    },
    "it": {
      "name": "Duplicazione di Macchine",
      "effect": "Scegli come bersaglio 1 mostro Macchina che controlli con ATK 500 o inferiore; Evoca Specialmente dal tuo Deck fino a 2 mostri con lo stesso nome di quel mostro scoperto."
    },
