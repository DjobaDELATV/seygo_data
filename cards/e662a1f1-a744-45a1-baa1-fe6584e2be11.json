  "text": {
    "en": {
      "name": "Vampire Baby",
      "effect": "At the end of the Battle Phase, if this card destroyed a monster by battle and sent it to the GY this turn: You can Special Summon that monster to your field."
    },
    "fr": {
      "name": "B\u00e9b\u00e9 Vampire",
      "effect": "\u00c0 la fin de la Battle Phase, si cette carte a d\u00e9truit un monstre au combat et l'a envoy\u00e9 au Cimeti\u00e8re ce tour : vous pouvez Invoquer Sp\u00e9cialement le monstre sur votre Terrain."
    },
    "de": {
