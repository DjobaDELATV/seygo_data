  "text": {
    "en": {
      "name": "Babycerasaurus",
      "effect": "If this card is destroyed by card effect and sent to the GY: Special Summon 1 Level 4 or lower Dinosaur monster from your Deck."
    },
    "fr": {
      "name": "B\u00e9b\u00e9c\u00e9rasaure",
      "effect": "Si cette carte est d\u00e9truite par un effet de carte et envoy\u00e9e au Cimeti\u00e8re : Invoquez Sp\u00e9cialement 1 monstre Dinosaure de max. Niveau 4 depuis votre Deck."
    },
    "de": {
      "name": "Babycerasaurier",
      "effect": "Falls diese Karte durch einen Karteneffekt zerst\u00f6rt und auf den Friedhof gelegt wird: Beschw\u00f6re 1 Dinosaurier-Monster der Stufe 4 oder niedriger als Spezialbeschw\u00f6rung von deinem Deck."
    },
    "it": {
