    },
    "pt": {
      "name": "Bebecerassauro",
      "effect": "Se este card for destru\u00eddo por um efeito de card e enviado para o Cemit\u00e9rio: Invoque por Invoca\u00e7\u00e3o-Especial 1 monstro Dinossauro de N\u00edvel 4 ou menos do seu Deck."
    },
