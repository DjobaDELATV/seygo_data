  "text": {
    "en": {
      "name": "Cursed Seal of the Forbidden Spell",
      "effect": "When a Spell Card is activated: Discard 1 Spell; negate the activation, and if you do, destroy it, and if you do that, your opponent cannot activate Spell Cards with that name for the rest of this Duel."
    },
    "fr": {
      "name": "Sceau Maudit de la Magie Interdite",
      "effect": "Lorsqu'une Carte Magie est activ\u00e9e : d\u00e9faussez 1 Magie ; annulez l'activation, et si vous le faites, d\u00e9truisez-la, et si vous faites \u00e7a, votre adversaire ne peut pas activer des Cartes Magie de ce nom le reste de ce Duel."
    },
    "de": {
      "name": "Verfluchtes Siegel des verbotenen Zaubers",
      "effect": "Wenn eine Zauberkarte aktiviert wird: Wirf 1 Zauber ab; annulliere die Aktivierung und falls du dies tust, zerst\u00f6re sie und falls du dies tust, kann dein Gegner f\u00fcr den Rest dieses Duells keine Zauberkarten mit jenem Namen aktivieren."
    },
    "it": {
      "name": "Sigillo Maledetto della Magia Proibita",
      "effect": "Quando viene attivata una Carta Magia: scarta 1 Magia; annulla l'attivazione e, se lo fai, distruggila e, se fai quello, il tuo avversario non pu\u00f2 attivare Carte Magia con quel nome per il resto di questo Duello."
    },
    "pt": {
      "name": "Selo Amaldi\u00e7oado da Magia Proibida",
      "effect": "Quando um Card de Magia for ativado: descarte 1 Magia; negue a ativa\u00e7\u00e3o e, se isso acontecer, destrua-o e, se isso acontecer, seu oponente n\u00e3o pode ativar Cards de Magia com esse nome pelo resto deste Duelo."
    },
    "es": {
      "name": "Sello Maldito del Hechizo Prohibido",
      "effect": "Cuando es activada una Carta M\u00e1gica: descarta 1 M\u00e1gica; niega la activaci\u00f3n y, si lo haces, destr\u00fayela y, si haces eso, por el resto de este Duelo tu adversario no puede activar Cartas M\u00e1gicas con ese nombre."
    },
