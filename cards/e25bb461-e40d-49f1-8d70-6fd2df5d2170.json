  "text": {
    "en": {
      "name": "Ojama King",
      "effect": "\"Ojama Green\" + \"Ojama Yellow\" + \"Ojama Black\"\nChoose up to 3 of your opponent's unused Monster Zones. Those zones cannot be used."
    },
    "fr": {
      "name": "Ojama Roi",
      "effect": "\"Ojama Vert\" + \"Ojama Jaune\" + \"Ojama Noir\"\nChoisissez max. 3 Zones Monstre inutilis\u00e9es de votre adversaire. Ces zones ne peuvent pas \u00eatre utilis\u00e9es."
    },
    "de": {
      "name": "Ojama-K\u00f6nig",
      "effect": "\u201eGr\u00fcner Ojama\u201c + \u201eGelber Ojama\u201c + \u201eSchwarzer Ojama\u201c\nBestimme bis zu 3 der nicht verwendeten Monsterzonen deines Gegners. Die Zonen k\u00f6nnen nicht verwendet werden."
    },
    "it": {
      "name": "Re Ojama",
      "effect": "\"Ojama Verde\" + \"Ojama Giallo\" + \"Ojama Nero\"\nSeleziona fino a 3 Zone Mostri inutilizzate del tuo avversario. Quelle zone non possono essere utilizzate."
    },
    "pt": {
      "name": "Rei Ojama",
      "effect": "\"Ojama Verde\" + \"Ojama Amarelo\" + \"Ojama Negro\"\nSelecione at\u00e9 3 das Zonas de Monstros n\u00e3o utilizadas do seu oponente. Essas zonas n\u00e3o podem ser usadas."
    },
    "es": {
      "name": "Rey Ojama",
      "effect": "\"Ojama Verde\" + \"Ojama Amarillo\" + \"Ojama Negro\"\nElige hasta 3 Zonas de Monstruos de tu adversario sin usar. Esas zonas no pueden ser usadas."
    },
