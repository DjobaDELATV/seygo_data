    "en": {
      "name": "Froggy Forcefield",
      "effect": "Activate only when a face-up \"Frog\" monster you control, except \"Frog the Jam\", is selected as an attack target. Destroy all Attack Position monsters your opponent controls."
    },
    "fr": {
      "name": "Barri\u00e8re de Force Grenouille",
