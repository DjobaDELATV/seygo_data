  "text": {
    "en": {
      "name": "Magnet Reverse",
      "effect": "Target 1 of your Machine or Rock monsters, that is banished or is in your GY, that cannot be Normal Summoned/Set; Special Summon it."
    },
    "fr": {
      "name": "Retour Magn\u00e9tique",
      "effect": "Ciblez 1 de vos monstres Machine ou Rocher, qui est banni ou dans votre Cimeti\u00e8re, qui ne peut pas \u00eatre Invoqu\u00e9/Pos\u00e9 Normalement ; Invoquez-le Sp\u00e9cialement."
    },
    "de": {
      "name": "Magnetische Umkehr",
      "effect": "W\u00e4hle 1 deiner Maschine- oder Fels-Monster, das verbannt ist oder sich in deinem Friedhof befindet, und nicht als Normalbeschw\u00f6rung beschworen/gesetzt werden kann; beschw\u00f6re es als Spezialbeschw\u00f6rung."
    },
    "it": {
      "name": "Inversione Magnetica",
      "effect": "Scegli come bersaglio 1 dei tuoi mostri Macchina o Roccia che \u00e8 bandito o \u00e8 nel tuo Cimitero, che non pu\u00f2 essere Evocato Normalmente/Posizionato; Evocalo Specialmente."
    },
    "pt": {
      "name": "Reverso do \u00cdm\u00e3",
