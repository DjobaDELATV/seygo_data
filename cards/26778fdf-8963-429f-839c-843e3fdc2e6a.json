{
  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "26778fdf-8963-429f-839c-843e3fdc2e6a",
  "text": {
    "en": {
      "name": "Cyberdark Impact!",
      "effect": "Fusion Summon 1 \"Cyberdark Dragon\" from your Extra Deck, by shuffling 1 each of \"Cyberdark Horn\", \"Cyberdark Edge\", and \"Cyberdark Keel\" from your hand, field, and/or GY, into the Deck, as Fusion Material."
    },
    "fr": {
      "name": "Impact Cybert\u00e9n\u00e9breux !",
      "effect": "Invoquez par Fusion 1 \"Dragon Cybert\u00e9n\u00e9breux\" depuis votre Extra Deck, en m\u00e9langeant 1 \"Corne Cybert\u00e9n\u00e9breuse\", 1 \"Tranchant Cybert\u00e9n\u00e9breux\" et 1 \"Queue Cybert\u00e9n\u00e9breuse\" depuis votre main, Terrain et/ou Cimeti\u00e8re dans le Deck comme Mat\u00e9riel Fusion."
    },
    "de": {
      "name": "Cyberfinsternis Einschlag!",
      "effect": "Beschw\u00f6re 1 \u201eCyberfinsternis Drache\u201c als Fusionsbeschw\u00f6rung von deinem Extra Deck, indem du jeweils 1 \u201eCyberfinsternis Horn\u201c, \u201eCyberfinsternis Zacke\u201c und \u201eCyberfinsternis Knochen\u201c von deiner Hand, deiner Spielfeldseite und/oder deinem Friedhof als Fusionsmaterial ins Deck mischst."
    },
    "it": {
      "name": "Impatto Cyberoscuro!",
      "effect": "Evoca tramite Fusione 1 \"Drago Cyberoscuro\" dal tuo Extra Deck, mischiando nel Deck 1 ciascuno di \"Corno Cyberoscuro\", \"Ali Cyberoscure\" e \"Scheletro Cyberoscuro\" dalla tua mano, Terreno e/o Cimitero come Materiale da Fusione."
    },
    "pt": {
      "name": "Impacto Cibersombrio!",
      "effect": "Invoque por Invoca\u00e7\u00e3o-Fus\u00e3o 1 \"Drag\u00e3o Cibersombrio\" do seu Deck Adicional, ao embaralhar no Deck, como Mat\u00e9ria de Fus\u00e3o, 1 de cada de \"Chifre Cibersombrio\", \"L\u00e2mina Cibersombria\" e \"Enquilha Cibersombria\" da sua m\u00e3o, do campo e/ou do Cemit\u00e9rio."
    },
    "es": {
      "name": "\u00a1Impacto Ciberoscuro!",
      "effect": "Invoca por Fusi\u00f3n, desde tu Deck Extra, 1 \"Drag\u00f3n Ciberoscuro\", barajando al Deck 1 de cada \"Cuerno Ciberoscuro\", \"Filo Ciberoscuro\" y \"Quilla Ciberoscura\" en tu mano, Campo y/o Cementerio, como Material de Fusi\u00f3n."
    },
