  "text": {
    "en": {
      "name": "Junk Warrior",
      "effect": "\"Junk Synchron\" + 1+ non-Tuner monsters\nIf this card is Synchro Summoned: It gains ATK equal to the total ATK of all Level 2 or lower monsters you currently control."
    },
    "fr": {
      "name": "Robot Guerrier",
      "effect": "\"Robot Synchronique\" + 1+ monstre non-Syntoniseur\nSi cette carte est Invoqu\u00e9e par Synchronisation : elle gagne une ATK \u00e9gale \u00e0 la somme des ATK de tous les monstres de max. Niveau 2 que vous contr\u00f4lez actuellement."
    },
    "de": {
      "name": "Ger\u00fcmpelkrieger",
      "effect": "\u201eGer\u00fcmpelsynchronisierer\u201c + 1+ Nicht-Empf\u00e4nger-Monster\nFalls diese Karte als Synchrobeschw\u00f6rung beschworen wird: Sie erh\u00e4lt ATK in H\u00f6he der Summe der ATK aller Monster der Stufe 2 oder niedriger, die du derzeit kontrollierst."
    },
    "it": {
      "name": "Guerriero Rottame",
      "effect": "\"Rottame Synchron\" + 1+ mostri non-Tuner\nSe questa carta viene Synchro Evocata: essa guadagna ATK pari alla somma degli ATK di tutti i mostri di Livello 2 o inferiore che controlli attualmente."
    },
    "pt": {
      "name": "Guerreiro Sucata",
      "effect": "\"Sucata Sincron\" + 1+ monstros n\u00e3o-Reguladores\nSe este card for Invocado por Invoca\u00e7\u00e3o-Sincro: ele ganha ATK igual ao ATK total de todos os monstros de N\u00edvel 2 ou menos que voc\u00ea controla atualmente."
    },
    "es": {
      "name": "Guerrero de Basura",
      "effect": "\"Sincronizador de Basura\" + 1+ monstruos que no sean Cantantes\nSi esta carta es Invocada por Sincron\u00eda: \u00e9sta gana ATK igual al ATK total de todos los monstruos de Nivel 2 o menor que controles en este momento."
    },
    "ja": {
      "name": "\u30b8\u30e3\u30f3\u30af\u30fb\u30a6\u30a9\u30ea\u30a2\u30fc",
      "effect": "\u300c\u30b8\u30e3\u30f3\u30af\u30fb\u30b7\u30f3\u30af\u30ed\u30f3\u300d\uff0b\u30c1\u30e5\u30fc\u30ca\u30fc\u4ee5\u5916\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u4ee5\u4e0a\n\u2460\uff1a\u3053\u306e\u30ab\u30fc\u30c9\u304c\uff33\u53ec\u559a\u3057\u305f\u5834\u5408\u306b\u767a\u52d5\u3059\u308b\u3002\u3053\u306e\u30ab\u30fc\u30c9\u306e\u653b\u6483\u529b\u306f\u3001\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\u30ec\u30d9\u30eb\uff12\u4ee5\u4e0b\u306e\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\u653b\u6483\u529b\u306e\u5408\u8a08\u5206\u30a2\u30c3\u30d7\u3059\u308b\u3002"
    },
    "ko": {
      "name": "\uc815\ud06c \uc6cc\ub9ac\uc5b4",
