{
  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "5b9e802b-6c1a-452b-9935-2194cfc80fa2",
  "text": {
    "en": {
      "name": "Called by the Grave",
      "effect": "Target 1 monster in your opponent's GY; banish it, and if you do, until the end of the next turn, its effects are negated, as well as the activated effects and effects on the field of monsters with the same original name."
    },
    "fr": {
      "name": "Appel\u00e9 par la Tombe",
      "effect": "Ciblez 1 monstre dans le Cimeti\u00e8re de votre adversaire ; bannissez-le, et si vous le faites, jusqu'\u00e0 la fin du prochain tour, ses effets sont annul\u00e9s, ainsi que les effets activ\u00e9s et les effets sur le Terrain de monstres du m\u00eame nom d'origine."
    },
    "de": {
      "name": "Vom Grab gerufen",
      "effect": "W\u00e4hle 1 Monster im Friedhof deines Gegners; verbanne es und falls du dies tust, werden seine Effekte sowie die aktivierten Effekte und Effekte auf dem Spielfeld von Monstern mit demselben Grund-Namen bis zum Ende des n\u00e4chsten Spielzugs annulliert."
    },
    "it": {
      "name": "Richiamato dalla Tomba",
      "effect": "Scegli come bersaglio 1 mostro nel Cimitero del tuo avversario; bandiscilo e, se lo fai, fino alla fine del prossimo turno, i suoi effetti sono annullati, cos\u00ec come gli effetti attivati e gli effetti sul Terreno dei mostri con lo stesso nome originale."
    },
    "pt": {
      "name": "Chamado da Cova",
      "effect": "Escolha 1 monstro no Cemit\u00e9rio do seu oponente; bana-o e, se isso acontecer, at\u00e9 o final do pr\u00f3ximo turno, seus efeitos s\u00e3o negados, assim como os efeitos ativados e efeitos no campo de monstros com o mesmo nome original."
    },
    "es": {
      "name": "Llamado por la Tumba",
      "effect": "Selecciona 1 monstruo en el Cementerio de tu adversario; desti\u00e9rralo y, si lo haces, hasta el final del pr\u00f3ximo turno sus efectos son negados, as\u00ed como los efectos activados y los efectos en el Campo de monstruos con el mismo nombre original."
    },
    "ja": {
      "name": "\u5893\u7a74\u306e\u6307\u540d\u8005",
