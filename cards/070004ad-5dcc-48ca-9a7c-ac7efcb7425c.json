  "text": {
    "en": {
      "name": "Robbin' Goblin",
      "effect": "Each time a monster you control inflicts Battle Damage to your opponent, your opponent discards 1 random card."
    },
    "fr": {
      "name": "Gobelin de Robbin",
      "effect": "Chaque fois qu'un monstre que vous contr\u00f4lez inflige des dommages de combat \u00e0 votre adversaire, votre adversaire d\u00e9fausse 1 carte au hasard."
    },
    "de": {
      "name": "Raubender Goblin",
      "effect": "Jedes Mal, wenn ein Monster, das du kontrollierst, deinem Gegner Kampfschaden zuf\u00fcgt, wirft dein Gegner 1 zuf\u00e4llige Karte ab."
    },
    "it": {
      "name": "Goblin Ladro",
      "effect": "Ogni volta che 1 mostro che controlli infligge danno da combattimento al tuo avversario, il tuo avversario scarta 1 carta a caso."
    },
    "pt": {
      "name": "Goblin Lar\u00e1pio",
