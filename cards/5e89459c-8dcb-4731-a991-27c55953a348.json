    "ko": {
      "name": "\uac00\uac00\uac00 \uac78",
      "effect": "\u2460: \uc790\uc2e0 \ud544\ub4dc\uc758 \"\uac00\uac00\uac00 \ub9e4\uc9c0\uc158\" 1\uc7a5\uc744 \ub300\uc0c1\uc73c\ub85c \ud558\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uc774 \uce74\ub4dc\uc758 \ub808\ubca8\uc740 \uadf8 \ubaac\uc2a4\ud130\uc640 \uac19\uc544\uc9c4\ub2e4. \u2461: \uc774 \uce74\ub4dc\ub97c \ud3ec\ud568\ud558\ub294 \"\uac00\uac00\uac00\" \ubaac\uc2a4\ud130\ub9cc\uc744 \uc18c\uc7ac\ub85c\uc11c \uc5d1\uc2dc\uc988 \uc18c\ud658\ud55c \ubaac\uc2a4\ud130\ub294 \uc774\ud558\uc758 \ud6a8\uacfc\ub97c \uc5bb\ub294\ub2e4. \u25cf\uc774 \uc5d1\uc2dc\uc988 \uc18c\ud658\uc5d0 \uc131\uacf5\ud588\uc744 \ub54c, \uc0c1\ub300 \ud544\ub4dc\uc758 \ud2b9\uc218 \uc18c\ud658\ub41c \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ub300\uc0c1\uc73c\ub85c \ud558\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uadf8 \ubaac\uc2a4\ud130\uc758 \uacf5\uaca9\ub825\uc744 0 \uc73c\ub85c \ud55c\ub2e4."
    },
    "zh-CN": {
