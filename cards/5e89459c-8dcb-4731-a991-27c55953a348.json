      "effect": "\u2460\uff1a\u4ee5\u81ea\u5df1\u573a\u4e0a\u76841\u53ea\u201c\u6211\u6211\u6211\u9b54\u672f\u5e08\u201d\u4e3a\u5bf9\u8c61\u53ef\u4ee5\u53d1\u52a8\u3002\u6b64\u5361\u7684\u7b49\u7ea7\u53d8\u4e3a\u4e0e\u8be5\u602a\u517d\u76f8\u540c\u3002\u2461\uff1a\u4ee5\u5305\u542b\u6b64\u5361\u5728\u5185\u7684\u3001\u4e14\u4ec5\u4ee5\u573a\u4e0a\u7684\u201c\u6211\u6211\u6211\u201d\u602a\u517d\u4f5c\u4e3a\u7d20\u6750\u8d85\u91cf\u53ec\u5524\u7684\u602a\u517d\u83b7\u5f97\u4ee5\u4e0b\u6548\u679c\u3002\n\u25cf\u6b64\u5361\u8d85\u91cf\u53ec\u5524\u65f6\uff0c\u4ee5\u5bf9\u624b\u573a\u4e0a\u76841\u53ea\u88ab\u7279\u6b8a\u53ec\u5524\u7684\u602a\u517d\u4e3a\u5bf9\u8c61\u53ef\u4ee5\u53d1\u52a8\u3002\u5c06\u8be5\u602a\u517d\u7684\u653b\u51fb\u529b\u6539\u62100\u3002"
