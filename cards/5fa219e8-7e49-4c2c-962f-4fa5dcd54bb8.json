  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "5fa219e8-7e49-4c2c-962f-4fa5dcd54bb8",
  "text": {
    "en": {
      "name": "Mind Control",
      "effect": "Target 1 monster your opponent controls; until the End Phase, take control of that target, but it cannot declare an attack or be Tributed."
    },
    "fr": {
      "name": "Contr\u00f4le Mental",
      "effect": "Ciblez 1 monstre contr\u00f4l\u00e9 par votre adversaire ; jusqu'\u00e0 la End Phase, prenez le contr\u00f4le de la cible, mais elle ne peut ni d\u00e9clarer d'attaque ni \u00eatre Sacrifi\u00e9e."
    },
    "de": {
      "name": "Gedankenkontrolle",
      "effect": "W\u00e4hle 1 Monster, das dein Gegner kontrolliert; bis zur End Phase, \u00fcbernimm die Kontrolle \u00fcber jenes gew\u00e4hlte Ziel, aber es kann weder einen Angriff deklarieren noch als Tribut angeboten werden."
    },
    "it": {
      "name": "Controlla Mente",
      "effect": "Scegli come bersaglio 1 mostro controllato dal tuo avversario; fino alla End Phase, prendi il controllo di quel bersaglio, ma esso non pu\u00f2 dichiarare un attacco o essere offerto come Tributo."
    },
    "pt": {
      "name": "Controle Mental",
      "effect": "Escolha 1 monstro que seu oponente controla; at\u00e9 a Fase Final, tome o controle do alvo, mas ele n\u00e3o pode declarar um ataque nem ser oferecido como Tributo."
    },
    "es": {
      "name": "Control de la Mente",
      "effect": "Selecciona 1 monstruo que controle tu adversario; hasta la End Phase, toma el control de ese objetivo, pero \u00e9ste no puede declarar un ataque o ser Sacrificado."
    },
    "ja": {
      "name": "\u7cbe\u795e\u64cd\u4f5c",
