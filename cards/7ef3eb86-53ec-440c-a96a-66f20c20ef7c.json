  "text": {
    "en": {
      "name": "Kuriboh",
      "effect": "During damage calculation, if your opponent's monster attacks (Quick Effect): You can discard this card; you take no battle damage from that battle."
    },
    "fr": {
      "name": "Kuriboh",
      "effect": "Durant le calcul des dommages, si un monstre de votre adversaire attaque (Effet Rapide) : vous pouvez d\u00e9fausser cette carte ; vous ne recevez aucun dommage de combat de ce combat."
    },
    "de": {
      "name": "Kuriboh",
      "effect": "W\u00e4hrend der Schadensberechnung, falls ein Monster deines Gegners angreift (Schnelleffekt): Du kannst diese Karte abwerfen; du erh\u00e4ltst aus dem Kampf keinen Kampfschaden."
    },
    "it": {
