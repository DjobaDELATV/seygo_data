  "text": {
    "en": {
      "name": "Fusion Recovery",
      "effect": "Target 1 \"Polymerization\" in your GY, and 1 monster in your GY that was used as material for a Fusion Summon; add them to your hand."
    },
    "fr": {
      "name": "R\u00e9cup\u00e9ration de Fusion",
      "effect": "Ciblez 1 \"Polym\u00e9risation\" dans votre Cimeti\u00e8re, et 1 monstre dans votre Cimeti\u00e8re qui a \u00e9t\u00e9 utilis\u00e9 comme Mat\u00e9riel pour une Invocation Fusion ; ajoutez-les \u00e0 votre main."
    },
    "de": {
      "name": "Fusionsr\u00fcckerstattung",
      "effect": "W\u00e4hle 1 \u201ePolymerisation\u201c in deinem Friedhof und 1 Monster in deinem Friedhof, das als Material f\u00fcr eine Fusionsbeschw\u00f6rung verwendet wurde; f\u00fcge sie deiner Hand hinzu."
    },
    "it": {
