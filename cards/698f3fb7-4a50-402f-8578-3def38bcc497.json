  "text": {
    "en": {
      "name": "Shattered Axe",
      "effect": "Activate this card by targeting 1 face-up monster on the field. During each of your Standby Phases: It loses 500 ATK. When that target is destroyed, destroy this card."
    },
    "fr": {
      "name": "Hache Bris\u00e9e",
      "effect": "Activez cette carte en ciblant 1 monstre face recto sur le Terrain. Durant chacune de vos Standby Phases : il perd 500 ATK. Lorsque la cible est d\u00e9truite, d\u00e9truisez cette carte."
    },
    "de": {
      "name": "Zerbrochene Axt",
      "effect": "Aktiviere diese Karte, indem du 1 offenes Monster auf dem Spielfeld w\u00e4hlst. W\u00e4hrend jeder deiner Standby Phasen: Es verliert 500 ATK. Wenn das gew\u00e4hlte Ziel zerst\u00f6rt wird, zerst\u00f6re diese Karte."
    },
    "it": {
      "name": "Ascia Frantumata",
      "effect": "Attiva questa carta scegliendo come bersaglio 1 mostro scoperto sul Terreno. Durante ogni tua Standby Phase: esso perde 500 ATK. Quando quel bersaglio viene distrutto, distruggi questa carta."
    },
    "pt": {
      "name": "Machado Despeda\u00e7ado",
      "effect": "Ative este card ao escolher 1 monstro com a face para cima no campo. Durante cada uma das suas Fases de Apoio: ele perde 500 de ATK. Quando o alvo for destru\u00eddo, destrua este card."
    },
    "es": {
      "name": "Hacha Destrozada",
      "effect": "Activa esta carta seleccionando 1 monstruo boca arriba en el Campo. Durante cada una de tus Standby Phases: \u00e9ste pierde 500 ATK. Cuando ese objetivo es destruido, destruye esta carta."
    },
