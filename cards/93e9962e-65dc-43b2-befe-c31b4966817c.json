  "text": {
    "en": {
      "name": "Typhoon",
      "effect": "Target 1 face-up Spell/Trap on the field; destroy it. If your opponent controls 2 or more Spells/Traps and you control no Spells/Traps, you can activate this card from your hand."
    },
    "fr": {
      "name": "Typhon",
      "effect": "Ciblez 1 Magie/Pi\u00e8ge face recto sur le Terrain ; d\u00e9truisez-le. Si votre adversaire contr\u00f4le min. 2 Magies/Pi\u00e8ges et que vous ne contr\u00f4lez aucune Magie/Pi\u00e8ge, vous pouvez activer cette carte depuis votre main."
    },
    "de": {
      "name": "Taifun",
      "effect": "W\u00e4hle 1 offene/n Zauber/Falle auf dem Spielfeld; zerst\u00f6re ihn oder sie. Falls dein Gegner 2 oder mehr Zauber/Fallen kontrolliert und du keine Zauber/Fallen kontrollierst, kannst du diese Karte von deiner Hand aktivieren."
    },
    "it": {
