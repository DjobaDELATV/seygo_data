  "text": {
    "en": {
      "name": "Bark of Dark Ruler",
      "effect": "If a Fiend monster you control battles, during the Damage Step: Pay LP in multiples of 100, then target the opponent's battling monster; that opponent's monster loses that much ATK and DEF, until the end of this turn."
    },
    "fr": {
      "name": "Le Rugissement du Gouverneur des T\u00e9n\u00e8bres",
      "effect": "Si un monstre D\u00e9mon que vous contr\u00f4lez combat, durant la Damage Step : payez des LP en multiples de 100, puis ciblez le monstre combattant de l'adversaire ; jusqu'\u00e0 la fin de ce tour, le monstre de l'adversaire perd autant d'ATK/DEF."
    },
    "de": {
      "name": "Gebell des Dunklen Herrschers",
      "effect": "Falls ein Unterweltler-Monster k\u00e4mpft, das du kontrollierst, w\u00e4hrend des Damage Steps: Zahle LP in Vielfachen von 100 und w\u00e4hle dann das k\u00e4mpfende Monster des Gegners; jenes Monster des Gegners verliert bis zum Ende dieses Spielzugs so viele ATK und DEF."
    },
    "it": {
      "name": "Latrato del Sovrano Oscuro",
      "effect": "Se un mostro Demone che controlli combatte, durante il Damage Step: paga LP in multipli di 100, poi scegli come bersaglio il mostro dell'avversario che sta combattendo; quel mostro dell'avversario perde quell'ammontare di ATK e DEF, fino alla fine di questo turno."
    },
    "pt": {
      "name": "Rugido do Governante Sombrio",
      "effect": "Se um monstro Dem\u00f4nio que voc\u00ea controla batalhar, durante a Etapa de Dano: pague PV em m\u00faltiplos de 100 e, depois, escolha o monstro que estava batalhando do oponente; at\u00e9 o final deste turno, esse monstro do oponente perde esse valor de ATK e DEF."
    },
    "es": {
      "name": "Ladrido del Gobernante Oscuro",
      "effect": "Si un monstruo Demonio que controlas batalla, durante el Damage Step: paga LP en m\u00faltiplos de 100, y despu\u00e9s selecciona el monstruo batallante del adversario; hasta el final de este turno, ese monstruo del adversario pierde esa misma cantidad de ATK y DEF."
    },
