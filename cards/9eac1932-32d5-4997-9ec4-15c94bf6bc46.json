  "text": {
    "en": {
      "name": "Red Dragon Archfiend's Chain",
      "effect": "You can activate this card the turn it was Set, by revealing 1 \"Red Dragon Archfiend\" in your Extra Deck. Activate this card by revealing any number of monsters in your hand, then target Effect Monsters your opponent controls equal to the number of Tuners revealed +1; they lose 100 ATK for each card you revealed in the hand to activate this card, also their effects are negated. If the last of those monsters is not on the field, destroy this card. You can only activate 1 \"Red Dragon Archfiend's Chain\" per turn.",
      "official": false
    },
