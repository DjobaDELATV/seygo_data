  "text": {
    "en": {
      "name": "Dark Blade",
      "effect": "They say he is a dragon-manipulating warrior from the dark world. His attack is tremendous, using his great swords with vicious power."
    },
    "fr": {
      "name": "Sombrelame",
      "effect": "On dit de lui que c'est un guerrier du monde des t\u00e9n\u00e8bres qui manipule les dragons. Son attaque est terrible, utilisant ses \u00e9p\u00e9es gigantesques avec une puissance haineuse."
    },
    "de": {
      "name": "Dunkelklinge",
      "effect": "Man sagt, er sei ein Krieger aus der Dunklen Welt und k\u00f6nne Drachen manipulieren. Seine Kampfkraft ist gewaltig und er schwingt seine gro\u00dfen Schwerter mit f\u00fcrchterlicher Wucht."
    },
    "it": {
      "name": "Lama Oscura",
      "effect": "Si dice sia un guerriero proveniente dal Mondo Oscuro, in grado di dominare i draghi. Il suo attacco \u00e8 tremendo, utilizza le sue gigantesche spade in modo diabolico."
    },
    "pt": {
      "name": "L\u00e2mina Sombria",
      "effect": "Dizem que ele \u00e9 um guerreiro manipulador de drag\u00f5es do mundo sombrio. O seu ataque \u00e9 tremendo, usando as suas grandes espadas com poder malicioso."
    },
    "es": {
      "name": "Hoja Oscura",
      "effect": "Dicen que es un guerrero del mundo oscuro que manipula dragones. Su ataque es tremendo, usando sus grandes espadas con malvado poder."
    },
