  "text": {
    "en": {
      "name": "Ally of Justice Clausolas",
      "effect": "A mighty monster in Mist Valley, and the ultimate weapon designed from Claiomh Solais. Its surprise attacks from above baffle invaders."
    },
    "fr": {
      "name": "Cla\u00edomh Solais, Alli\u00e9 de la Justice",
      "effect": "L'arme ultime con\u00e7ue d'apr\u00e8s Cla\u00edomh Solais, le l\u00e9gendaire monstre de la Vall\u00e9e des Brumes. Ses attaques a\u00e9riennes surprises affolent les envahisseurs."
    },
    "de": {
      "name": "Verb\u00fcndeter der Gerechtigkeit Clausolas",
      "effect": "Ein m\u00e4chtiges Monster im Nebeltal und die ultimative Waffe, die von Claiomh Solais erschaffen wurde. Seine \u00dcberraschungsangriffe aus luftiger H\u00f6he verbl\u00fcffen alle Eindringlinge."
    },
    "it": {
      "name": "Clausolas Alleato della Giustizia",
      "effect": "Mostro poderoso della Valle delle Nebbie, e arma definitiva progettata da Claiomh Solais. I suoi attacchi a sorpresa dall'alto sorprendono gli invasori."
    },
    "pt": {
      "name": "Clausolas, Aliado da Justi\u00e7a",
      "effect": "Um monstro poderoso do Vale das N\u00e9voas, e a arma definitiva criada a partir de Claiomh Solais. Seus ataques surpresa vindos das alturas confundem os invasores."
    },
    "es": {
      "name": "Clausolas, Aliado de la Justicia",
      "effect": "Un monstruo poderoso en el Valle Brumoso, y el arma m\u00e1s avanzada dise\u00f1ada a partir de Claiohm Solais. Sus ataques sorpresa desde lo alto desconciertan a los invasores."
    },
