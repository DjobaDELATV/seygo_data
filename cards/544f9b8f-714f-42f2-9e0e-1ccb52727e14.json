  "text": {
    "en": {
      "name": "Barrel Dragon",
      "effect": "Once per turn: You can target 1 monster your opponent controls; toss a coin 3 times and destroy it if at least 2 of the results are heads."
    },
    "fr": {
      "name": "Revolver Dragon",
      "effect": "Une fois par tour : vous pouvez cibler 1 monstre contr\u00f4l\u00e9 par votre adversaire ; lancez une pi\u00e8ce 3 fois et d\u00e9truisez-le si min. 2 des r\u00e9sultats sont face."
    },
    "de": {
      "name": "Pistolendrache",
      "effect": "Einmal pro Spielzug: Du kannst 1 Monster w\u00e4hlen, das dein Gegner kontrolliert; wirf 3-mal eine M\u00fcnze und zerst\u00f6re es, falls mindestens 2 der Ergebnisse Kopf sind."
    },
    "it": {
      "name": "Drago Revolver",
      "effect": "Una volta per turno: puoi scegliere come bersaglio 1 mostro controllato dal tuo avversario; lancia una moneta 3 volte e distruggilo se almeno 2 dei risultati sono testa."
    },
