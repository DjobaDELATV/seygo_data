    },
    "ko": {
      "name": "\uc18c\ud658\uc218 \ub77c\uc774\ub518",
      "effect": "\"\uc18c\ud658\uc0ac \uc54c\ub808\uc774\uc2a4\ud130\" \uff0b \ubc14\ub78c \uc18d\uc131 \ubaac\uc2a4\ud130\n\u2460: 1\ud134\uc5d0 1\ubc88, \ud544\ub4dc\uc758 \uc55e\uba74 \ud45c\uc2dc \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ub300\uc0c1\uc73c\ub85c \ud558\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uadf8 \ubaac\uc2a4\ud130\ub97c \ub4b7\uba74 \uc218\ube44 \ud45c\uc2dc\ub85c \ud55c\ub2e4. \uc774 \ud6a8\uacfc\ub294 \uc0c1\ub300 \ud134\uc5d0\ub3c4 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4."
    },
    "zh-CN": {
