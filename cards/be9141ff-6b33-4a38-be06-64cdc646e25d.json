  "text": {
    "en": {
      "name": "Invoked Raidjin",
      "effect": "\"Aleister the Invoker\" + 1 WIND monster\nOnce per turn (Quick Effect): You can target 1 face-up monster on the field; change it to face-down Defense Position."
    },
    "fr": {
      "name": "Raidjin l'Invokh\u00e9",
      "effect": "\"Aleister l'Invokhateur\" + 1 monstre VENT\nUne fois par tour (Effet Rapide) : vous pouvez cibler 1 monstre face recto sur le Terrain ; changez-le en Position de D\u00e9fense face verso."
    },
    "de": {
      "name": "Beschworener Raidjin",
      "effect": "\u201eAleister der Beschw\u00f6rer\u201c + 1 WIND Monster\nEinmal pro Spielzug (Schnelleffekt): Du kannst 1 offenes Monster auf dem Spielfeld w\u00e4hlen; \u00e4ndere es in die verdeckte Verteidigungsposition."
    },
    "it": {
      "name": "Raidjin Invokato",
      "effect": "\"Aleister l'Invocatore\" + 1 mostro VENTO\nUna volta per turno (Effetto Rapido): puoi scegliere come bersaglio 1 mostro scoperto sul Terreno; mettilo coperto in Posizione di Difesa."
    },
    "pt": {
      "name": "Raidjin, o Invokado",
      "effect": "\"Aleister, Aquele que Invoka\" + 1 monstro de VENTO\nUma vez por turno (Efeito R\u00e1pido): voc\u00ea pode escolher 1 monstro com a face para cima no campo; coloque-o com a face para baixo em Posi\u00e7\u00e3o de Defesa."
    },
    "es": {
      "name": "Raidjin Invokado",
      "effect": "\"Aleister, el que Invoka\" + 1 monstruo de VIENTO\nUna vez por turno (Efecto R\u00e1pido): puedes seleccionar 1 monstruo boca arriba en el Campo; c\u00e1mbialo a Posici\u00f3n de Defensa boca abajo."
    },
    "ja": {
