    "en": {
      "name": "Turret Warrior",
      "effect": "You can Special Summon this card (from your hand) by Tributing 1 Warrior-Type monster, and if you do, it gains ATK equal to the Tributed monster's original ATK."
    },
    "fr": {
      "name": "Guerrier Tourelle",
