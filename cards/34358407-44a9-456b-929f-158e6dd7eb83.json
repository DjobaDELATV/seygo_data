  "text": {
    "en": {
      "name": "The Phantom Knights of Malevolent Scythe",
      "effect": "2 Level 3 DARK monsters\nYou can detach 1 material from this card; Special Summon 1 \"The Phantom Knights\" monster from your Deck. If you Xyz Summon an \"Xyz Dragon\" monster while this card is in the Monster Zone (except during the Damage Step): You can add 1 \"Rank-Up-Magic\" Spell from your Deck to your hand. If this card is destroyed: You can add 1 of your banished \"The Phantom Knights\" cards to your hand, except an Xyz Monster. You can only use each effect of \"The Phantom Knights of Malevolent Scythe\" once per turn.",
      "official": false
    },
    "ja": {
      "name": "\u5e7b\u5f71\u9a0e\u58eb\u56e3\u30de\u30ec\u30f4\u30a9\u30ec\u30f3\u30b9\u30b5\u30a4\u30b9",
