  "id": "c4153d67-cdc1-4829-b151-fcb0aeb0d2eb",
  "text": {
    "en": {
      "name": "Allure of Darkness",
      "effect": "Draw 2 cards, then banish 1 DARK monster from your hand, or, if you do not have any in your hand, send your entire hand to the GY."
    },
    "fr": {
      "name": "Invitation des T\u00e9n\u00e8bres",
      "effect": "Piochez 2 cartes, puis bannissez 1 monstre T\u00c9N\u00c8BRES depuis votre main, ou, si vous n'en avez aucun dans votre main, envoyez toute votre main au Cimeti\u00e8re."
    },
    "de": {
      "name": "Verlockung der Finsternis",
      "effect": "Ziehe 2 Karten, dann verbanne 1 FINSTERNIS Monster von deiner Hand oder, falls du keins in deiner Hand hast, lege deine gesamte Hand auf den Friedhof."
    },
    "it": {
      "name": "Fascino dell'Oscurit\u00e0",
      "effect": "Pesca 2 carte, poi bandisci 1 mostro OSCURIT\u00c0 dalla tua mano, o, se non ne hai nessuno nella tua mano, manda tutta la tua mano al Cimitero."
    },
    "pt": {
      "name": "Fascina\u00e7\u00e3o das Trevas",
      "effect": "Compre 2 cards e, depois, bana 1 monstro de TREVAS da sua m\u00e3o ou, se voc\u00ea n\u00e3o tiver nenhum na sua m\u00e3o, envie toda a sua m\u00e3o para o Cemit\u00e9rio."
    },
    "es": {
      "name": "Atractivo de la Oscuridad",
      "effect": "Roba 2 cartas, y despu\u00e9s destierra 1 monstruo de OSCURIDAD en tu mano o, si no tienes ninguno en tu mano, manda al Cementerio toda tu mano."
    },
    "ja": {
      "name": "\u95c7\u306e\u8a98\u60d1",
      "effect": "\u2460\uff1a\u81ea\u5206\u306f\uff12\u679a\u30c9\u30ed\u30fc\u3059\u308b\u3002\u305d\u306e\u5f8c\u3001\u624b\u672d\u306b\u95c7\u5c5e\u6027\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\u5b58\u5728\u3059\u308b\u5834\u5408\u3001\u305d\u306e\u5185\u306e\uff11\u4f53\u3092\u9078\u3093\u3067\u9664\u5916\u3059\u308b\u3002\u5b58\u5728\u3057\u306a\u3044\u5834\u5408\u3001\u81ea\u5206\u306e\u624b\u672d\u3092\u5168\u3066\u5893\u5730\u3078\u9001\u308b\u3002"
    },
    "ko": {
      "name": "\uc5b4\ub460\uc758 \uc720\ud639",
      "effect": "\u2460: \uc790\uc2e0\uc740 2\uc7a5 \ub4dc\ub85c\uc6b0\ud55c\ub2e4. \uadf8 \ud6c4, \ud328\uc5d0 \uc5b4\ub460 \uc18d\uc131 \ubaac\uc2a4\ud130\uac00 \uc874\uc7ac\ud560 \uacbd\uc6b0, \uadf8 \uc911\uc758 1\uc7a5\uc744 \uace0\ub974\uace0 \uc81c\uc678\ud55c\ub2e4. \uc874\uc7ac\ud558\uc9c0 \uc54a\uc744 \uacbd\uc6b0, \uc790\uc2e0\uc758 \ud328\ub97c \uc804\ubd80 \ubb18\uc9c0\ub85c \ubcf4\ub0b8\ub2e4."
    },
    "zh-TW": {
