  "text": {
    "en": {
      "name": "Black Chaos the Ultimate Magical Swordsman",
      "effect": "Cannot be Normal Summoned/Set. Must be Special Summoned (from your hand) by shuffling 1 Ritual Monster (Spellcaster or Warrior) from your hand or GY into the Deck. You can only Special Summon \"Black Chaos the Ultimate Magical Swordsman\" once per turn this way. You can discard this card; place 1 Continuous Trap that mentions \"Light and Darkness Ritual\" from your Deck or GY, face-up on your field. Unaffected by your opponent's activated effects while you have a Ritual Spell in your GY. Once per turn: You can banish 2 cards your opponent controls.",
      "official": false
    },
    "ja": {
      "name": "\u8d85\u9b54\u5263\u58eb\u30d6\u30e9\u30c3\u30af\u30fb\u30ab\u30aa\u30b9",
