  "text": {
    "en": {
      "name": "Offerings to the Doomed",
      "effect": "Target 1 face-up monster on the field; destroy that target, also skip your next Draw Phase."
    },
    "fr": {
      "name": "Offrande aux Damn\u00e9s",
      "effect": "Ciblez 1 monstre face recto sur le Terrain ; d\u00e9truisez la cible, et aussi, sautez votre prochaine Draw Phase."
    },
    "de": {
      "name": "Angebote an die Verdammten",
      "effect": "W\u00e4hle 1 offenes Monster auf dem Spielfeld; zerst\u00f6re das gew\u00e4hlte Ziel, zus\u00e4tzlich \u00fcberspringe deine n\u00e4chste Draw Phase."
    },
    "it": {
      "name": "Offerte al Condannato",
      "effect": "Scegli come bersaglio 1 mostro scoperto sul Terreno; distruggi quel bersaglio, inoltre salta la tua prossima Draw Phase."
    },
    "pt": {
      "name": "Oferenda dos Condenados",
      "effect": "Escolha 1 monstro com a face para cima no campo; destrua o alvo e, al\u00e9m disso, pule sua pr\u00f3xima Fase de Compra."
    },
    "es": {
      "name": "Ofrendas a los Condenados",
      "effect": "Selecciona 1 monstruo boca arriba en el Campo; destruye ese objetivo, y adem\u00e1s s\u00e1ltate tu pr\u00f3xima Draw Phase."
    },
