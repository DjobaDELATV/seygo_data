  "text": {
    "en": {
      "name": "Illusion Magic",
      "effect": "Tribute 1 Spellcaster monster; add up to 2 copies of \"Dark Magician\" from your Deck and/or GY to your hand. You can only activate 1 \"Illusion Magic\" per turn."
    },
