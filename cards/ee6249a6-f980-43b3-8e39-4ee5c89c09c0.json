      "effect": "\u4ee5\u9ad8\u653b\u64ca\u529b\u8457\u7a31\u7684\u50b3\u8aaa\u4e4b\u9f8d\u3002\u4efb\u4f55\u5c0d\u624b\u90fd\u80fd\u5920\u7c89\u788e\uff0c\u5176\u7834\u58de\u529b\u4e0d\u53ef\u4f30\u91cf\u3002"
