  "text": {
    "en": {
      "name": "Junk Synchron",
      "effect": "When this card is Normal Summoned: You can target 1 Level 2 or lower monster in your GY; Special Summon that target in Defense Position, but negate its effects."
    },
    "fr": {
      "name": "Robot Synchronique",
      "effect": "Lorsque cette carte est Invoqu\u00e9e Normalement : vous pouvez cibler 1 monstre de max. Niveau 2 dans votre Cimeti\u00e8re ; Invoquez Sp\u00e9cialement la cible en Position de D\u00e9fense, mais annulez ses effets."
    },
    "de": {
      "name": "Ger\u00fcmpelsynchronisierer",
      "effect": "Wenn diese Karte als Normalbeschw\u00f6rung beschworen wird: Du kannst 1 Monster der Stufe 2 oder niedriger in deinem Friedhof w\u00e4hlen; beschw\u00f6re jenes gew\u00e4hlte Ziel als Spezialbeschw\u00f6rung in die Verteidigungsposition, aber annulliere seine Effekte."
    },
    "it": {
      "name": "Rottame Synchron",
      "effect": "Quando questa carta viene Evocata Normalmente: puoi scegliere come bersaglio 1 mostro di Livello 2 o inferiore nel tuo Cimitero; Evoca Specialmente quel bersaglio in Posizione di Difesa, ma annulla i suoi effetti."
    },
    "pt": {
      "name": "Sucata Sincron",
      "effect": "Quando este card for Invocado por Invoca\u00e7\u00e3o-Normal: voc\u00ea pode escolher 1 monstro de N\u00edvel 2 ou menos no seu Cemit\u00e9rio; Invoque o alvo por Invoca\u00e7\u00e3o-Especial em Posi\u00e7\u00e3o de Defesa, mas negue seus efeitos."
    },
    "es": {
