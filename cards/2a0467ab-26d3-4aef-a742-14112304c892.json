  "text": {
    "en": {
      "name": "Elegant Egotist",
      "effect": "If \"Harpie Lady\" is on the field: Special Summon 1 \"Harpie Lady\" or \"Harpie Lady Sisters\" from your hand or Deck."
    },
    "fr": {
      "name": "\u00c9gotiste \u00c9l\u00e9gant",
      "effect": "Si \"Dame Harpie\" est sur le Terrain : Invoquez Sp\u00e9cialement 1 \"Dame Harpie\" ou \"S\u0153urs de Harpie\" depuis votre main ou Deck."
    },
    "de": {
      "name": "Vornehmer Egotist",
      "effect": "Falls sich \u201eHarpyie\u201c auf dem Spielfeld befindet: Beschw\u00f6re 1 \u201eHarpyie\u201c oder \u201eHarpyien-Schwestern\u201c als Spezialbeschw\u00f6rung von deiner Hand oder deinem Deck."
    },
    "it": {
      "name": "Egotista Elegante",
      "effect": "Se \"Lady Arpia\" \u00e8 sul Terreno: Evoca Specialmente 1 \"Lady Arpia\" o \"Sorelle Arpie\" dalla tua mano o Deck."
    },
    "pt": {
      "name": "Egotista Elegante",
      "effect": "Se \"Lady Harpia\" estiver no campo: Invoque por Invoca\u00e7\u00e3o-Especial 1 \"Lady Harpia\" ou \"Irm\u00e3s de Lady Harpia\" da sua m\u00e3o ou do Deck."
    },
    "es": {
      "name": "Egotista Elegante",
      "effect": "Si \"Dama Arp\u00eda\" est\u00e1 en el Campo: Invoca de Modo Especial, desde tu mano o Deck, 1 \"Dama Arp\u00eda\" o \"Hermanas de la Dama Arp\u00eda\"."
    },
