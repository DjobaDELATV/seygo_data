  "text": {
    "en": {
      "name": "Lady Ninja Yae",
      "effect": "By discarding 1 WIND monster from your hand to the Graveyard, return all Spell and Trap Cards on your opponent's side of the field to the owner's hand."
    },
    "fr": {
      "name": "Dame Ninja Yae",
      "effect": "En d\u00e9faussant 1 carte monstre VENT de votre main au Cimeti\u00e8re, retournez toutes les Cartes Magie et Pi\u00e8ge sur le Terrain de votre adversaire dans la main de son propri\u00e9taire."
    },
    "de": {
      "name": "Ninjalady Yae",
      "effect": "Wirf 1 WIND Monster aus deiner Hand auf den Friedhof ab, um alle Zauber- und Fallenkarten auf der Spielfeldseite deines Gegners auf die Hand ihrer Besitzer zur\u00fcckzugeben."
    },
    "it": {
      "name": "Lady Ninja Yae",
      "effect": "Scarta 1 mostro VENTO dalla tua mano al Cimitero. Fa ritornare in mano al proprietario tutte le Carte Magia e Trappola sul Terreno del tuo avversario."
    },
    "pt": {
      "name": "Dama Ninja Yae",
      "effect": "Descarte 1 monstro do VENTO da sua m\u00e3o para o Cemit\u00e9rio. Devolva todos os Cards de Magia e Armadilha no Campo do seu advers\u00e1rio para a sua m\u00e3o dos seus donos."
    },
    "es": {
      "name": "Dama Ninja Yae",
      "effect": "Descarta 1 monstruo de VIENTO de tu mano al Cementerio. Devuelve todas las Cartas M\u00e1gicas y de Trampa en el Campo de tu adversario a la mano de sus propietarios."
    },
