  "text": {
    "en": {
      "name": "Preparation of Rites",
      "effect": "Add 1 Level 7 or lower Ritual Monster from your Deck to your hand, then you can add 1 Ritual Spell from your GY to your hand."
    },
    "fr": {
      "name": "Pr\u00e9paration des Rites",
      "effect": "Ajoutez 1 Monstre Rituel de max. Niveau 7 depuis votre Deck \u00e0 votre main, puis vous pouvez ajouter 1 Magie Rituelle depuis votre Cimeti\u00e8re \u00e0 votre main."
    },
    "de": {
      "name": "Vorbereitung der Riten",
      "effect": "F\u00fcge deiner Hand 1 Ritualmonster der Stufe 7 oder niedriger von deinem Deck hinzu, dann kannst du deiner Hand 1 Ritualzauber von deinem Friedhof hinzuf\u00fcgen."
    },
    "it": {
      "name": "Preparazione dei Riti",
      "effect": "Aggiungi 1 Mostro Rituale di Livello 7 o inferiore dal tuo Deck alla tua mano, poi puoi aggiungere 1 Magia Rituale dal tuo Cimitero alla tua mano."
    },
    "pt": {
      "name": "Prepara\u00e7\u00e3o de Ritos",
      "effect": "Adicione 1 Monstro de Ritual de N\u00edvel 7 ou menos do seu Deck \u00e0 sua m\u00e3o e, depois, voc\u00ea pode adicionar 1 Magia de Ritual do seu Cemit\u00e9rio \u00e0 sua m\u00e3o."
    },
    "es": {
      "name": "Preparaci\u00f3n de Rituales",
      "effect": "A\u00f1ade a tu mano 1 Monstruo de Ritual de Nivel 7 o menor en tu Deck, y despu\u00e9s puedes a\u00f1adir a tu mano 1 M\u00e1gica de Ritual en tu Cementerio."
    },
    "ja": {
      "name": "\u5100\u5f0f\u306e\u6e96\u5099",
