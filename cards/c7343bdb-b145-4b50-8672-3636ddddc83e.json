  "text": {
    "en": {
      "name": "Black Chaos the Dark Chaos Magician",
      "effect": "You can Ritual Summon this card with \"Ritual of Light and Darkness\". Unaffected by your opponent's activated effects, unless they target this card. Spells/Traps you control cannot be destroyed, or banished, by your opponent's card effects. You can only use each of the following effects of \"Black Chaos the Dark Chaos Magician\" once per turn. If this card is Special Summoned: You can add 1 Spell from your GY to your hand. You can target 1 card your opponent controls; banish it (face-down).",
      "official": false
    },
    "ja": {
      "name": "\u9ed2\u304d\u6df7\u6c8c\u306e\u9b54\u8853\u5e2b\u30d6\u30e9\u30c3\u30af\u30fb\u30ab\u30aa\u30b9",
