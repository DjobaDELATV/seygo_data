  "text": {
    "en": {
      "name": "Card Destruction",
      "effect": "Both players discard as many cards as possible from their hands, then each player draws the same number of cards they discarded."
    },
    "fr": {
      "name": "Destruction de Carte",
      "effect": "Chaque joueur d\u00e9fausse autant de cartes que possible depuis sa main, puis chaque joueur pioche le m\u00eame nombre de cartes qu'il a d\u00e9fauss\u00e9es."
    },
    "de": {
      "name": "Kartenzerst\u00f6rung",
      "effect": "Beide Spieler werfen so viele Karten wie m\u00f6glich von ihren H\u00e4nden ab, dann zieht jeder Spieler dieselbe Anzahl Karten, die er abgeworfen hat."
    },
    "it": {
      "name": "Distruggi-Carte",
      "effect": "Entrambi i giocatori scartano tante carte quante possibile dalla loro mano, poi ogni giocatore pesca lo stesso numero di carte che ha scartato."
    },
    "pt": {
      "name": "Destrui\u00e7\u00e3o de Cards",
      "effect": "Os dois duelistas descartam tantos cards quanto poss\u00edvel de suas m\u00e3os e, depois, cada duelista compra o mesmo n\u00famero de cards que ele descartou."
    },
    "es": {
      "name": "Destrucci\u00f3n de la Carta",
      "effect": "Ambos jugadores descartan tantas cartas como sea posible de sus manos, y despu\u00e9s cada jugador roba el mismo n\u00famero de cartas que descart\u00f3."
    },
    "ja": {
