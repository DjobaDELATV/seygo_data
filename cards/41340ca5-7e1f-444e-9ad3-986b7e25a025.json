  "text": {
    "en": {
      "name": "Fire Lake of the Burning Abyss",
      "effect": "Send 2 face-up \"Burning Abyss\" monsters you control to the Graveyard, then target up to 3 cards on the field; destroy those targets."
    },
    "fr": {
      "name": "Lac de Feu des Abysses Ardents",
      "effect": "Envoyez 2 monstres \"Abysses Ardents\" face recto que vous contr\u00f4lez au Cimeti\u00e8re, puis ciblez max. 3 cartes sur le Terrain ; d\u00e9truisez les cibles."
    },
    "de": {
      "name": "Feuersee des Brennenden Abgrunds",
      "effect": "Lege 2 offene \u201eBrennenden Abgrund\u201c-Monster, die du kontrollierst, auf den Friedhof und w\u00e4hle dann bis zu 3 Karten auf dem Spielfeld; zerst\u00f6re die gew\u00e4hlten Ziele."
    },
    "it": {
      "name": "Lago di Fuoco dell'Abisso Bruciante",
      "effect": "Manda 2 mostri \"Abisso Bruciante\" scoperti che controlli al Cimitero, poi scegli come bersaglio fino a 3 carte sul Terreno; distruggi quei bersagli."
    },
    "pt": {
      "name": "Lago de Fogo do Abismo Ardente",
      "effect": "Envie 2 monstros \"Abismo Ardente\" com a face para cima que voc\u00ea controla para o Cemit\u00e9rio e, depois, escolha at\u00e9 3 cards no campo; destrua os alvos."
    },
    "es": {
      "name": "Lago de Fuego del Abismo Ardiente",
      "effect": "Manda al Cementerio 2 monstruos \"Abismo Ardiente\" boca arriba que controles, y despu\u00e9s selecciona hasta 3 cartas en el Campo; destruye esos objetivos."
