      "effect": "\u5e94\u5bf9\u6b64\u5361\u7684\u53d1\u52a8\uff0c\u5bf9\u624b\u4e0d\u53ef\u53d1\u52a8\u602a\u517d\u7684\u6548\u679c\u3002\u2460\uff1a\u4ece\u989d\u5916\u724c\u7ec4\u5c061\u53ea\u602a\u517d\u9001\u81f3\u5893\u5730\uff0c\u4ee5\u5bf9\u624b\u573a\u4e0a1\u53ea\u79cd\u7c7b\uff08\u878d\u5408\u30fb\u540c\u6b65\u30fb\u8d85\u91cf\u30fb\u7075\u6446\u30fb\u8fde\u63a5\uff09\u4e0e\u8be5\u602a\u517d\u76f8\u540c\u7684\u602a\u517d\u4e3a\u5bf9\u8c61\u53ef\u4ee5\u53d1\u52a8\u3002\u5c06\u8be5\u602a\u517d\u653e\u56de\u724c\u7ec4\u3002"
