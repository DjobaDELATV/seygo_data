    },
    "ko": {
      "name": "\ub9c8\uc288\ub9c8\ub860",
      "effect": "\u2460: \uc774 \uce74\ub4dc\ub294 \uc804\ud22c\ub85c\ub294 \ud30c\uad34\ub418\uc9c0 \uc54a\ub294\ub2e4. \u2461: \ub4b7\uba74 \ud45c\uc2dc\uc758 \uc774 \uce74\ub4dc\uac00 \uacf5\uaca9\ubc1b\uc740 \ub370\ubbf8\uc9c0 \uacc4\uc0b0 \ud6c4\uc5d0 \ubc1c\ub3d9\ud55c\ub2e4. \uc774 \uce74\ub4dc\ub97c \uacf5\uaca9\ud55c \ubaac\uc2a4\ud130\uc758 \ucee8\ud2b8\ub864\ub7ec\ub294 1000 \ub370\ubbf8\uc9c0\ub97c \ubc1b\ub294\ub2e4."
