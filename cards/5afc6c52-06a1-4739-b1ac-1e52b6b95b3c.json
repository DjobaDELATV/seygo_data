    "en": {
      "name": "Marionette Mite",
      "effect": "You can discard this card to the GY, then target 1 Fiend or Zombie monster your opponent controls; take control of that target until the End Phase."
    },
    "fr": {
      "name": "Mite Articul\u00e9e",
      "effect": "Vous pouvez d\u00e9fausser cette carte au Cimeti\u00e8re, puis ciblez 1 monstre D\u00e9mon ou Zombie contr\u00f4l\u00e9 par votre adversaire ; jusqu'\u00e0 la End Phase, prenez le contr\u00f4le de la cible."
    },
    "de": {
      "name": "Marionettenmilbe",
