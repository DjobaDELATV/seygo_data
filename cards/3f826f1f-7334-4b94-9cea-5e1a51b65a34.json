  "text": {
    "en": {
      "name": "Snipe Hunter",
      "effect": "You can discard 1 card, then target 1 card on the field; roll a six-sided die, and destroy that target unless you roll a 1 or 6."
    },
    "fr": {
      "name": "Chasseur de Pr\u00e9cision",
      "effect": "Vous pouvez d\u00e9fausser 1 carte, puis ciblez 1 carte sur le Terrain ; lancez un d\u00e9 \u00e0 six faces, et d\u00e9truisez la cible sauf si le r\u00e9sultat est 1 ou 6."
    },
    "de": {
      "name": "J\u00e4ger im Hinterhalt",
      "effect": "Du kannst 1 Karte abwerfen und dann 1 Karte auf dem Spielfeld w\u00e4hlen; wirf einen sechsseitigen W\u00fcrfel und zerst\u00f6re jenes gew\u00e4hlte Ziel, es sei denn, du w\u00fcrfelst eine 1 oder 6."
    },
    "it": {
      "name": "Cacciatore Cecchino",
      "effect": "Puoi scartare 1 carta, poi scegliere come bersaglio 1 carta sul Terreno; tira un dado a sei facce e distruggi il bersaglio a meno che tu tiri un 1 o un 6."
    },
    "pt": {
      "name": "Ca\u00e7ador Escondido",
      "effect": "Voc\u00ea pode descartar 1 card e, depois, escolha 1 card no campo; lance um dado de seis faces e destrua o alvo a n\u00e3o ser que o resultado seja 1 ou 6."
    },
    "es": {
      "name": "Cazador Escondido",
      "effect": "Puedes descartar 1 carta, y despu\u00e9s selecciona 1 carta en el Campo; lanza un dado de seis caras, y destruye ese objetivo a menos que salga 1 o 6."
    },
