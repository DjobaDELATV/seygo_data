  "text": {
    "en": {
      "name": "Gaia The Fierce Knight",
      "effect": "A knight whose horse travels faster than the wind. His battle-charge is a force to be reckoned with."
    },
    "fr": {
      "name": "Ga\u00efa le Chevalier Implacable",
      "effect": "Chevalier dont le destrier voyage plus vite que le vent. Sa charge de bataille est une force \u00e0 ne pas sous-estimer."
    },
    "de": {
      "name": "Gaia, zorniger Ritter",
      "effect": "Ein Ritter, dessen Pferd schneller als der Wind ist. Mit seiner Kampfkraft muss man rechnen."
    },
    "it": {
      "name": "Gaia il Cavaliere",
      "effect": "Un cavaliere il cui destriero galoppa pi\u00f9 veloce del vento. Quando attacca alla carica dimostra una forza devastante."
    },
    "pt": {
      "name": "Gaia, o Cavaleiro Impetuoso",
      "effect": "Um cavaleiro com um cavalo que galopa mais r\u00e1pido que o vento. Sua carga em batalha \u00e9 de uma for\u00e7a avassaladora."
    },
    "es": {
      "name": "Gaia el Caballero Feroz",
      "effect": "Un caballero cuyo caballo galopa m\u00e1s r\u00e1pido que el viento. Su carga en la batalla es una fuerza a considerar."
    },
