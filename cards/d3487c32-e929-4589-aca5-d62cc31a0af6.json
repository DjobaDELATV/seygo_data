  "text": {
    "en": {
      "name": "Red Nova Dragon/Assault Mode",
      "effect": "Cannot be Normal Summoned/Set. Must be Special Summoned with \"Assault Mode Activate\". When your opponent activates a card or effect (Quick Effect): You can banish this card until the End Phase; banish cards your opponent controls up to the number of Tuners in your GY. When an opponent's monster declares an attack: You can banish this card until the End Phase; negate the attack, then end the Battle Phase. If this card is destroyed: You can Special Summon 1 \"Red Nova Dragon\" from your GY.",
      "official": false
    },
    "ja": {
      "name": "\u30b9\u30ab\u30fc\u30ec\u30c3\u30c9\u30fb\u30ce\u30f4\u30a1\u30fb\u30c9\u30e9\u30b4\u30f3\uff0f\u30d0\u30b9\u30bf\u30fc",
