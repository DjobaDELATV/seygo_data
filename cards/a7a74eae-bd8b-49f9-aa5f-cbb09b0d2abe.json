  "text": {
    "en": {
      "name": "Chaos Hunter",
      "effect": "When your opponent Special Summons a monster (except during the Damage Step): You can discard 1 card; Special Summon this card from your hand. Your opponent cannot banish cards."
    },
    "fr": {
      "name": "Chasseresse du Chaos",
      "effect": "Lorsque votre adversaire Invoque Sp\u00e9cialement un monstre (sauf durant la Damage Step) : vous pouvez d\u00e9fausser 1 carte ; Invoquez Sp\u00e9cialement cette carte depuis votre main. Votre adversaire ne peut pas bannir de cartes."
    },
    "de": {
      "name": "Chaosj\u00e4gerin",
      "effect": "Wenn dein Gegner ein Monster als Spezialbeschw\u00f6rung beschw\u00f6rt (au\u00dfer w\u00e4hrend des Damage Steps): Du kannst 1 Karte abwerfen; beschw\u00f6re diese Karte als Spezialbeschw\u00f6rung von deiner Hand. Dein Gegner kann keine Karten verbannen."
    },
    "it": {
      "name": "Cacciatore del Chaos",
      "effect": "Quando il tuo avversario Evoca Specialmente un mostro (eccetto durante il Damage Step): puoi scartare 1 carta; Evoca Specialmente questa carta dalla tua mano. Il tuo avversario non pu\u00f2 bandire carte."
    },
    "pt": {
