  "text": {
    "en": {
      "name": "Synchron Explorer",
      "effect": "When this card is Normal Summoned: You can target 1 \"Synchron\" monster in your GY; Special Summon that target, but negate its effects."
    },
    "fr": {
      "name": "Explorateur Synchronique",
      "effect": "Lorsque cette carte est Invoqu\u00e9e Normalement : vous pouvez cibler 1 monstre \"Synchronique\" dans votre Cimeti\u00e8re ; Invoquez Sp\u00e9cialement la cible, mais annulez ses effets."
    },
    "de": {
      "name": "Synchronentdecker",
      "effect": "Wenn diese Karte als Normalbeschw\u00f6rung beschworen wird: Du kannst 1 \u201eSynchron\u201c-Monster in deinem Friedhof w\u00e4hlen; beschw\u00f6re das gew\u00e4hlte Ziel als Spezialbeschw\u00f6rung, aber annulliere seine Effekte."
    },
    "it": {
