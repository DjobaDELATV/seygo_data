      "effect": "\u2460\uff1a\u53ea\u8981\u6b64\u5361\u5728\u602a\u517d\u533a\u57df\u4ee5\u653b\u51fb\u8868\u793a\u5b58\u5728\uff0c\u4ec5\u4ee5\u81ea\u5df1\u573a\u4e0a\u76841\u53ea\u673a\u68b0\u65cf\u602a\u517d\u4e3a\u5bf9\u8c61\u7684\u9b54\u6cd5\u30fb\u9677\u9631\u5361\u7684\u6548\u679c\u5c31\u5c06\u88ab\u65e0\u6548\u3002\u2461\uff1a\u6b64\u5361\u56e0\u6218\u6597\u88ab\u7834\u574f\u4e14\u9001\u81f3\u5893\u5730\u65f6\u53ef\u4ee5\u53d1\u52a8\u3002\u81ea\u5df1\u4ece\u724c\u7ec4\u4e2d\u62bd1\u5f20\u3002"
