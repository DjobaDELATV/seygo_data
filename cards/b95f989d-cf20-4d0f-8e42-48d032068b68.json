  "text": {
    "en": {
      "name": "Damage Gate",
      "effect": "When you take battle damage: Target 1 monster in your Graveyard with ATK less than or equal to the amount of damage you took; Special Summon that target."
    },
    "fr": {
      "name": "Portail de la Douleur",
      "effect": "Lorsque vous recevez des dommages de combat : ciblez 1 monstre dans votre Cimeti\u00e8re avec une ATK inf\u00e9rieure ou \u00e9gale au montant des dommages que vous avez re\u00e7us ; Invoquez Sp\u00e9cialement la cible."
    },
    "de": {
      "name": "Schadenstor",
      "effect": "Wenn du Kampfschaden erh\u00e4ltst: W\u00e4hle 1 Monster in deinem Friedhof mit ATK kleiner oder gleich dem Schaden, den du erhalten hast; beschw\u00f6re das gew\u00e4hlte Ziel als Spezialbeschw\u00f6rung."
    },
    "it": {
      "name": "Cancello del Danno",
      "effect": "Quando subisci danno da combattimento: scegli come bersaglio 1 mostro nel tuo Cimitero con ATK pari o inferiore all'ammontare del danno che hai subito; Evoca Specialmente quel bersaglio."
    },
    "pt": {
      "name": "Avariar Portal",
      "effect": "Quando voc\u00ea sofrer dano de batalha: escolha 1 monstro em seu Cemit\u00e9rio com ATK menor ou igual ao dano que voc\u00ea sofreu; Invoque o alvo por Invoca\u00e7\u00e3o-Especial."
    },
    "es": {
      "name": "Portal del Da\u00f1o",
      "effect": "Cuando recibes da\u00f1o de batalla: selecciona 1 monstruo en tu Cementerio con un ATK menor o igual que el da\u00f1o que recibiste; Invoca ese objetivo de Modo Especial."
