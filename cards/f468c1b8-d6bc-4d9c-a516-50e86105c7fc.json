  "text": {
    "en": {
      "name": "Ryko, Lightsworn Hunter",
      "effect": "FLIP: Apply these effects (simultaneously).\n\u25cf You can destroy 1 card on the field.\n\u25cf Send the top 3 cards of your Deck to the GY."
    },
