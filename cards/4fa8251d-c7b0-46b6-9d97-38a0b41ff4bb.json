  "text": {
    "en": {
      "name": "D.D. Crow",
      "effect": "(Quick Effect): You can discard this card to the GY, then target 1 card in your opponent's GY; banish that target."
    },
    "fr": {
      "name": "Corbeau D.D.",
      "effect": "(Effet Rapide) : vous pouvez d\u00e9fausser cette carte au Cimeti\u00e8re, puis ciblez 1 carte dans le Cimeti\u00e8re de votre adversaire ; bannissez la cible."
    },
    "de": {
      "name": "D.D. Kr\u00e4he",
      "effect": "(Schnelleffekt): Du kannst diese Karte auf den Friedhof abwerfen und dann 1 Karte im Friedhof deines Gegners w\u00e4hlen; verbanne jenes gew\u00e4hlte Ziel."
    },
    "it": {
      "name": "Corvo D.D.",
      "effect": "(Effetto Rapido): puoi scartare questa carta al Cimitero, poi scegliere come bersaglio 1 carta nel Cimitero del tuo avversario; bandisci quel bersaglio."
    },
