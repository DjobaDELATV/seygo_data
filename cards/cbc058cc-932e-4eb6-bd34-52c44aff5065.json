  "text": {
    "en": {
      "name": "Negate Attack",
      "effect": "When an opponent's monster declares an attack: Target the attacking monster; negate the attack, then end the Battle Phase."
    },
    "fr": {
      "name": "Annulation d'Attaque",
      "effect": "Lorsqu'un monstre de l'adversaire d\u00e9clare une attaque : ciblez le monstre attaquant ; annulez l'attaque, puis terminez la Battle Phase."
    },
    "de": {
      "name": "Angriff annullieren",
      "effect": "Wenn ein Monster eines Gegners einen Angriff deklariert: W\u00e4hle das angreifende Monster; annulliere den Angriff, dann beende die Battle Phase."
    },
    "it": {
      "name": "Annulla Attacco",
      "effect": "Quando un mostro dell'avversario dichiara un attacco: scegli come bersaglio il mostro attaccante; annulla l'attacco, poi termina la Battle Phase."
    },
    "pt": {
      "name": "Negativa\u00e7\u00e3o de Ataque",
      "effect": "Quando um monstro do oponente declarar um ataque: escolha o monstro atacante; negue o ataque e, depois, encerre a Fase de Batalha."
    },
    "es": {
