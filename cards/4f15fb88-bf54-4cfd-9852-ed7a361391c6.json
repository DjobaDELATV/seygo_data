  "text": {
    "en": {
      "name": "Stumbling",
      "effect": "Any monster that is Normal Summoned, Flip Summoned or Special Summoned is changed to Defense Position."
    },
    "fr": {
      "name": "Faux Pas",
      "effect": "Tant que cette carte reste face recto sur le Terrain, tout monstre Invoqu\u00e9 avec succ\u00e8s par Invocation Normale, Invocation Flip ou Invocation Sp\u00e9ciale est chang\u00e9 en Position de D\u00e9fense."
    },
    "de": {
      "name": "Stolpern",
      "effect": "Solange sich diese Karte offen auf dem Spielfeld befindet, wird jedes Monster, das erfolgreich als Normal-, Flipp- oder Spezialbeschw\u00f6rung beschworen wurde, in Verteidigungsposition gedreht."
    },
    "it": {
      "name": "Inciampare",
      "effect": "Fino a quando questa carta resta scoperta sul Terreno, qualsiasi mostro Evocato tramite Evocazione Normale, Evocazione per Scoperta o Evocazione Speciale viene messa in Posizione di Difesa."
    },
    "pt": {
      "name": "Trope\u00e7ar",
      "effect": "Qualquer monstro que for Invocado por Invoca\u00e7\u00e3o-Normal, Virar ou Especial \u00e9 colocado em Posi\u00e7\u00e3o de Defesa."
    },
    "es": {
      "name": "Tropezando",
      "effect": "Todo monstruo que sea Invocado con \u00e9xito mediante una Invocaci\u00f3n Normal, de Volteo o Invocaci\u00f3n Especial se cambia a Posici\u00f3n de Defensa."
    },
    "ja": {
      "name": "\u3064\u307e\u305a\u304d",
      "effect": "\u53ec\u559a\u30fb\u53cd\u8ee2\u53ec\u559a\u30fb\u7279\u6b8a\u53ec\u559a\u306b\u6210\u529f\u3057\u305f\u30e2\u30f3\u30b9\u30bf\u30fc\u306f\u5b88\u5099\u8868\u793a\u306b\u306a\u308b\u3002"
