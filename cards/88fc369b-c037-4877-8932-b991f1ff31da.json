  "id": "88fc369b-c037-4877-8932-b991f1ff31da",
  "text": {
    "en": {
      "name": "Elemental HERO Avian",
      "effect": "A winged Elemental HERO who wheels through the sky and manipulates the wind. His signature move, Featherbreak, gives villainy a blow from sky-high."
    },
    "fr": {
      "name": "Avian, H\u00c9ROS \u00c9l\u00e9mentaire",
      "effect": "Un H\u00c9ROS \u00c9l\u00e9mentaire ail\u00e9 qui tournoie dans le ciel et manipule les vents. Son attaque sp\u00e9cifique, Fracas de Plume, fait voler l'infamie en morceaux."
    },
    "de": {
      "name": "Elementar-HELD Avian",
      "effect": "Ein gefl\u00fcgelter Elementar-HELD, welcher seine Kreise durch den Himmel zieht und den Wind manipuliert. Seine charakteristische Bewegung, Federbrecher, gibt Schurken einen Sto\u00df aus hoher Luft."
    },
    "it": {
      "name": "Avian EROE Elementale",
      "effect": "Un EROE Elementale alato che volteggia nel cielo e manipola il vento. La sua mossa segreta, Colpo di Piuma, colpisce la malvagit\u00e0 dall'alto dei cieli."
    },
    "pt": {
      "name": "Avi\u00e1rio, o HER\u00d3I do Elemento",
      "effect": "Um HER\u00d3I do Elemento alado que vaga pelo c\u00e9u e manipula o vento. O seu ataque caracter\u00edstico, o Quebra-penas, derruba vil\u00f5es com golpe vindo dos c\u00e9us."
    },
    "es": {
      "name": "H\u00c9ROE Elemental Avian",
      "effect": "Un H\u00c9ROE Elemental alado que gira cruzando el cielo y manipula el viento. Su movimiento personal, Rompeplumas, le propina a la vileza un golpe desde el cielo."
    },
    "ja": {
      "name": "\uff25\u30fb\uff28\uff25\uff32\uff2f \u30d5\u30a7\u30b6\u30fc\u30de\u30f3",
      "effect": "\u98a8\u3092\u64cd\u308a\u7a7a\u3092\u821e\u3046\u7ffc\u3092\u6301\u3063\u305f\uff25\u30fb\uff28\uff25\uff32\uff2f\u3002\u5929\u7a7a\u304b\u3089\u306e\u4e00\u6483\u3001\u30d5\u30a7\u30b6\u30fc\u30d6\u30ec\u30a4\u30af\u3067\u60aa\u3092\u88c1\u304f\u3002"
    },
    "ko": {
