    "en": {
      "name": "TGX1-HL",
      "effect": "Target 1 \"T.G.\" monster you control; its ATK/DEF each become half its current ATK/DEF, and if they do, destroy 1 other Spell/Trap on the field."
    },
    "fr": {
      "name": "TGX1-HL",
      "effect": "Ciblez 1 monstre \"T.G.\" que vous contr\u00f4lez ; son ATK/DEF deviennent la moiti\u00e9 de son ATK/DEF actuelles, et si elles le deviennent, d\u00e9truisez 1 autre Magie/Pi\u00e8ge sur le Terrain."
    },
    "de": {
