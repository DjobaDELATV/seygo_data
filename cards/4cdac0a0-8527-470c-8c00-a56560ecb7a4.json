  "text": {
    "en": {
      "name": "The Phantom Knights of Decayed Cloak",
      "effect": "You can reveal 1 other \"The Phantom Knights\" card in your hand; Special Summon this card from your hand. If this card is Normal or Special Summoned: You can add 1 \"The Phantom Knights\" monster from your Deck to your hand. You can banish this card from your GY, then target 1 Xyz Monster you control; this turn, you can use it as material for an Xyz Summon using its Rank as if it were a Level. You can only use each effect of \"The Phantom Knights of Decayed Cloak\" once per turn.",
      "official": false
    },
    "ja": {
      "name": "\u5e7b\u5f71\u9a0e\u58eb\u56e3\u30c7\u30a3\u30b1\u30a4\u30af\u30ed\u30fc\u30af",
