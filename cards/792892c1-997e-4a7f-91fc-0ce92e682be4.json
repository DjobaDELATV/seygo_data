    "ko": {
      "name": "\ub124\uba54\uc2dc\uc2a4 \ucf54\ub9ac\ub3c4",
      "effect": "\uc774 \uce74\ub4dc\uba85\uc758 \u2460\u2461\uc758 \ud6a8\uacfc\ub294 \uac01\uac01 1\ud134\uc5d0 1\ubc88\ubc16\uc5d0 \uc0ac\uc6a9\ud560 \uc218 \uc5c6\ub2e4. \u2460: \uc774 \uce74\ub4dc\uac00 \ud328\uc5d0 \uc874\uc7ac\ud560 \uacbd\uc6b0, \"\ub124\uba54\uc2dc\uc2a4 \ucf54\ub9ac\ub3c4\" \uc774\uc678\uc758 \uc790\uc2e0\uc758 \uc81c\uc678 \uc0c1\ud0dc\uc778 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ub300\uc0c1\uc73c\ub85c \ud558\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uc774 \uce74\ub4dc\ub97c \ud2b9\uc218 \uc18c\ud658\ud558\uace0, \ub300\uc0c1 \ubaac\uc2a4\ud130\ub97c \ub371\uc73c\ub85c \ub418\ub3cc\ub9b0\ub2e4. \u2461: \"\ub124\uba54\uc2dc\uc2a4 \ucf54\ub9ac\ub3c4\" \uc774\uc678\uc758 \uc790\uc2e0\uc758 \uc81c\uc678 \uc0c1\ud0dc\uc778 \"\ub124\uba54\uc2dc\uc2a4\" \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ub300\uc0c1\uc73c\ub85c \ud558\uace0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \uadf8 \ubaac\uc2a4\ud130\ub97c \ud328\uc5d0 \ub123\ub294\ub2e4."
    },
    "zh-CN": {
      "name": "\u661f\u4e49\u30fb\u7eff\u5eca",
      "effect": "\u6b64\u5361\u540d\u7684\u2460\u2461\u6548\u679c1\u56de\u5408\u4ec5\u53ef\u5404\u4f7f\u75281\u6b21\u3002\u2460\uff1a\u6b64\u5361\u5b58\u5728\u4e8e\u624b\u724c\u7684\u60c5\u51b5\u4e0b\uff0c\u4ee5\u201c\u661f\u4e49\u30fb\u7eff\u5eca\u201d\u4ee5\u5916\u7684\u3001\u81ea\u5df1\u9664\u5916\u72b6\u6001\u76841\u53ea\u602a\u517d\u4e3a\u5bf9\u8c61\u53ef\u4ee5\u53d1\u52a8\u3002\u5c06\u6b64\u5361\u7279\u6b8a\u53ec\u5524\uff0c\u5c06\u5bf9\u8c61\u602a\u517d\u653e\u56de\u724c\u7ec4\u3002\u2461\uff1a\u4ee5\u201c\u661f\u4e49\u30fb\u7eff\u5eca\u201d\u4ee5\u5916\u7684\u3001\u81ea\u5df1\u9664\u5916\u72b6\u6001\u76841\u53ea\u201c\u661f\u4e49\u201d\u602a\u517d\u4e3a\u5bf9\u8c61\u53ef\u4ee5\u53d1\u52a8\u3002\u5c06\u8be5\u602a\u517d\u52a0\u5165\u624b\u724c\u3002"
