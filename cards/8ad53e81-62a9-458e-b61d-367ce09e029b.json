  "text": {
    "en": {
      "name": "Dicephoon",
      "effect": "Roll a six-sided die and apply the result.\n\u25cf 2, 3, or 4: Destroy 1 Spell/Trap on the field.\n\u25cf 5: Destroy 2 Spells/Traps on the field.\n\u25cf 1 or 6: You take 1000 damage."
    },
    "fr": {
      "name": "D\u00e9phon",
      "effect": "Lancez un d\u00e9 \u00e0 six faces et appliquez le r\u00e9sultat.\n\u25cf 2, 3 ou 4 : D\u00e9truisez 1 Magie/Pi\u00e8ge sur le Terrain.\n\u25cf 5 : D\u00e9truisez 2 Magies/Pi\u00e8ges sur le Terrain.\n\u25cf 1 ou 6 : Vous recevez 1000 points de dommages."
    },
    "de": {
      "name": "W\u00fcrfeltaifun",
      "effect": "Wirf einen sechsseitigen W\u00fcrfel und f\u00fchre das Ergebnis aus.\n\u25cf 2, 3 oder 4: Zerst\u00f6re 1 Zauber/Falle auf dem Spielfeld.\n\u25cf 5: Zerst\u00f6re 2 Zauber/Fallen auf dem Spielfeld.\n\u25cf 1 oder 6: Du erh\u00e4ltst 1000 Schaden."
    },
    "it": {
      "name": "Dadotifone",
      "effect": "Tira un dado a sei facce e applica il risultato.\n\u25cf 2, 3 o 4: Distruggi 1 Magia/Trappola sul Terreno.\n\u25cf 5: Distruggi 2 Magie/Trappole sul Terreno.\n\u25cf 1 o 6: Tu subisci 1000 danni."
    },
    "pt": {
      "name": "Furadad\u00e3o",
      "effect": "Lance um dado de seis faces e aplique o resultado.\n\u25cf 2, 3 ou 4: Destrua 1 Magia/Armadilha no campo.\n\u25cf 5: Destrua 2 Magia/Armadilha no campo.\n\u25cf 1 ou 6: Voc\u00ea sofre 1000 de dano."
    },
    "es": {
      "name": "Dadof\u00f3n",
      "effect": "Lanza un dado de seis caras y aplica el resultado.\n\u25cf 2, 3 o 4: Destruye 1 M\u00e1gica/Trampa en el Campo.\n\u25cf 5: Destruye 2 M\u00e1gicas/Trampas en el Campo.\n\u25cf 1 o 6: Recibes 1000 puntos de da\u00f1o."
    },
