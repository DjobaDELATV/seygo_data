  "text": {
    "en": {
      "name": "Yami",
      "effect": "All Fiend and Spellcaster monsters on the field gain 200 ATK/DEF, also all Fairy monsters on the field lose 200 ATK/DEF."
    },
    "fr": {
      "name": "Yami",
      "effect": "Tous les monstres D\u00e9mon et Magicien sur le Terrain gagnent 200 ATK/DEF, et aussi, tous les monstres Elfe sur le Terrain perdent 200 ATK/DEF."
    },
    "de": {
      "name": "Yami",
      "effect": "Alle Unterweltler- und Hexer-Monster auf dem Spielfeld erhalten 200 ATK/DEF, zus\u00e4tzlich verlieren alle Fee-Monster auf dem Spielfeld 200 ATK/DEF."
    },
    "it": {
      "name": "Yami",
      "effect": "Tutti i mostri Demone e Incantatore sul Terreno guadagnano 200 ATK/DEF, inoltre tutti i mostri Fata sul Terreno perdono 200 ATK/DEF."
    },
    "pt": {
      "name": "Yami",
      "effect": "Todos os monstros Dem\u00f4nio e Mago no campo ganham 200 de ATK/DEF e, al\u00e9m disso, todos os monstros Fada no campo perdem 200 de ATK/DEF."
    },
    "es": {
      "name": "Yami",
      "effect": "Todos los monstruos Demonio y Lanzador de Conjuros en el Campo ganan 200 ATK/DEF, y adem\u00e1s todos los monstruos Hada en el Campo pierden 200 ATK/DEF."
    },
