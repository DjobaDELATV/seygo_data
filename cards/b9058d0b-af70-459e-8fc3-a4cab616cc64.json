      "effect": "\u6b64\u5361\u4e0d\u53ef\u901a\u5e38\u53ec\u5524\u3002\u4ec5\u53ef\u4ee5\u201c\u6b66\u88c5\u9f99 LV5\u201d\u7684\u6548\u679c\u7279\u6b8a\u53ec\u5524\u3002\u2460\uff1a\u4ece\u624b\u724c\u5c06\uff11\u53ea\u602a\u517d\u9001\u81f3\u5893\u5730\u53ef\u4ee5\u53d1\u52a8\u3002\u5c06\u5bf9\u624b\u573a\u4e0a\u62e5\u6709\u8be5\u9001\u81f3\u5893\u5730\u602a\u517d\u7684\u653b\u51fb\u529b\u4ee5\u4e0b\u653b\u51fb\u529b\u7684\u602a\u517d\u5168\u90e8\u7834\u574f\u3002"
