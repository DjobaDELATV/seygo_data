  "text": {
    "en": {
      "name": "Ego Boost",
      "effect": "When a monster declares an attack: Target 1 face-up monster on the field; it gains 1000 ATK until the end of the Battle Phase."
    },
    "fr": {
      "name": "Boost d'Ego",
      "effect": "Lorsqu'un monstre d\u00e9clare une attaque : ciblez 1 monstre face recto sur le Terrain ; jusqu'\u00e0 la fin de la Battle Phase, il gagne 1000 ATK."
    },
    "de": {
      "name": "Egoschub",
      "effect": "Wenn ein Monster einen Angriff deklariert: W\u00e4hle 1 offenes Monster auf dem Spielfeld; es erh\u00e4lt bis zum Ende der Battle Phase 1000 ATK."
    },
    "it": {
      "name": "Potenziamento dell'Ego",
      "effect": "Quando un mostro dichiara un attacco: scegli come bersaglio 1 mostro scoperto sul Terreno; esso guadagna 1000 ATK fino alla fine della Battle Phase."
    },
    "pt": {
      "name": "Intensificador de Ego",
      "effect": "Quando um monstro declarar um ataque: escolha 1 monstro com a face para cima no campo; ele ganha 1000 de ATK at\u00e9 o final da Fase de Batalha."
    },
    "es": {
      "name": "Mejora del Ego",
      "effect": "Cuando un monstruo declara un ataque: selecciona 1 monstruo boca arriba en el Campo; \u00e9ste gana 1000 ATK hasta el final de la Battle Phase."
    },
    "ja": {
