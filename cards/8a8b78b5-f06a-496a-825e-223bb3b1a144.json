  "text": {
    "en": {
      "name": "De-Spell",
      "effect": "Target 1 face-up Spell, or 1 Set Spell/Trap, on the field; destroy that target if it is a Spell. (If the target is Set, reveal it.)"
    },
    "fr": {
      "name": "Exorcisme",
      "effect": "Ciblez 1 Magie face recto ou 1 Magie/Pi\u00e8ge Pos\u00e9 sur le Terrain ; d\u00e9truisez la cible si c'est une Magie. (Si la cible est Pos\u00e9e, r\u00e9v\u00e9lez-la.)"
    },
    "de": {
      "name": "Fluchzerst\u00f6rer",
      "effect": "W\u00e4hle 1 offenen Zauber oder 1 gesetzte/n Zauber/Falle auf dem Spielfeld; zerst\u00f6re das gew\u00e4hlte Ziel, falls es ein Zauber ist. (Falls das gew\u00e4hlte Ziel gesetzt ist, zeige es vor.)"
    },
    "it": {
      "name": "Annulla Carta Magia",
      "effect": "Scegli come bersaglio 1 Magia scoperta, oppure 1 Magia/Trappola Posizionata, sul Terreno; distruggi quel bersaglio se \u00e8 una Magia. (Se il bersaglio \u00e8 Posizionato, rivelalo.)"
    },
    "pt": {
      "name": "Remover Magia",
      "effect": "Escolha 1 Magia com a face para cima ou 1 Magia/Armadilha Baixada no campo; destrua o alvo se for uma Magia. (Se o alvo estiver Baixado, revele-o.)"
    },
    "es": {
      "name": "Exorcismo",
      "effect": "Selecciona 1 M\u00e1gica boca arriba, o 1 M\u00e1gica/Trampa Colocada, en el Campo; destruye ese objetivo si es una M\u00e1gica. (Si el objetivo est\u00e1 Colocado, mu\u00e9stralo)."
    },
