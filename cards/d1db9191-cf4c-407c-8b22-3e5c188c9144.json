    },
    "zh-TW": {
      "name": "\u65e5\u98df\u7ffc\u9f8d",
      "effect": "\u6b64\u5361\u88ab\u9001\u5165\u5893\u5730\u7684\u573a\u5408\uff0c\u4ece\u724c\u7ec4\u4e2d\u5c06\uff11\u53ea\u5149\u5c5e\u6027\u6216\u6697\u5c5e\u6027\u9f99\u65cf\u3001\u7b49\u7ea7\uff17\u6216\u4ee5\u4e0a\u7684\u602a\u517d\u4ece\u6e38\u620f\u4e2d\u9664\u5916\u3002\u4e4b\u540e\uff0c\u5893\u5730\u4e2d\u7684\u6b64\u5361\u4ece\u6e38\u620f\u4e2d\u9664\u5916\u7684\u573a\u5408\uff0c\u53ef\u4ee5\u5c06\u6b64\u5361\u7684\u5361\u724c\u6548\u679c\u4ece\u6e38\u620f\u4e2d\u9664\u5916\u7684\u8be5\u602a\u517d\u52a0\u5165\u624b\u724c\u3002"
