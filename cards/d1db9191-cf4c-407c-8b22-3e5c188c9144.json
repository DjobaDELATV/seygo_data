  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "d1db9191-cf4c-407c-8b22-3e5c188c9144",
  "text": {
    "en": {
      "name": "Eclipse Wyvern",
      "effect": "If this card is sent to the GY: Banish 1 Level 7 or higher LIGHT or DARK Dragon monster from your Deck. If this card is banished from your GY: You can add the monster banished by this card's effect to your hand."
    },
    "fr": {
      "name": "Vouivre \u00c9clipse",
      "effect": "Si cette carte est envoy\u00e9e au Cimeti\u00e8re : bannissez 1 monstre LUMI\u00c8RE ou T\u00c9N\u00c8BRES Dragon de min. Niveau 7 depuis votre Deck. Si cette carte est bannie depuis votre Cimeti\u00e8re : vous pouvez ajouter le monstre banni par l'effet de cette carte \u00e0 votre main."
    },
    "de": {
      "name": "Eklipsen-Lindwurm",
      "effect": "Falls diese Karte auf den Friedhof gelegt wird: Verbanne 1 LICHT oder FINSTERNIS Drache-Monster der Stufe 7 oder h\u00f6her von deinem Deck. Falls diese Karte von deinem Friedhof verbannt wird: Du kannst das durch den Effekt dieser Karte verbannte Monster deiner Hand hinzuf\u00fcgen."
    },
    "it": {
      "name": "Viverna Eclisse",
      "effect": "Se questa carta viene mandata al Cimitero: bandisci 1 mostro LUCE o OSCURIT\u00c0 Drago di Livello 7 o superiore dal tuo Deck. Se questa carta viene bandita dal tuo Cimitero: puoi aggiungere alla tua mano il mostro bandito dall'effetto di questa carta."
    },
    "pt": {
      "name": "Wivern do Eclipse",
      "effect": "Se este card for enviado para o Cemit\u00e9rio: bana 1 monstro Drag\u00e3o de LUZ ou de TREVAS de N\u00edvel 7 ou mais do seu Deck. Se este card for banido do seu Cemit\u00e9rio: voc\u00ea pode adicionar \u00e0 sua m\u00e3o o monstro banido pelo efeito deste card."
    },
    "es": {
      "name": "G\u00fciverno del Eclipse",
      "effect": "Si esta carta es mandada al Cementerio: destierra 1 monstruo Drag\u00f3n de LUZ u OSCURIDAD de Nivel 7 o mayor en tu Deck. Si esta carta es desterrada de tu Cementerio: puedes a\u00f1adir a tu mano el monstruo desterrado por el efecto de esta carta."
    },
    "ja": {
      "name": "\u30a8\u30af\u30ea\u30d7\u30b9\u30fb\u30ef\u30a4\u30d0\u30fc\u30f3",
      "effect": "\u2460\uff1a\u3053\u306e\u30ab\u30fc\u30c9\u304c\u5893\u5730\u3078\u9001\u3089\u308c\u305f\u5834\u5408\u306b\u767a\u52d5\u3059\u308b\u3002\u30c7\u30c3\u30ad\u304b\u3089\u30ec\u30d9\u30eb\uff17\u4ee5\u4e0a\u3067\u5149\u30fb\u95c7\u5c5e\u6027\u306e\u30c9\u30e9\u30b4\u30f3\u65cf\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u9664\u5916\u3059\u308b\u3002\u2461\uff1a\u5893\u5730\u306e\u3053\u306e\u30ab\u30fc\u30c9\u304c\u9664\u5916\u3055\u308c\u305f\u5834\u5408\u306b\u767a\u52d5\u3067\u304d\u308b\u3002\u3053\u306e\u30ab\u30fc\u30c9\u306e\u2460\u306e\u52b9\u679c\u3067\u9664\u5916\u3055\u308c\u3066\u3044\u308b\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u624b\u672d\u306b\u52a0\u3048\u308b\u3002"
    },
    "ko": {
      "name": "\uc774\ud074\ub9bd\uc2a4 \uc640\uc774\ubc18",
