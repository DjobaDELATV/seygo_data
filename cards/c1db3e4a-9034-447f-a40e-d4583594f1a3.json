  "text": {
    "en": {
      "name": "Zombie World",
      "effect": "All monsters on the field and in the GYs become Zombie monsters. Neither player can Tribute Summon monsters, except Zombie monsters."
    },
    "fr": {
      "name": "Monde Zombie",
      "effect": "Tous les monstres sur le Terrain et dans les Cimeti\u00e8res deviennent des monstres Zombie. Aucun joueur ne peut Invoquer par Sacrifice de monstres (monstres Zombie exclus)."
    },
    "de": {
      "name": "Zombiewelt",
      "effect": "Alle Monster auf dem Spielfeld und in den Friedh\u00f6fen werden zu Zombie-Monstern. Kein Spieler kann Monster als Tributbeschw\u00f6rung beschw\u00f6ren, au\u00dfer Zombie-Monstern."
    },
    "it": {
      "name": "Mondo Zombie",
      "effect": "Tutti i mostri sul Terreno e nei Cimiteri diventano mostri Zombie. Nessun giocatore pu\u00f2 Evocare mostri tramite Tributo, eccetto mostri Zombie."
    },
    "pt": {
      "name": "Mundo Zumbi",
      "effect": "Todos os monstros no campo e nos Cemit\u00e9rios se tornam monstros Zumbi. Nenhum duelista pode Invocar monstros por Invoca\u00e7\u00e3o-Tributo, exceto monstros Zumbi."
    },
    "es": {
      "name": "Mundo Zombi",
