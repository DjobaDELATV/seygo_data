{
  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "d9af20f3-cc07-4783-83f0-b200d3406290",
  "text": {
    "en": {
      "name": "Sky Striker Mobilize - Engage!",
      "effect": "If you control no monsters in your Main Monster Zone: Add 1 \"Sky Striker\" card from your Deck to your hand, except \"Sky Striker Mobilize - Engage!\", then, if you have 3 or more Spells in your GY, you can draw 1 card."
    },
    "fr": {
      "name": "Assaut de l'Air - Mobilisation - \u00c0 l'Attaque !",
      "effect": "Si vous ne contr\u00f4lez aucun monstre dans votre Zone Monstre Main : ajoutez 1 carte \"Assaut de l'Air\" (\"Assaut de l'Air - Mobilisation - \u00c0 l'Attaque !\" exclu) depuis votre Deck \u00e0 votre main, puis, si vous avez min. 3 Magies dans votre Cimeti\u00e8re, vous pouvez piocher 1 carte."
    },
    "de": {
      "name": "Himmelsj\u00e4ger-Mobilisierung - Angriff!",
      "effect": "Falls du keine Monster in deiner Main-Monsterzone kontrollierst: F\u00fcge deiner Hand 1 \u201eHimmelsj\u00e4ger\u201c-Karte von deinem Deck hinzu, au\u00dfer \u201eHimmelsj\u00e4ger-Mobilisierung - Angriff!\u201c, dann, falls du 3 oder mehr Zauber in deinem Friedhof hast, kannst du 1 Karte ziehen."
    },
    "it": {
      "name": "Assaltatrice del Cielo Mobilitazione - Ingaggiare!",
      "effect": "Se non controlli nessun mostro nella tua Zona Mostri Main: aggiungi 1 carta \"Assaltatrice del Cielo\" dal tuo Deck alla tua mano, eccetto \"Assaltatrice del Cielo Mobilitazione - Ingaggiare!\", poi, se hai 3 o pi\u00f9 Magie nel tuo Cimitero, puoi pescare 1 carta."
    },
    "pt": {
      "name": "For\u00e7a Celeste - Mobilizar - Engajar!",
      "effect": "Se voc\u00ea n\u00e3o controlar nenhum monstro na sua Zona de Monstros Principal: adicione 1 card \"For\u00e7a Celeste\" do seu Deck \u00e0 sua m\u00e3o, exceto \"For\u00e7a Celeste - Mobilizar - Engajar!\" e, depois, se voc\u00ea tiver 3 ou mais Magias no seu Cemit\u00e9rio, voc\u00ea pode comprar 1 card."
    },
    "es": {
      "name": "Caza del Cielo Movilizar - \u00a1Atacar!",
      "effect": "Si no controlas monstruos en tu Zona de Monstruos Principal: a\u00f1ade a tu mano 1 carta \"Caza del Cielo\" en tu Deck, excepto \"Caza del Cielo Movilizar - \u00a1Atacar!\" y despu\u00e9s, si tienes 3 o m\u00e1s M\u00e1gicas en tu Cementerio, puedes robar 1 carta."
    },
    "ja": {
      "name": "\u9583\u5200\u8d77\u52d5\uff0d\u30a8\u30f3\u30b2\u30fc\u30b8",
      "effect": "\u2460\uff1a\u81ea\u5206\u306e\u30e1\u30a4\u30f3\u30e2\u30f3\u30b9\u30bf\u30fc\u30be\u30fc\u30f3\u306b\u30e2\u30f3\u30b9\u30bf\u30fc\u304c\u5b58\u5728\u3057\u306a\u3044\u5834\u5408\u306b\u767a\u52d5\u3067\u304d\u308b\u3002\u30c7\u30c3\u30ad\u304b\u3089\u300c\u9583\u5200\u8d77\u52d5\uff0d\u30a8\u30f3\u30b2\u30fc\u30b8\u300d\u4ee5\u5916\u306e\u300c\u9583\u5200\u300d\u30ab\u30fc\u30c9\uff11\u679a\u3092\u624b\u672d\u306b\u52a0\u3048\u308b\u3002\u305d\u306e\u5f8c\u3001\u81ea\u5206\u306e\u5893\u5730\u306b\u9b54\u6cd5\u30ab\u30fc\u30c9\u304c\uff13\u679a\u4ee5\u4e0a\u5b58\u5728\u3059\u308b\u5834\u5408\u3001\u81ea\u5206\u306f\uff11\u679a\u30c9\u30ed\u30fc\u3067\u304d\u308b\u3002"
    },
    "ko": {
      "name": "\uc12c\ub3c4\uae30\ub3d9\uff0d\uc778\uac8c\uc774\uc9c0",
      "effect": "\u2460: \uc790\uc2e0 \uba54\uc778 \ubaac\uc2a4\ud130 \uc874\uc5d0 \ubaac\uc2a4\ud130\uac00 \uc874\uc7ac\ud558\uc9c0 \uc54a\uc744 \uacbd\uc6b0\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \ub371\uc5d0\uc11c \"\uc12c\ub3c4\uae30\ub3d9\uff0d\uc778\uac8c\uc774\uc9c0\" \uc774\uc678\uc758 \"\uc12c\ub3c4\" \uce74\ub4dc 1\uc7a5\uc744 \ud328\uc5d0 \ub123\ub294\ub2e4. \uadf8 \ud6c4, \uc790\uc2e0 \ubb18\uc9c0\uc5d0 \ub9c8\ubc95 \uce74\ub4dc\uac00 3\uc7a5 \uc774\uc0c1 \uc874\uc7ac\ud560 \uacbd\uc6b0, \uc790\uc2e0\uc740 1\uc7a5 \ub4dc\ub85c\uc6b0\ud560 \uc218 \uc788\ub2e4."
