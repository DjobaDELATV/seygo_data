  "text": {
    "en": {
      "name": "Bottomless Trap Hole",
      "effect": "When your opponent Summons a monster(s) with 1500 or more ATK: Destroy that monster(s) with 1500 or more ATK, and if you do, banish it."
    },
    "fr": {
      "name": "Trappe sans Fond",
      "effect": "Lorsque votre adversaire Invoque un ou plusieurs monstres avec min. 1500 ATK : d\u00e9truisez ces monstres avec min. 1500 ATK, et si vous le faites, bannissez-les."
    },
    "de": {
      "name": "Bodenlose Fallgrube",
      "effect": "Wenn dein Gegner ein oder mehr Monster mit 1500 oder mehr ATK beschw\u00f6rt: Zerst\u00f6re jene Monster mit 1500 oder mehr ATK und falls du dies tust, verbanne sie."
    },
