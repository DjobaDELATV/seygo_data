  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "e0443f27-3082-4363-bd83-9d2200e099d3",
  "text": {
    "en": {
      "name": "Magic Cylinder",
      "effect": "When an opponent's monster declares an attack: Target the attacking monster; negate the attack, and if you do, inflict damage to your opponent equal to its ATK."
    },
    "fr": {
      "name": "Cylindre Magique",
      "effect": "Lorsqu'un monstre de l'adversaire d\u00e9clare une attaque : ciblez le monstre attaquant ; annulez l'attaque, et si vous le faites, infligez des dommages \u00e0 votre adversaire \u00e9gaux \u00e0 son ATK."
    },
    "de": {
      "name": "Magischer Zylinder",
      "effect": "Wenn ein Monster eines Gegners einen Angriff deklariert: W\u00e4hle das angreifende Monster; annulliere den Angriff und falls du dies tust, f\u00fcge deinem Gegner Schaden in H\u00f6he seiner ATK zu."
    },
    "it": {
      "name": "Cilindro Magico",
      "effect": "Quando un mostro dell'avversario dichiara un attacco: scegli come bersaglio il mostro attaccante; annulla l'attacco e, se lo fai, infliggi al tuo avversario danno pari al suo ATK."
    },
    "pt": {
      "name": "Cilindro M\u00e1gico",
      "effect": "Quando um monstro do oponente declarar um ataque: escolha o monstro atacante; negue o ataque e, se isso acontecer, cause dano ao seu oponente igual ao ATK dele."
    },
    "es": {
      "name": "Cilindro M\u00e1gico",
      "effect": "Cuando un monstruo del adversario declara un ataque: selecciona al monstruo atacante; niega el ataque y, si lo haces, inflige da\u00f1o a tu adversario igual a su ATK."
    },
    "ja": {
