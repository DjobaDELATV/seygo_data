  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "c15e1dd2-769e-4f94-868c-3ebceee6ac6a",
  "text": {
    "en": {
      "name": "Nobleman of Crossout",
      "effect": "Target 1 face-down monster on the field; destroy that target, and if you do, banish it, then, if it was a Flip monster, each player reveals their Main Deck, then banishes all cards from it with that monster's name."
    },
    "fr": {
      "name": "Seigneur de la Suppression",
      "effect": "Ciblez 1 monstre face verso sur le Terrain ; d\u00e9truisez la cible, et si vous le faites, bannissez-le, puis, si c'\u00e9tait un monstre Flip, chaque joueur r\u00e9v\u00e8le son Main Deck, puis en bannit toutes les cartes du nom du monstre."
    },
    "de": {
      "name": "Adliger der Ausl\u00f6schung",
      "effect": "W\u00e4hle 1 verdecktes Monster auf dem Spielfeld; zerst\u00f6re jenes gew\u00e4hlte Ziel und falls du dies tust, verbanne es, dann, falls es ein Flippmonster war, zeigt jeder Spieler sein Main Deck vor, dann verbannt er alle Karten mit dem Namen jenes Monsters daraus."
    },
    "it": {
      "name": "Nobiluomo dello Scambio",
      "effect": "Scegli come bersaglio 1 mostro coperto sul Terreno; distruggi quel bersaglio e, se lo fai, bandiscilo, poi, se era un mostro Scoperta, ogni giocatore rivela il suo Main Deck, poi bandisce da esso tutte le carte con il nome di quel mostro."
    },
    "pt": {
      "name": "O Nobre de Crossout",
      "effect": "Escolha 1 monstro com a face para baixo no campo; destrua o alvo e, se isso acontecer, bana-o e, depois, se ele era um monstro de Virar, cada duelista revela o seu Deck Principal e, depois, bane dele todos os cards com aquele nome de monstro."
    },
    "es": {
      "name": "Noble de Crossout",
      "effect": "Selecciona 1 monstruo boca abajo en el Campo; destruye ese objetivo y, si lo haces, desti\u00e9rralo y despu\u00e9s, si era un monstruo de Volteo, cada jugador muestra su Deck Principal, y despu\u00e9s destierra de \u00e9ste todas las cartas con ese nombre de monstruo."
    },
    "ja": {
      "name": "\u62b9\u6bba\u306e\u4f7f\u5f92",
