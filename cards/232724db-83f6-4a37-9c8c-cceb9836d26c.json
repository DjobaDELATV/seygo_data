  "text": {
    "en": {
      "name": "Imperial Order",
      "effect": "Negate all Spell effects on the field. Once per turn, during the Standby Phase, you must pay 700 LP (this is not optional), or this card is destroyed."
    },
    "fr": {
      "name": "Ordre Imp\u00e9rial",
      "effect": "Annulez tous les effets de Magie sur le Terrain. Une fois par tour, durant la Standby Phase, vous devez payer 700 LP (ceci est obligatoire), ou cette carte est d\u00e9truite."
    },
    "de": {
      "name": "Kaiserlicher Befehl",
