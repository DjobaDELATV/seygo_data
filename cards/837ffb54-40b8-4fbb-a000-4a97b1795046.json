  "text": {
    "en": {
      "name": "Pharaoh's Servant (card)",
      "effect": "An apparition of those said to formerly serve the Pharaoh. It has tremendous loyalty that does not waver."
    },
    "fr": {
      "name": "Serviteur du Pharaon",
      "effect": "Une apparition d'un de ceux qui, dit-on, servait autrefois le Pharaon. Il est dot\u00e9 d'une loyaut\u00e9 in\u00e9branlable qui ne faiblit pas."
    },
    "de": {
      "name": "Diener des Pharao",
      "effect": "Eine Erscheinung derer, von denen man sagt, dass sie fr\u00fcher dem Pharao gedient haben. Sie zeigt gewaltige Loyalit\u00e4t, die ungebrochen ist."
    },
    "it": {
      "name": "Servitore del Faraone",
      "effect": "L'apparizione di colui che per lungo tempo ha servito il Faraone. Ha una fedelt\u00e0 estrema che non l'abbandona mai."
    },
    "pt": {
      "name": "Servo do Fara\u00f3",
      "effect": "Uma apari\u00e7\u00e3o da qual se diz ter servido antigamente o Fara\u00f3. Tem uma tremenda lealdade que n\u00e3o desaparece."
    },
    "es": {
      "name": "El Servidor del Fara\u00f3n",
      "effect": "Una aparici\u00f3n de aquellos que se dice sirvieron al Fara\u00f3n. Tiene una lealtad enorme que no se desvanece."
