  "text": {
    "en": {
      "name": "Final Attack Orders",
      "effect": "All face-up monsters on the field are changed to Attack Position and their battle positions cannot be changed."
    },
    "fr": {
      "name": "Derniers Ordres de Combat",
      "effect": "Tous les monstres face recto sur le Terrain sont chang\u00e9s en Position d'Attaque et leur position de combat ne peut pas \u00eatre chang\u00e9e."
    },
    "de": {
      "name": "Letzte Angriffsbefehle",
      "effect": "Alle offenen Monster auf dem Spielfeld werden in die Angriffsposition ge\u00e4ndert und ihre Kampfpositionen k\u00f6nnen nicht ge\u00e4ndert werden."
    },
    "it": {
      "name": "Ordini di Attacco Finale",
      "effect": "Tutti i mostri scoperti sul Terreno vengono messi in Posizione di Attacco e la loro posizione non pu\u00f2 essere cambiata."
    },
    "pt": {
      "name": "Ordens para o Ataque Final",
      "effect": "Todos os monstros com a face para cima no campo s\u00e3o colocados em Posi\u00e7\u00e3o de Ataque e suas posi\u00e7\u00f5es de batalha n\u00e3o podem ser mudadas."
    },
    "es": {
      "name": "\u00d3rdenes de Ataque Final",
      "effect": "Todos los monstruos boca arriba en el Campo se cambian a Posici\u00f3n de Ataque y sus posiciones de batalla no pueden ser cambiadas."
    },
