  "text": {
    "en": {
      "name": "Resonator Command",
      "effect": "Discard 1 \"Resonator\" monster; add 1 Level 4 or lower Fiend monster from your Deck to your hand. You can only activate 1 \"Resonator Command\" per turn."
    },
    "fr": {
      "name": "Ordre du Diapason",
      "effect": "D\u00e9faussez 1 monstre \"Diapason\" ; ajoutez 1 monstre D\u00e9mon de max. Niveau 4 depuis votre Deck \u00e0 votre main. Vous ne pouvez activer qu'1 \"Ordre du Diapason\" par tour."
    },
    "de": {
      "name": "Resonatorkommando",
      "effect": "Wirf 1 \u201eResonator\u201c-Monster ab; f\u00fcge deiner Hand 1 Unterweltler-Monster der Stufe 4 oder niedriger von deinem Deck hinzu. Du kannst nur 1 \u201eResonatorkommando\u201c pro Spielzug aktivieren."
    },
    "it": {
      "name": "Commando Diapason",
      "effect": "Scarta 1 mostro \"Diapason\"; aggiungi 1 mostro Demone di Livello 4 o inferiore dal tuo Deck alla tua mano. Puoi attivare solo 1 \"Commando Diapason\" per turno."
    },
    "pt": {
      "name": "Comandar Ressonador",
      "effect": "Descarte 1 monstro \"Ressonador\"; adicione 1 monstro Dem\u00f4nio de N\u00edvel 4 ou menos do seu Deck \u00e0 sua m\u00e3o. Voc\u00ea s\u00f3 pode ativar 1 \"Comandar Ressonador\" por turno."
    },
    "es": {
      "name": "Mando de Resonador",
      "effect": "Descarta 1 monstruo \"Resonador\"; a\u00f1ade a tu mano 1 monstruo Demonio de Nivel 4 o menor en tu Deck. S\u00f3lo puedes activar 1 \"Mando de Resonador\" por turno."
    },
