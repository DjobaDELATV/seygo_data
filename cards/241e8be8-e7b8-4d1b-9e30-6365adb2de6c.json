  "text": {
    "en": {
      "name": "Reject Reborn",
      "effect": "When an opponent's monster declares a direct attack: End the Battle Phase, then you can Special Summon 1 Tuner and 1 Synchro Monster from your Graveyard, but they have their effects negated."
    },
    "fr": {
      "name": "Renaissance Rejet\u00e9e",
      "effect": "Lorsqu'un monstre de votre adversaire d\u00e9clare une attaque directe : terminez la Battle Phase, puis vous pouvez Invoquer Sp\u00e9cialement 1 Syntoniseur et 1 Monstre Synchro depuis votre Cimeti\u00e8re, mais ils ont leurs effets annul\u00e9s."
    },
    "de": {
      "name": "Ablehnende Wiedergeburt",
      "effect": "Wenn ein Monster deines Gegners einen direkten Angriff deklariert: Beende die Battle Phase, dann kannst du 1 Empf\u00e4nger und 1 Synchromonster als Spezialbeschw\u00f6rung von deinem Friedhof beschw\u00f6ren, aber ihre Effekte bleiben annulliert."
    },
    "it": {
      "name": "Rinascita Rifiuto",
      "effect": "Quando un mostro dell'avversario dichiara un attacco diretto: termina la Battle Phase, poi puoi Evocare Specialmente 1 Tuner e 1 Mostro Synchro dal tuo Cimitero, ma i loro effetti si annullano."
    },
    "pt": {
      "name": "Rejeitar Renascimento",
