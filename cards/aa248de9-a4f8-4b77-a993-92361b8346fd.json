  "text": {
    "en": {
      "name": "Emergency Teleport",
      "effect": "Special Summon 1 Level 3 or lower Psychic monster from your hand or Deck, but banish it during the End Phase of this turn."
    },
    "fr": {
      "name": "T\u00e9l\u00e9porteur d'Urgence",
      "effect": "(Cette carte est toujours trait\u00e9e comme carte \"T\u00e9l\u00e9portation\".)\nInvoquez Sp\u00e9cialement 1 monstre Psychique de max. Niveau 3 depuis votre main ou Deck, mais bannissez-le durant la End Phase de ce tour."
    },
    "de": {
      "name": "Notfallteleport",
      "effect": "Beschw\u00f6re 1 Psi-Monster der Stufe 3 oder niedriger als Spezialbeschw\u00f6rung von deiner Hand oder deinem Deck, aber verbanne es w\u00e4hrend der End Phase dieses Spielzugs."
    },
    "it": {
