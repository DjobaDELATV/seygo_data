  "text": {
    "en": {
      "name": "Mistaken Arrest",
      "effect": "Until the end of your next turn after this card resolves, neither player can add cards from their Deck to their hand except by drawing them."
    },
    "fr": {
      "name": "Arrestation Erron\u00e9e",
      "effect": "Jusqu'\u00e0 la fin de votre prochain tour apr\u00e8s la r\u00e9solution de cette carte, aucun joueur ne peut ajouter de cartes depuis son Deck \u00e0 sa main, sauf en les piochant."
    },
    "de": {
      "name": "Fehlerhafte Verhaftung",
      "effect": "Bis zum Ende deines n\u00e4chsten Spielzugs, nachdem diese Karte aufgel\u00f6st wurde, kann kein Spieler seiner Hand Karten von seinem Deck hinzuf\u00fcgen, au\u00dfer indem er sie zieht."
    },
    "it": {
      "name": "Arrestato per Sbaglio",
      "effect": "Fino alla fine del tuo prossimo turno dopo che questa carta si \u00e8 risolta, nessun giocatore pu\u00f2 aggiungere carte dal suo Deck alla sua mano, eccetto pescandole."
    },
