  "text": {
    "en": {
      "name": "Red Carpet",
      "effect": "If a Dragon-Type Synchro Monster is on the field: Target up to 2 \"Resonator\" monsters in your Graveyard; Special Summon them."
    },
    "fr": {
      "name": "Tapis Rouge",
      "effect": "Si un Monstre Synchro de Type Dragon est sur le Terrain : ciblez max. 2 monstres \"Diapason\" (\"R\u00e9sonateur des Flammes\" inclus) dans votre Cimeti\u00e8re ; Invoquez-les Sp\u00e9cialement."
    },
    "de": {
      "name": "Roter Teppich",
      "effect": "Falls sich ein Synchromonster vom Typ Drache auf dem Spielfeld befindet: W\u00e4hle bis zu 2 \u201eResonator\u201c-Monster in deinem Friedhof; beschw\u00f6re sie als Spezialbeschw\u00f6rung."
    },
    "it": {
