  "text": {
    "en": {
      "name": "Copycat",
      "effect": "If this card is Summoned: Target 1 face-up monster your opponent controls; this card's ATK/DEF become equal to that monster's original ATK/DEF."
    },
    "fr": {
      "name": "Copiechat",
      "effect": "Si cette carte est Invoqu\u00e9e : ciblez 1 monstre face recto contr\u00f4l\u00e9 par votre adversaire ; l'ATK/DEF de cette carte deviennent \u00e9gales \u00e0 l'ATK/DEF d'origine du monstre."
    },
    "de": {
