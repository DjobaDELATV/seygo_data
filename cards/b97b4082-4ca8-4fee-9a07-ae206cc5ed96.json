  "text": {
    "en": {
      "name": "The Dragon Dwelling in the Cave",
      "effect": "A huge dragon dwelling in a cave. It is horrible when it gets angry, although it is usually quiet. It is said to preserve certain treasures."
    },
    "fr": {
      "name": "Le Dragon Tapi dans la Caverne",
      "effect": "Un imposant dragon vivant dans une caverne. Calme de nature, il est redoutable lorsqu'il se met en col\u00e8re. Selon la l\u00e9gende, il prot\u00e8gerait certains tr\u00e9sors."
    },
    "de": {
      "name": "Drache, der in der H\u00f6hle haust",
      "effect": "Ein gro\u00dfer Drache, der in einer H\u00f6hle lebt. Sein Zorn ist f\u00fcrchterlich, wenn er gereizt wird, doch normalerweise ist er recht friedlich. Man sagt, er bewache Sch\u00e4tze."
    },
    "it": {
      "name": "Il Drago Abitante nella Caverna",
      "effect": "Un gigantesco drago che vive nelle caverne. Terribile quando si infuria, tuttavia \u00e8 generalmente tranquillo. Si narra che protegga alcuni tesori."
    },
    "pt": {
      "name": "O Drag\u00e3o Vivendo na Caverna",
      "effect": "Um enorme drag\u00e3o que vive em uma caverna. Quando ele fica nervoso, a situa\u00e7\u00e3o fica terr\u00edvel, embora ele normalmente seja quieto. Dizem que ele guarda alguns tesouros."
    },
    "es": {
      "name": "El Drag\u00f3n que Mora en la Cueva",
      "effect": "Un enorme drag\u00f3n que mora en una cueva. Es horrible cuando se enfada, a pesar de que es normalmente tranquilo. Se dice que conserva varios tesoros."
    },
