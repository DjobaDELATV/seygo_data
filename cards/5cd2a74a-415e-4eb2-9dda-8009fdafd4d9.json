  "text": {
    "en": {
      "name": "Faustian Bargain",
      "effect": "Target 1 Special Summoned monster on either field; send it to the GY, and if you do, Special Summon 1 Level 4 or lower Normal Monster from your hand."
    },
    "fr": {
      "name": "Pacte avec le Diable",
      "effect": "Ciblez 1 monstre Invoqu\u00e9 Sp\u00e9cialement sur le Terrain ; envoyez-le au Cimeti\u00e8re, et si vous le faites, Invoquez Sp\u00e9cialement 1 Monstre Normal de max. Niveau 4 depuis votre main."
    },
    "de": {
      "name": "Faustischer Handel",
      "effect": "W\u00e4hle 1 als Spezialbeschw\u00f6rung beschworenes Monster auf einer beliebigen Spielfeldseite; lege es auf den Friedhof und falls du dies tust, beschw\u00f6re 1 Normales Monster der Stufe 4 oder niedriger als Spezialbeschw\u00f6rung von deiner Hand."
    },
    "it": {
      "name": "Patto Faustiano",
      "effect": "Scegli come bersaglio 1 mostro Evocato Specialmente su qualsiasi Terreno; mandalo al Cimitero e, se lo fai, Evoca Specialmente 1 Mostro Normale di Livello 4 o inferiore dalla tua mano."
    },
    "pt": {
      "name": "Barganha Faustiana",
      "effect": "Escolha 1 monstro Invocado por Invoca\u00e7\u00e3o-Especial em qualquer campo; envie-o para o Cemit\u00e9rio e, se isso acontecer, Invoque por Invoca\u00e7\u00e3o-Especial 1 Monstro Normal de N\u00edvel 4 ou menos da sua m\u00e3o."
    },
    "es": {
      "name": "Pacto de Fausto",
      "effect": "Selecciona 1 monstruo Invocado de Modo Especial en cualquier Campo; m\u00e1ndalo al Cementerio y, si lo haces, Invoca de Modo Especial, desde tu mano, 1 Monstruo Normal de Nivel 4 o menor."
    },
    "ja": {
