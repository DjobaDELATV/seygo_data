  "text": {
    "en": {
      "name": "Angel Trumpeter",
      "effect": "This beautiful, fairy-like flower generates a delusional mist to keep intruders away from the deepest parts of the forest, where sacred beasts dwell."
    },
    "fr": {
      "name": "Trompettiste d'Ange",
      "effect": "Cette belle fleur f\u00e9erique g\u00e9n\u00e8re un brouillard d\u00e9lirant pour \u00e9loigner les intrus des parties les plus profondes de la for\u00eat o\u00f9 demeurent les b\u00eates sacr\u00e9es."
    },
    "de": {
      "name": "Engelstrompeter",
      "effect": "Diese wundersch\u00f6ne, feengleiche Blume erzeugt einen irref\u00fchrenden Nebel, der Eindringlinge aus den tiefsten Teilen des Waldes fernh\u00e4lt, in denen heilige Unwesen leben."
    },
    "it": {
      "name": "Trombettiere Angelico",
      "effect": "Questo bellissimo fiore fatato genera una foschia ammaliatrice per tenere gli intrusi lontani dal profondo della foresta, dove dimorano le bestie sacre."
    },
    "pt": {
      "name": "Anjo Trompetista",
      "effect": "Esta flor linda e fe\u00e9rica cria uma n\u00e9voa delirante para manter os intrusos afastados das partes mais profundas da floresta, onde vivem as feras mais sagradas."
    },
    "es": {
      "name": "\u00c1ngel Trompetista",
      "effect": "Esta hermosa flor, parecida a un hada, genera una niebla que confunde y mantiene a los intrusos lejos de las partes m\u00e1s profundas del bosque, donde moran las bestias sagradas."
    },
    "ja": {
