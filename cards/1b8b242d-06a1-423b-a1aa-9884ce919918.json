  "text": {
    "en": {
      "name": "Sea Serpent Warrior of Darkness",
      "effect": "A warrior who defends the world of the Sea of Darkness. He prides himself on his fighting prowess both on the ground and, of course, in the water."
    },
    "fr": {
      "name": "Guerrier Serpent de Mer des T\u00e9n\u00e8bres",
      "effect": "Un guerrier qui d\u00e9fend le monde de la Mer des T\u00e9n\u00e8bres. Il s'enorgueillit de ses prouesses au combat, tant sur la terre que dans l'eau."
    },
    "de": {
      "name": "Seeschlangenk\u00e4mpfer der Dunkelheit",
      "effect": "Ein Krieger welcher die Welt der See der Finsternis verteidigt. Er ist stolz auf seine Kampff\u00e4higkeiten, sowohl auf dem Festland als selbstverst\u00e4ndlich auch im Wasser."
    },
    "it": {
      "name": "Serpente Marino Guerriero dell'Oscurit\u00e0",
      "effect": "Un guerriero che difende il mondo del Mare dell'Oscurit\u00e0. Si inorgoglisce delle sue capacit\u00e0 in combattimento sia sulla terra ferma quanto, ovviamente, in mare."
    },
    "pt": {
      "name": "Gerreiro da Serpente Marinha das Trevas",
      "effect": "Um Guerreiro que defende o mundo do Mar das Trevas. Ele orgulha-se da sua capacidade de luta tanto em terra como, \u00e9 claro, na \u00e1gua."
    },
    "es": {
      "name": "Guerrero Serpiente Marina de la Oscuridad",
      "effect": "Un guerrero que defiende el mundo del Mar de la Oscuridad. Se enorgullece de su habilidad en batalla tanto en tierra como, por supuesto, en el agua."
    },
    "ja": {
      "name": "\u6697\u9ed2\u306e\u6d77\u7adc\u5175",
      "effect": "\u6697\u9ed2\u6d77\u306e\u4e16\u754c\u3092\u5b88\u308b\u6226\u58eb\u3002\u6c34\u4e2d\u306f\u3082\u3061\u308d\u3093\u3001\u9678\u4e0a\u3067\u3082\u9ad8\u3044\u6226\u95d8\u80fd\u529b\u3092\u8a87\u308b\u3002"
    },
    "ko": {
      "name": "\uc554\ud751\uc758 \ud574\ub8e1\ubcd1",
      "effect": "\uc554\ud751\ud574\uc758 \uc138\uacc4\ub97c \uc9c0\ud0a4\ub294 \uc804\uc0ac. \uc218\uc911\uc740 \ubb3c\ub860\uc774\uace0, \uc721\uc0c1\uc5d0\uc11c\ub3c4 \ub192\uc740 \uc804\ud22c \ub2a5\ub825\uc744 \uc790\ub791\ud55c\ub2e4."
