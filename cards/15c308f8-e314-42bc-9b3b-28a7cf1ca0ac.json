  "text": {
    "en": {
      "name": "Ritual Beast Tamer Lara",
      "effect": "If this card is Normal Summoned: You can target 1 \"Ritual Beast\" monster in your Graveyard; Special Summon it. You can only Special Summon \"Ritual Beast Tamer Lara(s)\" once per turn."
    },
    "fr": {
      "name": "Lara, Dompteur B\u00eate Spirituelle",
      "effect": "Si cette carte est Invoqu\u00e9e Normalement : vous pouvez cibler 1 monstre \"B\u00eate Spirituelle\" dans votre Cimeti\u00e8re ; Invoquez-le Sp\u00e9cialement. Vous ne pouvez Invoquer Sp\u00e9cialement un ou plusieurs \"Lara, Dompteur B\u00eate Spirituelle\" qu'une fois par tour."
    },
    "de": {
      "name": "Geistungeheuer-Z\u00e4hmerin Lara",
      "effect": "Falls diese Karte als Normalbeschw\u00f6rung beschworen wird: Du kannst 1 \u201eGeistungeheuer\u201c-Monster in deinem Friedhof w\u00e4hlen; beschw\u00f6re es als Spezialbeschw\u00f6rung. Du kannst nur einmal pro Spielzug ein oder mehr \u201eGeistungeheuer-Z\u00e4hmerin Lara\u201c als Spezialbeschw\u00f6rung beschw\u00f6ren."
    },
    "it": {
