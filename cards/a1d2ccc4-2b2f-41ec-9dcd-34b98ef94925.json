    "en": {
      "name": "Electric Virus",
      "effect": "You can discard this card to the GY, then target 1 Machine or Dragon monster your opponent controls; take control of that target until the End Phase."
    },
    "fr": {
      "name": "Virus \u00c9lectrique",
      "effect": "Vous pouvez d\u00e9fausser cette carte au Cimeti\u00e8re, puis ciblez 1 monstre Machine ou Dragon contr\u00f4l\u00e9 par votre adversaire ; jusqu'\u00e0 la End Phase, prenez le contr\u00f4le de la cible."
    },
    "de": {
      "name": "Elektrischer Virus",
