  "text": {
    "en": {
      "name": "The Melody of Awakening Dragon",
      "effect": "Discard 1 card; add up to 2 Dragon monsters with 3000 or more ATK and 2500 or less DEF from your Deck to your hand."
    },
    "fr": {
      "name": "La M\u00e9lodie du R\u00e9veil des Dragons",
      "effect": "D\u00e9faussez 1 carte ; ajoutez max. 2 monstres Dragon avec min. 3000 ATK et max. 2500 DEF depuis votre Deck \u00e0 votre main."
    },
    "de": {
      "name": "Die Melodie des erwachenden Drachen",
      "effect": "Wirf 1 Karte ab; f\u00fcge deiner Hand bis zu 2 Drache-Monster mit 3000 oder mehr ATK und 2500 oder weniger DEF von deinem Deck hinzu."
    },
    "it": {
      "name": "La Melodia del Drago che si Risveglia",
