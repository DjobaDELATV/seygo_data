  "$schema": "https://raw.githubusercontent.com/DjobaDELATV/seygo_data/main/schema/v1/card.json",
  "id": "5175978d-915a-46a8-b035-e3cb35a34c31",
  "text": {
    "en": {
      "name": "Cyberse Code Magician",
      "effect": "You can Ritual Summon this card with \"Cynet Ritual\". If a Link Monster you control would be used as Link Material for a Cyberse monster, this card in your hand can also be used as material. If this card is sent from the hand or field to the GY: You can send 1 Cyberse monster from your Deck to the GY, or if this Ritual Summoned card was sent to the GY, you can Special Summon that monster instead, also in either case, you cannot Special Summon for the rest of this turn, except Cyberse monsters. You can only use each effect of \"Cyberse Code Magician\" once per turn.",
      "official": false
    },
    "ja": {
      "name": "\u30b5\u30a4\u30d0\u30fc\u30b9\u30fb\u30b3\u30fc\u30c9\u30fb\u30de\u30b8\u30b7\u30e3\u30f3",
      "effect": "\u300c\u30b5\u30a4\u30d0\u30cd\u30c3\u30c8\u30fb\u30ea\u30c1\u30e5\u30fc\u30a2\u30eb\u300d\u306b\u3088\u308a\u964d\u81e8\n\u3053\u306e\u30ab\u30fc\u30c9\u540d\u306e\u2460\u2461\u306e\u52b9\u679c\u306f\u305d\u308c\u305e\u308c\uff11\u30bf\u30fc\u30f3\u306b\uff11\u5ea6\u3057\u304b\u4f7f\u7528\u3067\u304d\u306a\u3044\u3002\u2460\uff1a\u81ea\u5206\u30d5\u30a3\u30fc\u30eb\u30c9\u306e\uff2c\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u30b5\u30a4\u30d0\u30fc\u30b9\u65cf\uff2c\u30e2\u30f3\u30b9\u30bf\u30fc\u306e\uff2c\u7d20\u6750\u3068\u3059\u308b\u5834\u5408\u3001\u624b\u672d\u306e\u3053\u306e\u30ab\u30fc\u30c9\u3082\uff2c\u7d20\u6750\u306b\u3067\u304d\u308b\u3002\u2461\uff1a\u3053\u306e\u30ab\u30fc\u30c9\u304c\u624b\u672d\u30fb\u30d5\u30a3\u30fc\u30eb\u30c9\u304b\u3089\u5893\u5730\u3078\u9001\u3089\u308c\u305f\u5834\u5408\u306b\u767a\u52d5\u3067\u304d\u308b\u3002\u30c7\u30c3\u30ad\u304b\u3089\u30b5\u30a4\u30d0\u30fc\u30b9\u65cf\u30e2\u30f3\u30b9\u30bf\u30fc\uff11\u4f53\u3092\u5893\u5730\u3078\u9001\u308b\u3002\u5100\u5f0f\u53ec\u559a\u3057\u305f\u3053\u306e\u30ab\u30fc\u30c9\u304c\u5893\u5730\u3078\u9001\u3089\u308c\u3066\u3044\u305f\u5834\u5408\u3001\u30c7\u30c3\u30ad\u304b\u3089\u5893\u5730\u3078\u9001\u3089\u305a\u7279\u6b8a\u53ec\u559a\u3059\u308b\u4e8b\u3082\u3067\u304d\u308b\u3002\u3053\u306e\u30bf\u30fc\u30f3\u3001\u81ea\u5206\u306f\u30b5\u30a4\u30d0\u30fc\u30b9\u65cf\u30e2\u30f3\u30b9\u30bf\u30fc\u3057\u304b\u7279\u6b8a\u53ec\u559a\u3067\u304d\u306a\u3044\u3002"
    },
    "ko": {
      "name": "\uc0ac\uc774\ubc84\uc2a4 \ucf54\ub4dc \ub9e4\uc9c0\uc158",
      "effect": "\"\uc0ac\uc774\ubc14\ub137 \ub9ac\uce04\uc5bc\"\uc5d0 \uc758\ud574 \uc758\uc2dd \uc18c\ud658\n\uc774 \uce74\ub4dc\uba85\uc758 \u2460\u2461\uc758 \ud6a8\uacfc\ub294 \uac01\uac01 1\ud134\uc5d0 1\ubc88\ubc16\uc5d0 \uc0ac\uc6a9\ud560 \uc218 \uc5c6\ub2e4. \u2460: \uc790\uc2e0 \ud544\ub4dc\uc758 \ub9c1\ud06c \ubaac\uc2a4\ud130\ub97c \uc0ac\uc774\ubc84\uc2a4\uc871 \ub9c1\ud06c \ubaac\uc2a4\ud130\uc758 \ub9c1\ud06c \uc18c\uc7ac\ub85c \ud560 \uacbd\uc6b0, \ud328\uc758 \uc774 \uce74\ub4dc\ub3c4 \ub9c1\ud06c \uc18c\uc7ac\ub85c \ud560 \uc218 \uc788\ub2e4. \u2461: \uc774 \uce74\ub4dc\uac00 \ud328 / \ud544\ub4dc\uc5d0\uc11c \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uc84c\uc744 \uacbd\uc6b0\uc5d0 \ubc1c\ub3d9\ud560 \uc218 \uc788\ub2e4. \ub371\uc5d0\uc11c \uc0ac\uc774\ubc84\uc2a4\uc871 \ubaac\uc2a4\ud130 1\uc7a5\uc744 \ubb18\uc9c0\ub85c \ubcf4\ub0b8\ub2e4. \uc758\uc2dd \uc18c\ud658\ud55c \uc774 \uce74\ub4dc\uac00 \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uc838 \uc788\uc5c8\uc744 \uacbd\uc6b0, \ub371\uc5d0\uc11c \ubb18\uc9c0\ub85c \ubcf4\ub0b4\uc9c0 \uc54a\uace0 \ud2b9\uc218 \uc18c\ud658\ud560 \uc218\ub3c4 \uc788\ub2e4. \uc774 \ud134\uc5d0, \uc790\uc2e0\uc740 \uc0ac\uc774\ubc84\uc2a4\uc871 \ubaac\uc2a4\ud130\ubc16\uc5d0 \ud2b9\uc218 \uc18c\ud658\ud560 \uc218 \uc5c6\ub2e4."
    },
    "zh-CN": {
      "name": "\u7535\u5b50\u754c\u4ee3\u7801\u9b54\u672f\u5e08",
      "effect": "\u4ee5\u201c\u7535\u8111\u7f51\u4eea\u5f0f\u201d\u964d\u4e34\n\u6b64\u5361\u540d\u7684\u2460\u2461\u6548\u679c1\u56de\u5408\u4ec5\u53ef\u5404\u4f7f\u75281\u6b21\u3002\u2460\uff1a\u5728\u8981\u5c06\u81ea\u5df1\u573a\u4e0a\u7684\u8fde\u63a5\u602a\u517d\u4f5c\u4e3a\u7535\u5b50\u754c\u65cf\u8fde\u63a5\u602a\u517d\u7684\u8fde\u63a5\u7d20\u6750\u7684\u60c5\u51b5\u4e0b\uff0c\u624b\u724c\u7684\u6b64\u5361\u4e5f\u53ef\u4e00\u8d77\u4f5c\u4e3a\u8fde\u63a5\u7d20\u6750\u3002\u2461\uff1a\u6b64\u5361\u4ece\u624b\u724c\u30fb\u573a\u4e0a\u88ab\u9001\u81f3\u5893\u5730\u7684\u60c5\u51b5\u4e0b\u53ef\u4ee5\u53d1\u52a8\u3002\u4ece\u724c\u7ec4\u5c061\u53ea\u7535\u5b50\u754c\u65cf\u602a\u517d\u9001\u81f3\u5893\u5730\u3002\u88ab\u9001\u81f3\u5893\u5730\u7684\u6b64\u5361\u539f\u5148\u662f\u88ab\u4eea\u5f0f\u53ec\u5524\u7684\u60c5\u51b5\u4e0b\uff0c\u4e5f\u53ef\u5c06\u4ece\u724c\u7ec4\u9001\u81f3\u5893\u5730\u6539\u6210\u7279\u6b8a\u53ec\u5524\u3002\u6b64\u56de\u5408\uff0c\u81ea\u5df1\u4ec5\u53ef\u7279\u6b8a\u53ec\u5524\u7535\u5b50\u754c\u65cf\u602a\u517d\u3002"
    }
