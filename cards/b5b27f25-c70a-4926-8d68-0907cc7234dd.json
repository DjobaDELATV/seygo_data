      "effect": "\u4ec5\u53ef\u88c5\u5907\u4e8e\u9b54\u6cd5\u5e08\u65cf\u602a\u517d\u3002\u2460\uff1a\u88c5\u5907\u602a\u517d\u7684\u653b\u51fb\u529b\u4e0a\u5347500\u3002\u2461\uff1a\u5c06\u88c5\u5907\u602a\u517d\u548c\u6b64\u5361\u4ece\u81ea\u5df1\u573a\u4e0a\u9001\u81f3\u5893\u5730\u53ef\u4ee5\u53d1\u52a8\u3002\u81ea\u5df1\u4ece\u724c\u7ec4\u62bd2\u5f20\u3002"
