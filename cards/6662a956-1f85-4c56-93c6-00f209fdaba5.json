  "text": {
    "en": {
      "name": "Delinquent Duo",
      "effect": "Pay 1000 LP; your opponent discards 1 random card, and if they have any other cards in their hand, discard 1 more card of their choice."
    },
    "fr": {
      "name": "Duo de D\u00e9linquants",
      "effect": "Payez 1000 LP ; votre adversaire d\u00e9fausse 1 carte au hasard, et s'il a d'autres cartes dans sa main, il d\u00e9fausse 1 carte suppl\u00e9mentaire de son choix."
    },
    "de": {
      "name": "Verbrecher-Duo",
      "effect": "Zahle 1000 LP; dein Gegner wirft 1 zuf\u00e4llige Karte ab und falls er andere Karten in seiner Hand hat, wirft er 1 weitere Karte ab, die er bestimmt."
    },
    "it": {
      "name": "Due di Meno",
      "effect": "Paga 1000 LP; il tuo avversario scarta 1 carta a caso e, se ha altre carte nella sua mano, scarta 1 altra carta a sua scelta."
    },
    "pt": {
      "name": "Duo Delinquente",
      "effect": "Pague 1000 PV; seu oponente descarta 1 card aleat\u00f3rio e, se ele tiver qualquer outro card na m\u00e3o dele, ele descarta mais 1 card \u00e0 escolha dele."
    },
    "es": {
