  "text": {
    "en": {
      "name": "Left Arm of the Forbidden One",
      "effect": "A forbidden left arm sealed by magic. Whosoever breaks this seal will know infinite power."
    },
    "fr": {
      "name": "Bras Gauche de l'Interdit",
      "effect": "Bras gauche interdit scell\u00e9 par la magie. Toute personne rompant ce sceau conna\u00eetra la puissance infinie."
    },
    "de": {
      "name": "Linker Arm der Verbotenen",
      "effect": "Ein verbannter linker Arm, der durch einen Zauber versiegelt ist. Wer dieses Siegel bricht, erh\u00e4lt unbegrenzte Macht."
    },
    "it": {
      "name": "Braccio Sx del Proibito",
      "effect": "Un braccio sinistro proibito reso inaccessibile dalla magia. Chiunque rompa il sigillo che lo chiude conoscer\u00e0 potenza infinita."
    },
    "pt": {
      "name": "Bra\u00e7o Esquerdo de \"O Proibido\"",
      "effect": "Um bra\u00e7o esquerdo, proibido e selado por magia. Qualquer um que romper este selo obter\u00e1 poder infinito."
    },
    "es": {
      "name": "Brazo Izquierdo del Prohibido",
      "effect": "Un brazo izquierdo prohibido, sellado m\u00e1gicamente. Quienquiera que rompa este sello conocer\u00e1 el poder infinito."
    },
    "ja": {
