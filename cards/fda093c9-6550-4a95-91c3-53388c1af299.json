  "text": {
    "en": {
      "name": "Gottoms' Emergency Call",
      "effect": "If an \"X-Saber\" monster is on the field: Target 2 \"X-Saber\" monsters in any GY(s); Special Summon both to your field."
    },
    "fr": {
      "name": "Ordre de Ralliement de Gottoms",
      "effect": "Si un monstre \"Sabre X\" est sur le Terrain : ciblez 2 monstres \"Sabre X\" dans les Cimeti\u00e8res ; Invoquez-les Sp\u00e9cialement tous les deux sur votre Terrain."
    },
    "de": {
      "name": "Gottoms Notruf",
      "effect": "Falls ein \u201eX-S\u00e4bel\u201c-Monster auf dem Spielfeld liegt: W\u00e4hle 2 \u201eX-S\u00e4bel\u201c-Monster in beliebigen Friedh\u00f6fen; beschw\u00f6re beide als Spezialbeschw\u00f6rung auf deine Spielfeldseite."
    },
    "it": {
      "name": "Richiamo di Emergenza di Gottoms",
      "effect": "Se un mostro \"Sciabola-X\" \u00e8 sul Terreno: scegli come bersaglio 2 mostri \"Sciabola-X\" in qualsiasi Cimitero; Evoca Specialmente entrambi sul tuo Terreno."
    },
    "pt": {
      "name": "Chamada Emergencial de Gottoms",
      "effect": "Se um monstro \"Sabre-X\" estiver no campo: escolha 2 monstros \"Sabre-X\" em quaisquer Cemit\u00e9rios; Invoque os dois por Invoca\u00e7\u00e3o-Especial no seu campo."
    },
    "es": {
      "name": "La Llamada de Emergencia de Gottom",
      "effect": "Si un monstruo \"Sable-X\" est\u00e1 en el Campo: selecciona 2 monstruos \"Sable-X\" en cualquier Cementerio; Invoca ambos de Modo Especial a tu Campo."
    },
    "ja": {
