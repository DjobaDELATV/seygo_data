  "text": {
    "en": {
      "name": "Sabersaurus",
      "effect": "This normally gentle dinosaur enjoys relaxing in its nest in the prairies. If it becomes angered, it turns terribly ferocious."
    },
    "fr": {
      "name": "Sabresaure",
      "effect": "Ce dinosaure habituellement paisible aime \u00e0 se relaxer dans son repaire au c\u0153ur des prairies. Si on le met en col\u00e8re, il peut devenir terriblement f\u00e9roce."
    },
    "de": {
      "name": "S\u00e4belsaurier",
      "effect": "Dieser normalerweise sanfte Dinosaurier ruht sich gern in seinem Nest in der Pr\u00e4rie aus. Wenn er gereizt wird, wird er furchtbar wild."
    },
    "it": {
      "name": "Sciabolasaurus",
      "effect": "Questo dinosauro, normalmente di natura mite, ama rilassarsi nel suo nido nelle praterie. Se si arrabbia, diventa terribilmente feroce."
    },
    "pt": {
      "name": "Sabressauro",
      "effect": "Este dinossauro, normalmente gentil, gosta de relaxar em seu lar nas pradarias. Mas se ele se zanga, fica extremamente furioso."
    },
    "es": {
      "name": "Sablesaurio",
      "effect": "Este dinosaurio, gentil por lo general, disfruta relaj\u00e1ndose en su nido de la pradera. Si se lo enoja, se vuelve terriblemente feroz."
    },
