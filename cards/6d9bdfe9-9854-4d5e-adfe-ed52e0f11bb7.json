      "effect": "\u6b64\u5361\u540d\u5728\u89c4\u5219\u4e0a\u4e5f\u89c6\u4e3a\u201c\u9752\u773c\u201d\u5361\u3002\u6b64\u5361\u540d\u7684\u2460\u2461\u6548\u679c1\u56de\u5408\u4ec5\u53ef\u5404\u4f7f\u75281\u6b21\u3002\u2460\uff1a\u4ece\u624b\u724c\u5c06\u6b64\u5361\u820d\u5f03\u53ef\u4ee5\u53d1\u52a8\u3002\u4ece\u724c\u7ec4\u5c061\u53ea\u5149\u5c5e\u6027\u30fb\u7b49\u7ea71\u534f\u8c03\u52a0\u5165\u624b\u724c\u3002\u2461\uff1a\u6709\u201c\u9752\u773c\u201d\u4eea\u5f0f\u602a\u517d\u6216\u201c\u9752\u773c\u767d\u9f99\u201d\u88ab\u9001\u81f3\u81ea\u5df1\u5893\u5730\u7684\u60c5\u51b5\u4e0b\uff0c\u4ee5\u5176\u4e2d1\u53ea\u4e3a\u5bf9\u8c61\u53ef\u4ee5\u53d1\u52a8\u3002\u4ece\u624b\u724c\u30fb\u5893\u5730\u5c06\u6b64\u5361\u7279\u6b8a\u53ec\u5524\u3002\u4ee5\u6b64\u6548\u679c\u7279\u6b8a\u53ec\u5524\u7684\u6b64\u5361\uff0c\u653b\u51fb\u529b\u53d8\u4e3a\u4e0e\u5bf9\u8c61\u602a\u517d\u76f8\u540c\u3001\u4ece\u573a\u4e0a\u79bb\u5f00\u7684\u60c5\u51b5\u4e0b\uff0c\u5c06\u5176\u9664\u5916\u3002"
